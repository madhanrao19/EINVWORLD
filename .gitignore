# ---- Build output ----
[Bb]in/
[Oo]bj/
[Pp]ublish/
publish/
*.user
*.suo
.vs/

# ---- Secrets & certificates (NEVER commit) ----
# appsettings.json should contain only placeholders; if you must keep a filled copy locally, ignore it:
appsettings.*.local.json
secrets.json
*.p12
*.pfx
# DataProtection key ring written locally (contains encryption keys — NEVER commit).
LocalKeys/

# ---- Node / Playwright QA harness ----
node_modules/
test-results/
playwright-report/
/playwright/.cache/
*.pem
Cert/

# web.config can carry environment variables / secrets on the server
web.config

# ---- Data Protection keys (machine-specific; back up separately, don't commit) ----
DataProtectionKeys/

# ---- Runtime data / generated artifacts ----
# Anchor to repo root so this only ignores the Serilog output dir (logs/log.txt), NOT source
# directories like Pages/Admin/Logs/ or Models/Logs/ (git is case-insensitive on Windows).
/logs/
Documents/
invoice-counter.txt

# ---- Backups / scratch ----
*.bak
*.bak-*
EINVWORLD.csproj.bak-net8

# ---- OS / editor ----
Thumbs.db
.DS_Store

# Claude Code per-machine settings (may contain local credentials in permission entries)
.claude/settings.local.json

# ---- Local scratch + machine-specific deploy profile (internal host/user details) ----
/temp/
Properties/PublishProfiles/IISProfile.pubxml
