<div class="row">
    <div class="col-lg-12">
        <div class="text-center mt-sm-5 mb-4 text-white-50">
            <div>
                <a href="/" class="d-inline-block auth-logo">
                    <img src="~/images/einvworld-logo.png" alt="eInvWorld" style="width: 100px; height: auto;" class="me-2">
                </a>
            </div>
            <p class="mt-3 fs-15 fw-medium">eInvWorld</p>
        </div>
    </div>
</div>
<!-- end row -->

@* Stitch reference 4: left-aligned dark title + plain sentence, uppercase label,
   primary action with a mail icon, then a quiet "back to login" line under a divider. *@
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 col-xl-5">
        <div class="card mt-4 card-bg-fill">
            <div class="card-body p-4">
                <h4 class="fw-bold fs-3 mb-2">Forgot Password</h4>
                <p class="text-muted mb-4">Enter your email address and we&rsquo;ll email you a link to reset your password.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label text-uppercase fw-semibold small" style="letter-spacing:.05em;">Email address</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Enter email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- ✅ Include Honeypot & Turnstile -->
                    <partial name="_TurnstilePartial" />

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="ri-mail-line me-1" aria-hidden="true"></i> Send me a reset link
                        </button>
                    </div>
                </form>

                <hr class="my-4">
                <p class="text-center mb-0">Forget it, <a asp-page="/Account/Login" class="fw-semibold">send me back to the login screen</a></p>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
