@page "/login"
@model LoginModel
@{
    ViewData["Title"] = "Login | eInvWorld";
    ViewData["Description"] = "Access your eInvWorld account to manage and submit LHDN-compliant e-Invoices efficiently and securely.";
    ViewData["Keywords"] = "login einvworld, e-invoicing portal login, Malaysia LHDN e-invoice, user login";
}
    <div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(255,255,255,0.8); z-index: 9999; text-align: center;">
        <div class="d-flex justify-content-center align-items-center h-100">
            <div>
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <div class="mt-3 fw-semibold text-primary">Logging in...</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="text-center mt-sm-5 mb-4 text-white-50">
                <div>
                    <a href="/" class="d-inline-block auth-logo">
                        <img src="~/images/einvworld-logo.png" alt="eInvWorld" style="width: 100px; height: auto;" class="me-2">
                    </a>
                </div>
                <p class="mt-3 fs-15 fw-medium">eInvWorld</p>
            </div>
        </div>
    </div>
    <!-- end row -->

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="card">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <h5 class="text-primary">Welcome Back</h5>
                        <p class="text-muted mb-0">Sign in to continue to eInvWorld.</p>
                    </div>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="mb-3">
                            <label for="username" class="form-label">Username</label>
                            <div class="einv-input">
                                <i class="einv-input-ic ri-user-3-line" aria-hidden="true"></i>
                                <input asp-for="Input.UserName" class="form-control" id="username" autocomplete="username" aria-required="true" placeholder="Enter your username" />
                            </div>
                            <span asp-validation-for="Input.UserName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0" for="password-input">Password</label>
                                <a id="forgot-password" href="/forgot-password">Forgot password?</a>
                            </div>
                            <div class="einv-input auth-pass-inputgroup mt-1">
                                <i class="einv-input-ic ri-lock-2-line" aria-hidden="true"></i>
                                <input type="password" asp-for="Input.Password" class="form-control pe-5 password-input" autocomplete="current-password" aria-required="true" placeholder="Enter your password" id="password-input" />
                                <button class="btn btn-link password-addon" type="button" id="password-addon" aria-label="Show password"><i class="ri-eye-fill align-middle"></i></button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" value="" id="auth-remember-check">
                            <label class="form-check-label" for="auth-remember-check">Remember me</label>
                        </div>

                        <partial name="_TurnstilePartial" />

                        <div class="mt-3">
                            <button id="login-submit" type="submit" class="w-100 btn btn-primary">Login</button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- end card -->

            <div class="mt-3 text-center">
                <p class="mb-1 text-white">Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold">Register as a new user</a></p>
                <p class="mb-0"><a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="fw-semibold">Resend email confirmation</a></p>
            </div>
        </div>
    </div>
    <!-- end row -->
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const loginForm = document.getElementById("account");
            const loginButton = document.getElementById("login-submit");
            const overlay = document.getElementById("loadingOverlay");

            if (loginForm) {
                loginForm.addEventListener("submit", function () {
                    overlay.style.display = "block";
                    loginButton.disabled = true;

                    // ⏱️ After 3 seconds, check if an error is shown
                    setTimeout(() => {
                        const errorSummary = document.querySelector('[asp-validation-summary="ModelOnly"]');
                        const errorItems = errorSummary?.querySelectorAll("li");
                        if (errorItems?.length > 0) {
                            overlay.style.display = "none";
                            loginButton.disabled = false;
                        }
                    }, 3000); // Give server round-trip time
                });
            }

            

            // const params = new URLSearchParams(window.location.search);
            // const reason = params.get("logoutReason");

            // if (reason === "timeout") {
            //     Swal.fire({
            //         icon: 'info',
            //         title: 'Session Ended',
            //         text: 'You were logged out due to inactivity.',
            //         confirmButtonText: 'OK'
            //     });
            // } else if (reason === "manual") {t
            //     Swal.fire({
            //         icon: 'info',
            //         title: 'Logged Out',
            //         text: 'You have successfully logged out.',
            //         confirmButtonText: 'OK'
            //     });
            // }

            // if (reason) {
            //     window.history.replaceState({}, document.title, window.location.pathname);
            // }

        });
    </script>

