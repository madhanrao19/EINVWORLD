@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Two-factor authentication";
}

<div class="row">
    <div class="col-lg-12">
        <div class="text-center mt-sm-5 mb-4 text-white-50">
            <div>
                <a href="/" class="d-inline-block auth-logo">
                    <img src="~/images/einvworld-logo-light.png" alt="" style="width: 100px; height: auto;" class="me-2">
                </a>
            </div>
            <p class="mt-3 fs-15 fw-medium">eInvWorld</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 col-xl-5">
        <div class="card mt-4 card-bg-fill">
            <div class="card-body p-4">

                <div class="text-center mt-2">
                    <div class="avatar-lg mx-auto">
                        <div class="avatar-title bg-light text-primary display-5 rounded-circle">
                            <i class="ri-shield-keyhole-line"></i>
                        </div>
                    </div>
                    <h5 class="text-primary mt-4">Two-Step Verification</h5>
                    <p class="text-muted">Enter the 6-digit code from your authenticator app.</p>
                </div>

                <div class="p-2 mt-4">
                    <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                        <input asp-for="RememberMe" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Input.TwoFactorCode" class="form-label">Authenticator Code</label>
                            <input asp-for="Input.TwoFactorCode" class="form-control text-center fs-18" autocomplete="off" placeholder="XXXXXX" style="letter-spacing: 5px;" />
                            <span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Input.RememberMachine" class="form-check-input" />
                            <label asp-for="Input.RememberMachine" class="form-check-label">
                                Don't ask again on this device
                            </label>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary w-100">Confirm & Login</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="mt-4 text-center">
            <p class="mb-0">
                Don't have access to your device?
                <a id="recovery-code-login" asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold text-primary text-decoration-underline">
                    Use a recovery code
                </a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}