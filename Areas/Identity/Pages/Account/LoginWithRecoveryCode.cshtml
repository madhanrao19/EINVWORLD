@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code verification";
}

<div class="row">
    <div class="col-lg-12">
        <div class="text-center mt-sm-5 mb-4 text-white-50">
            <div>
                <a href="/" class="d-inline-block auth-logo">
                    <img src="~/images/einvworld-logo-light.png" alt="" style="width: 100px; height: auto;" class="me-2">
                </a>
            </div>
            <p class="mt-3 fs-15 fw-medium">eInvWorld</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 col-xl-5">
        <div class="card mt-4 card-bg-fill">
            <div class="card-body p-4">

                <div class="text-center mt-2">
                    <div class="avatar-lg mx-auto">
                        <div class="avatar-title bg-light text-warning display-5 rounded-circle">
                            <i class="ri-lock-unlock-line"></i>
                        </div>
                    </div>
                    <h5 class="text-primary mt-4">Recovery Login</h5>
                    <p class="text-muted">You have requested to log in with a recovery code. This login will not be remembered until you provide an authenticator app code at login or disable 2FA and log in again.</p>
                </div>

                <div class="p-2 mt-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Input.RecoveryCode" class="form-label">Recovery Code</label>
                            <input asp-for="Input.RecoveryCode" class="form-control text-center fs-18" autocomplete="off" placeholder="XXXXXX" />
                            <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary w-100">Log in</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="mt-4 text-center">
            <p class="mb-0">
                Found your device?
                <a asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold text-primary text-decoration-underline">
                    Use Authenticator App
                </a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}