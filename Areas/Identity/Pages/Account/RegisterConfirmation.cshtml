@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Email Confirmation";
}

<div class="row">
    <div class="col-lg-12">
        <div class="text-center mt-sm-5 mb-4 text-white-50">
            <div>
                <a href="/" class="d-inline-block auth-logo">
                    <img src="~/images/einvworld-logo.png" alt="eInvWorld Logo" style="width: 100px; height: auto;" class="me-2">
                </a>
            </div>
            <p class="mt-3 fs-15 fw-medium">eInvWorld</p>
        </div>
    </div>
</div>
<!-- end row -->

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 col-xl-5">
        <div class="card mt-4 card-bg-fill">
            <div class="card-body p-4">
                <div class="text-center mt-2">
                    <h5 class="text-primary">Confirm Your Email</h5>
                    <p class="text-muted">
                        A confirmation email has been sent to <strong>@Model.Email</strong>.
                        Please check your inbox and click the verification link to activate your account.
                    </p>
                </div>

                @* <div class="p-2">
                    <p class="text-center">
                        Didn't receive an email? <a asp-page="./ResendConfirmationEmail">Resend Email</a>
                    </p>
