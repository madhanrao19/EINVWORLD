@page
@model eInvWorld.Pages.Admin.Codes.UnitTypes.ListUnitTypeModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Unit Types List";

    string GetSortUrl(string column)
    {
        string newSortOrder = (Model.SortBy == column && Model.SortOrder == "asc") ? "desc" : "asc";
        return Url.Page(null, new { SortBy = column, SortOrder = newSortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter, CurrentPage = Model.CurrentPage }) ?? "#";
    }

    Microsoft.AspNetCore.Html.IHtmlContent GetSortIcon(string column)
    {
        if (Model.SortBy == column)
        {
            return Html.Raw(Model.SortOrder == "asc" ? "<i class='ri-arrow-up-s-fill ms-1'></i>" : "<i class='ri-arrow-down-s-fill ms-1'></i>");
        }
        return Html.Raw("");
    }
}

<h2>Unit Types</h2>

<form method="get" class="mb-4">
    <input type="hidden" name="SortBy" value="@Model.SortBy" />
    <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <input type="text" asp-for="SearchTerm" class="form-control" placeholder="Search by Code or Name..." />
        </div>
        <div class="col-md-3">
            <select asp-for="StatusFilter" class="form-select">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
                <option value="">All Statuses</option>
            </select>
        </div>
        <div class="col-md-5">
            <button type="submit" class="btn btn-primary"><i class="ri-search-line align-bottom me-1"></i> Filter</button>
            <a asp-page="./ListUnitType" class="btn btn-soft-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table id="dataTable" class="table table-sm table-bordered table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>
                    <a href="@GetSortUrl("code")" class="text-white text-decoration-none">
                        Code @GetSortIcon("code")
                    </a>
                </th>
                <th>
                    <a href="@GetSortUrl("name")" class="text-white text-decoration-none">
                        Name @GetSortIcon("name")
                    </a>
                </th>
                <th>Updated By</th>
                <th>Updated Date</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.UnitTypes.Any())
            {
                @foreach (var unitType in Model.UnitTypes)
                {
                    <tr>
                        <td>@unitType.Code</td>
                        <td>@unitType.Name</td>
                        <td>@(string.IsNullOrEmpty(unitType.UpdatedBy) ? "-" : unitType.UpdatedBy)</td>
                        <td>@(unitType.UpdatedDate?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No unit types found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (Model.TotalPages > 1)
{
    // Calculate sliding window for pagination
    int maxPagesToShow = 5; // Change this if you want to show more/less numbers
    int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
    int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);

    if (endPage - startPage + 1 < maxPagesToShow)
    {
        startPage = Math.Max(1, endPage - maxPagesToShow + 1);
    }

    <div class="row mt-3 align-items-center">
        <div class="col-sm">
            <div class="text-muted">
                Showing <span class="fw-semibold">@(((Model.CurrentPage - 1) * Model.PageSize) + 1)</span> to
                <span class="fw-semibold">@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)</span> of
                <span class="fw-semibold">@Model.TotalRecords</span> entries
            </div>
        </div>
        <div class="col-sm-auto">
            <ul class="pagination pagination-separated pagination-sm justify-content-center justify-content-sm-start mb-0">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage - 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter })">Previous</a>
                </li>

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Page(null, new { CurrentPage = 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter })">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Page(null, new { CurrentPage = i, SortBy = Model.SortBy, SortOrder = Model.SortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter })">@i</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.TotalPages, SortBy = Model.SortBy, SortOrder = Model.SortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter })">@Model.TotalPages</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage + 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, SearchTerm = Model.SearchTerm, StatusFilter = Model.StatusFilter })">Next</a>
                </li>
            </ul>
        </div>
    </div>
}