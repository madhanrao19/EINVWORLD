@page
@model eInvWorld.Pages.Admin.SystemHealthModel
@{
    ViewData["Title"] = "System Health";
}

<h3 class="mb-3">🩺 System Health</h3>
<p class="text-muted">A snapshot for on-prem operators. Times/ages are UTC.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Application</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Version</dt><dd class="col-6">@Model.Version</dd>
                    <dt class="col-6">Environment</dt><dd class="col-6">@Model.Environment</dd>
                    <dt class="col-6">Runtime</dt><dd class="col-6">@Model.Runtime</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Background jobs</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Queued</dt><dd class="col-6">@Model.QueuedJobs</dd>
                    <dt class="col-6">Running</dt><dd class="col-6">@Model.RunningJobs</dd>
                    <dt class="col-6">Failed</dt>
                    <dd class="col-6">
                        <span class="@(Model.FailedJobs > 0 ? "text-danger fw-semibold" : "")">@Model.FailedJobs</span>
                        @if (Model.FailedJobs > 0)
                        {
                            <a asp-page="/Admin/SyncJobs" class="ms-2 small">review</a>
                        }
                    </dd>
                    <dt class="col-6">Oldest queued</dt><dd class="col-6">@Model.OldestQueuedAge</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Data stores</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Audit rows</dt>
                    <dd class="col-6">@(Model.AuditRows < 0 ? "unavailable" : Model.AuditRows.ToString("N0"))</dd>
                    <dt class="col-6">Submission records</dt>
                    <dd class="col-6">@(Model.SubmissionRecords < 0 ? "unavailable" : Model.SubmissionRecords.ToString("N0"))</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Infrastructure</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">DataProtection keys</dt><dd class="col-7"><small>@Model.KeyRingStatus</small></dd>
                    <dt class="col-5">Documents disk</dt><dd class="col-7"><small>@Model.DocumentsDisk</small></dd>
                    <dt class="col-5">Signing cert</dt>
                    <dd class="col-7">
                        <small class="@(Model.SigningCert.Contains("EXPIRED") || Model.SigningCert.Contains("expiring") ? "text-danger fw-semibold" : "")">@Model.SigningCert</small>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header fw-semibold">🔐 PII encryption (maintenance)</div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.PiiBackfillMessage))
        {
            <div class="alert @(Model.PiiBackfillFailed ? "alert-danger" : "alert-success") py-2">
                @Model.PiiBackfillMessage
            </div>
        }
        <p class="mb-2 small text-muted">
            Bank account numbers and secondary/tertiary address lines are encrypted at rest with the
            DataProtection key-ring. New and edited records are encrypted automatically. Use this one-time
            action to encrypt <strong>existing</strong> rows that predate this feature. It is safe to run
            more than once — already-encrypted rows are skipped.
        </p>
        <div class="alert alert-warning py-2 small mb-2">
            <strong>Before running:</strong> take a full database backup and confirm the DataProtection
            key-ring folder is backed up. Losing the key-ring makes these columns permanently unreadable.
        </div>
        <form method="post" asp-page-handler="EncryptPii"
              onsubmit="return confirm('Encrypt existing PII values now? Ensure a database backup has been taken first. This is safe to re-run.');">
            <button type="submit" class="btn btn-outline-primary btn-sm">Encrypt existing PII</button>
        </form>
    </div>
</div>
