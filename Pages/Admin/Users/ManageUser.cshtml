@page
@model eInvWorld.Pages.Admin.Users.ManageUserModel
@{
    ViewData["Title"] = "User & Role Management";

    // Helper to differentiate role colors
    string GetRoleBadgeColor(string role) => role.ToLower() switch
    {
        "admin" => "bg-danger",       // Red
        "supplier" => "bg-primary",    // Blue
        "buyer" => "bg-success",      // Green
        "intermediary" => "bg-info",   // Cyan/Teal
        _ => "bg-secondary"            // Grey
    };

    string GetSortUrl(string column)
    {
        string newSortOrder = (Model.SortBy == column && Model.SortOrder == "asc") ? "desc" : "asc";
        return Url.Page(null, new { SortBy = column, SortOrder = newSortOrder, searchName = Model.SearchName, searchEmail = Model.SearchEmail, CurrentPage = Model.CurrentPage }) ?? "#";
    }

    Microsoft.AspNetCore.Html.IHtmlContent GetSortIcon(string column)
    {
        if (Model.SortBy == column)
        {
            return Html.Raw(Model.SortOrder == "asc" ? "<i class='ri-arrow-up-s-fill ms-1'></i>" : "<i class='ri-arrow-down-s-fill ms-1'></i>");
        }
        return Html.Raw("");
    }
}

<div class="container-fluid p-4">
    <div class="mb-4">
        <h2 class="fw-bold text-dark">User & Role Management</h2>
        <p class="text-muted">Manage users and roles</p>
    </div>

    <div class="card shadow-sm border-0 bg-white">
        <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center p-3">
            <h4 class="mb-0 text-dark">All Users</h4>
            <div class="d-flex gap-2">
                <a asp-page="/Admin/Users/AddEditUser" class="btn btn-primary btn-sm px-3">
                    <i class="ri-user-add-line me-1"></i> Add New User
                </a>
            </div>
        </div>

        <div class="card-body bg-light border-bottom">
            <form method="get">
                <input type="hidden" name="SortBy" value="@Model.SortBy" />
                <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="searchName" class="form-control" placeholder="Search by Name" value="@Model.SearchName" />
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="searchEmail" class="form-control" placeholder="Search by Email" value="@Model.SearchEmail" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-secondary">Filter</button>
                        <button type="button" class="btn btn-danger" onclick="clearFilters()">Clear</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="text-muted small text-uppercase bg-light">
                    <tr>
                        <th class="ps-4"><a href="@GetSortUrl("name")" class="text-dark text-decoration-none">User @GetSortIcon("name")</a></th>
                        <th>Roles</th>
                        <th><a href="@GetSortUrl("status")" class="text-dark text-decoration-none">Approval Status @GetSortIcon("status")</a></th>
                        <th><a href="@GetSortUrl("updatedby")" class="text-dark text-decoration-none">Updated By @GetSortIcon("updatedby")</a></th>
                        <th><a href="@GetSortUrl("updateddate")" class="text-dark text-decoration-none">Updated Date @GetSortIcon("updateddate")</a></th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@user.FullName</div>
                                    <div class="small text-muted">@user.Email</div>
                                </td>
                                <td>
                                    @if (Model.UserRoles.ContainsKey(user.Id))
                                    {
                                        @foreach (var role in Model.UserRoles[user.Id])
                                        {
                                            <span class="badge rounded-pill @GetRoleBadgeColor(role) px-2 py-1 me-1">@role.ToLower()</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="form-check form-switch me-2">
                                            <input class="form-check-input" type="checkbox"
                                                   onchange="confirmApprovalChange('@user.Id', '@user.IsApproved')"
                                                   @(user.IsApproved ? "checked" : "") />
                                        </div>
                                        <span class="small @(user.IsApproved ? "text-success" : "text-warning")">
                                            @(user.IsApproved ? "Approved" : "Pending")
                                        </span>
                                    </div>
                                </td>
                                <td>@(string.IsNullOrEmpty(user.UpdatedBy) ? "-" : user.UpdatedBy)</td>
                                <td>@(user.UpdatedDate?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-link text-muted p-0 shadow-none" type="button" data-bs-toggle="dropdown">
                                            <i class="ri-more-2-fill fs-4"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li>
                                                <a class="dropdown-item" href="javascript:void(0);" onclick="openAddRoleModal('@user.Id', '@user.FullName')">
                                                    <i class="ri-shield-user-line me-2 text-primary"></i>Change Role
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" asp-page="/Admin/Users/AddEditUser" asp-route-id="@user.Id"><i class="ri-edit-line me-2"></i>Edit User</a></li>
                                            <li>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline" onsubmit="return confirm('Permanently delete this user?');">
                                                    <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                                                    <input type="hidden" name="SortBy" value="@Model.SortBy" />
                                                    <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                                                    <input type="hidden" name="SearchName" value="@Model.SearchName" />
                                                    <input type="hidden" name="SearchEmail" value="@Model.SearchEmail" />
                                                    <button type="submit" class="dropdown-item text-danger"><i class="ri-delete-bin-line me-2"></i>Delete</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-transparent border-top">
                <div class="row align-items-center">
                    <div class="col-sm">
                        <div class="text-muted small">
                            Showing <span class="fw-semibold">@(((Model.CurrentPage - 1) * Model.PageSize) + 1)</span> to
                            <span class="fw-semibold">@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)</span> of
                            <span class="fw-semibold">@Model.TotalRecords</span> entries
                        </div>
                    </div>
                    <div class="col-sm-auto">
                        <ul class="pagination pagination-sm justify-content-center justify-content-sm-start mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage - 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchEmail = Model.SearchEmail })">Previous</a>
                            </li>

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Page(null, new { CurrentPage = i, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchEmail = Model.SearchEmail })">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage + 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchEmail = Model.SearchEmail })">Next</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="addRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Change Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="addRoleModalLabel" class="text-muted mb-4 small"></p>
                <form method="post" asp-page-handler="AssignRole">
                    <input type="hidden" name="userId" id="addRoleUserId" />
                    <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                    <input type="hidden" name="SortBy" value="@Model.SortBy" />
                    <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                    <input type="hidden" name="SearchName" value="@Model.SearchName" />
                    <input type="hidden" name="SearchEmail" value="@Model.SearchEmail" />
                    <div class="list-group list-group-flush border-top">
                        @foreach (var role in Model.AllRoles)
                        {
                            <button type="submit" name="roleName" value="@role.Name" class="list-group-item list-group-item-action py-3 d-flex justify-content-between">
                                @role.Name <i class="ri-add-circle-line text-primary"></i>
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="removeRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Remove Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="removeRoleModalLabel" class="text-muted mb-4 small"></p>
                <form method="post" asp-page-handler="RemoveRolePost">
                    <input type="hidden" name="userId" id="removeRoleUserId" />
                    <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
                    <input type="hidden" name="SortBy" value="@Model.SortBy" />
                    <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                    <input type="hidden" name="SearchName" value="@Model.SearchName" />
                    <input type="hidden" name="SearchEmail" value="@Model.SearchEmail" />
                    <div class="list-group list-group-flush border-top">
                        @foreach (var role in Model.AllRoles)
                        {
                            <button type="submit" name="roleName" value="@role.Name" class="list-group-item list-group-item-action py-3 d-flex justify-content-between text-danger">
                                @role.Name <i class="ri-indeterminate-circle-line"></i>
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddRoleModal(id, name) {
            document.getElementById('addRoleUserId').value = id;
            document.getElementById('addRoleModalLabel').innerText = "Assign a role to " + name;
            new bootstrap.Modal(document.getElementById('addRoleModal')).show();
        }

        function openRemoveRoleModal(id, name) {
            document.getElementById('removeRoleUserId').value = id;
            document.getElementById('removeRoleModalLabel').innerText = "Select a role to remove from " + name;
            new bootstrap.Modal(document.getElementById('removeRoleModal')).show();
        }

        function confirmApprovalChange(id, currentStatus) {
            const handler = currentStatus.toLowerCase() === "true" ? "Disapprove" : "Approve";

            // Pass all sorting/pagination values to maintain state after approval
            const currentPage = '@Model.CurrentPage';
            const sortBy = '@Model.SortBy';
            const sortOrder = '@Model.SortOrder';
            const searchName = '@(Model.SearchName ?? "")';
            const searchEmail = '@(Model.SearchEmail ?? "")';

            window.location.href = `?handler=${handler}&id=${id}&currentPage=${currentPage}&sortBy=${sortBy}&sortOrder=${sortOrder}&searchName=${searchName}&searchEmail=${searchEmail}`;
        }

        function clearFilters() {
            const url = new URL(window.location.href);
            url.searchParams.delete("searchName");
            url.searchParams.delete("searchEmail");
            url.searchParams.delete("SortBy");
            url.searchParams.delete("SortOrder");
            url.searchParams.delete("CurrentPage");
            window.location.href = url.toString();
        }
    </script>
}