                                                else if (item.LHDNStatusId == "Invalid")
                                                {
                                                    <span class="badge rounded-pill bg-danger text-white ms-1 shadow-sm"><i class="ri-error-warning-line me-1"></i>Action Req.</span>
                                                }
                                            </td>
                                            <td class="text-muted small">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                            <td class="text-end pe-4">
                                                <a class="btn btn-sm @(isHighRisk ? "btn-danger" : "btn-light border") fw-semibold shadow-sm transition-hover" href="/Invoices/InvoiceDetails2/@(string.IsNullOrEmpty(item.UUID) ? item.InvoiceNo : item.UUID)">
                                                    @(isHighRisk ? "View Issue" : "Review")
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="6" class="text-center py-5 text-muted"><i class="ri-inbox-line fs-3 d-block mb-2 text-light"></i>No invoices found for the selected filters.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@section Scripts {
    <script src="/assets/libs/chart.js/chart.umd.js"></script>
    <script src="/assets/libs/chartjs-plugin-zoom/chartjs-plugin-zoom.min.js"></script> 
    <script src="~/js/dashboard.js"></script>
}