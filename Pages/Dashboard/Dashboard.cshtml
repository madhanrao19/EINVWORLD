@page
@model eInvWorld.Pages.Invoices.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}


<style>
    :root {
        --primary-soft: #eef2ff;
        --primary-text: #4f46e5;
        --success-soft: #f0fdf4;
        --success-text: #16a34a;
        --danger-soft: #fef2f2;
        --danger-text: #dc2626;
        --warning-soft: #fffbeb;
        --warning-text: #d97706;
        --chart-bg: #ffffff;
    }

    /* Consolidated Card Aesthetics */
    .card {
        background: var(--card-bg) !important;
        border: 1px solid var(--card-border) !important;
        border-radius: 12px !important; /* Slightly sharper corners as per image */
        box-shadow: none !important;
        transition: none !important;
    }

        .card:hover {
            transform: none !important;
        }

    /* KPI Icon Box Styling */
    .icon-box {
        background: transparent !important; /* Image shows subtle outlines or transparent backgrounds */
        color: var(--text-muted) !important;
        font-size: 1.2rem;
        margin-bottom: 0;
        width: auto;
        height: auto;
    }

    /* Typography Overrides */
    .metric-value {
        font-size: 2rem !important;
        font-weight: 700 !important;
        color: var(--text-main) !important;
        margin: 0.5rem 0;
    }

    .metric-label-top {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-main);
    }

    .metric-label-bottom {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    /* Status Dot Indicators (Bottom row of the image) */
    .status-dot {
        height: 10px;
        width: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

    /* Wave Background Decorations */
    .wave-container {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        line-height: 0;
        z-index: 1;
    }

    .wave-svg {
        width: 100%;
        height: 60px;
    }

    /* Chart Headers */
    .card-header-clean {
        background: transparent;
        border-bottom: none;
        padding: 1.5rem 1.5rem 0.5rem 1.5rem;
    }

        .card-header-clean h5 {
            font-weight: 600;
            color: #374151;
        }

    /* Styling for Quick Action Buttons and Table Badges */
    .bg-success-soft {
        background-color: var(--success-soft);
        color: var(--success-text);
    }

    .bg-warning-soft {
        background-color: var(--warning-soft);
        color: var(--warning-text);
    }

    .btn-primary {
        background-color: var(--primary-text);
        border-color: var(--primary-text);
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
    }

    .table thead th {
        border-top: none;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
    }

    .transition-hover {
        transition: all 0.2s ease-in-out;
    }

    .transition-hover:hover {
        box-shadow: 0 6px 15px rgba(0,0,0,0.1) !important;
        transform: translateY(-2px); /* A slight lift up looks more natural for buttons than shifting right */
    }

    /* Force calendar picker to open when clicking anywhere on the input */
    #filterDate {
        position: relative;
    }
    
        #filterDate::-webkit-calendar-picker-indicator {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }
</style>

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h4 class="fw-bold text-dark mb-1">Dashboard Overview</h4>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 bg-transparent p-0">
                        <li class="breadcrumb-item text-muted">Dashboards</li>
                        <li class="breadcrumb-item active fw-semibold text-primary">Overview</li>
                    </ol>
                </nav>
            </div>
            
            <form method="get" id="filterForm" class="d-flex flex-wrap align-items-center gap-2 bg-white p-2 rounded shadow-sm border">
                <select name="FilterType" id="filterType" class="form-select form-select-sm border-0" style="width: 110px; background-color: var(--primary-soft); color: var(--primary-text); font-weight: 600;">
                    <option value="Day" selected="@(Model.FilterType == "Day")">Specific Day</option>
                    <option value="Month" selected="@(Model.FilterType == "Month")">Full Month</option>
                    <option value="Year" selected="@(Model.FilterType == "Year")">Full Year</option>
                </select>
    
                <input id="filterDate"
                       type="@(Model.FilterType == "Month" ? "month" : "date")"
                       class="form-control form-control-sm border-0"
                       value="@(Model.FilterType == "Month" ? Model.FilterDate?.ToString("yyyy-MM") : Model.FilterDate?.ToString("yyyy-MM-dd"))"
                       data-default-date="@(Model.FilterDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))"
                       style="width: 160px; cursor: pointer;"
                       onkeydown="return false;" />
           
                <select id="filterYear" class="form-select form-select-sm border-0" style="width: 160px; display: none;">
                    @for (int i = 2020; i <= DateTime.Now.Year + 5; i++)
                    {
                        <option value="@i-01-01" selected="@(Model.FilterDate?.Year == i)">@i</option>
                    }
                </select>
           
                <button type="submit" class="btn btn-sm btn-primary px-3 rounded">Apply</button>
            </form>
        </div>
    </div>
</div>

