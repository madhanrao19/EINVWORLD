    // --- Generate bulletproof Start and End dates for the Invoice List ---
    DateTime baseDate = Model.FilterDate ?? DateTime.Now;
    DateTime start, end;

    if (Model.FilterType == "Day")
    {
        start = baseDate.Date;
        end = baseDate.Date.AddDays(1).AddTicks(-1);
    }
    else if (Model.FilterType == "Year")
    {
        start = new DateTime(baseDate.Year, 1, 1);
        end = new DateTime(baseDate.Year, 12, 31, 23, 59, 59);
    }
    else
    {
        start = new DateTime(baseDate.Year, baseDate.Month, 1);
        end = start.AddMonths(1).AddTicks(-1);
    }

    string dateParams = $"&submissionDateFrom={start:s}&submissionDateTo={end:s}";

