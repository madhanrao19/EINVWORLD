@page
@model eInvWorld.Pages.Invoices.DashboardBuyerModel
@{
    ViewData["Title"] = "Buyer Dashboard";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Header Section -->
    <div class="mb-3">
        <h1>Buyer Dashboard</h1>
    </div>

    <!-- KPI Section - Single Row with 6 Cards -->
    <div class="row justify-content-center">
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Invoices</h5>
                    <h2 class="fw-bold">@Model.TotalInvoices</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Submitted</h5>
                    <h2 class="fw-bold">@Model.SubmittedInvoices</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Valid</h5>
                    <h2 class="fw-bold">@Model.ValidInvoices</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Invalid</h5>
                    <h2 class="fw-bold">@Model.InvalidInvoices</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Cancelled</h5>
                    <h2 class="fw-bold">@Model.CancelledInvoices</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 shadow text-center">
                <div class="card-body">
                    <h5 class="card-title">Request Reject</h5>
                    <h2 class="fw-bold">@Model.RejectRequestInvoices</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Row 1: Pie & Doughnut Charts -->
        <div class="col-lg-6 col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Invoice Status Breakdown</h5>
                </div>
                <div class="card-body">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6 col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Invoice Type Breakdown</h5>
                </div>
                <div class="card-body">
                    <canvas id="invoiceTypesChart"></canvas> <!--approvalChart-->
                </div>
            </div>
        </div>

        <!-- Row 2: Line & Bar Charts -->
        <div class="col-lg-6 col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Rejected Reasons Distribution</h5>
                </div>
                <div class="card-body">
                    <canvas id="rejectedReasonsChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6 col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Invoices by Customer</h5>
                </div>
                <div class="card-body">
                    <canvas id="customerChart"></canvas>
                </div>
            </div>
        </div>

        @* <div class="col-lg-6 col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Invoice Type Breakdown</h5>
                </div>
                <div class="card-body">
                    <canvas id="invoiceTypesChart"></canvas>
                </div>
            </div>
        </div> *@

        <!-- Row 3: Stacked Bar for Monthly Breakdown -->
        <div class="col-lg-12">
            <div class="card border-0 shadow">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        Monthly Invoice Type Breakdown <small class="text-muted" id="selectedYearText">(Year)</small>
                    </h5>
                </div>
                <div class="card-body" style="height: 400px;">
                    <canvas id="invoiceTypesMonthlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard-buyer.js"></script>
}
