@if (ViewData["Message"] != null)
{
    var msg = ViewData["Message"]?.ToString() ?? string.Empty;
    var title = msg.Contains("Template") ? "Template Saved Successfully!" : "Draft Saved Successfully!";
    <script>
        Swal.fire({
            icon: 'success',
            title: '@title',
            text: '@msg',
            confirmButtonColor: '#3AA564',  // eInvWorld brand primary green
            timer: 2500,
            timerProgressBar: true
        });
        // If template was saved, highlight the Submit to LHDN button
        if (@(msg.Contains("Template").ToString().ToLower())) {
            setTimeout(function() {
                var btn = document.getElementById('sa-success-submit-lhdn');
                if (btn) {
                    btn.classList.add('btn-success');
                    btn.classList.remove('btn-danger');
                    btn.style.boxShadow = '0 0 0 0.25rem rgba(40, 167, 69, 0.5)';
                    setTimeout(function() {
                        btn.classList.remove('btn-success');
                        btn.classList.add('btn-danger');
                        btn.style.boxShadow = '';
                    }, 2000);
                }
            }, 2600);
        }
    </script>
}

@if ((ViewData["ShowReviewTab"] as bool?) == true)
{
    <script>
        setTimeout(function() {
            // Hide all steps
            document.querySelectorAll('.card.mb-4').forEach(card => card.classList.add('d-none'));
            // Show step 3
            document.getElementById('step3').classList.remove('d-none');
            // Set currentStep and update progress bar if needed
            if (typeof currentStep !== 'undefined') {
                currentStep = 3;
                if (typeof updateProgress === 'function') updateProgress();
            }
        }, 2600); // Wait for SweetAlert2 to close
    </script>
}

@if (!string.IsNullOrEmpty(Model.Message))
{
