@page
@model EINVWORLD.Pages.Invoices.CreateInvoiceModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["IsEditMode"] = false;
}

<style>
    /* Success Dialog Styling - Ensure consistent UUID/Submission UID display */
    .swal-submission-success .detail-item code.text-primary {
        background-color: rgba(58, 165, 100, 0.1) !important;  /* eInvWorld brand primary green background */
        color: #3AA564 !important;  /* eInvWorld brand primary green text */
        border: 1px solid rgba(58, 165, 100, 0.3) !important;
        border-radius: 0.25rem !important;
        padding: 0.25rem 0.5rem !important;
        font-weight: 600 !important;
        display: inline-block !important;
        font-size: 0.875rem !important;
    }
    
    .swal-submission-success .detail-item code.text-info {
        background-color: rgba(41, 156, 219, 0.1) !important;  /* Light blue background for UUID */
        color: #299cdb !important;  /* Bootstrap info color */
        border: 1px solid rgba(41, 156, 219, 0.3) !important;
        border-radius: 0.25rem !important;
        padding: 0.25rem 0.5rem !important;
        font-weight: 600 !important;
        display: inline-block !important;
        font-size: 0.875rem !important;
    }

    /* Responsive design for 1280x720 screens */
    @@media (max-width: 1366px) {
        .container-fluid {
            padding-left: 10px;
            padding-right: 10px;
        }

        .card {
            margin-bottom: 1rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-floating {
            margin-bottom: 0.75rem;
        }

        .table-responsive {
            font-size: 0.875rem;
        }

        .table th, .table td {
            padding: 0.5rem 0.25rem;
        }

        .btn {
            padding: 0.375rem 0.75rem;
            font-size: 0.875rem;
        }

        .page-title-box {
            padding: 0.75rem !important;
        }

            .page-title-box h4 {
                font-size: 1.25rem;
            }

            .page-title-box p {
                font-size: 0.875rem;
            }

        .breadcrumb {
            font-size: 0.75rem;
        }

        .alert {
            padding: 0.75rem;
            font-size: 0.875rem;
        }

        .progress {
            height: 6px;
        }

            .progress + .d-flex small {
                font-size: 0.75rem;
            }
    }

    /* Compact form layout for smaller screens */
    @@media (max-width: 1280px) {
        .col-md-6 {
            margin-bottom: 0.5rem;
        }

        .col-md-4 {
            margin-bottom: 0.5rem;
        }

        .form-floating {
            margin-bottom: 0.5rem;
        }

        .card-header {
            padding: 0.75rem;
        }

            .card-header h5 {
                font-size: 1.1rem;
            }

            .card-header small {
                font-size: 0.8rem;
            }

        .avatar-sm {
            width: 2rem;
            height: 2rem;
        }

            .avatar-sm span {
                font-size: 0.875rem;
            }

        .table-responsive {
            font-size: 0.8rem;
        }

        .table th, .table td {
            padding: 0.375rem 0.25rem;
        }

        .form-control-sm, .form-select-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.8rem;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.8rem;
        }

        .tax-row {
            padding: 0.5rem !important;
        }

            .tax-row .row {
                margin: 0;
            }

            .tax-row .col-6, .tax-row .col-3 {
                padding: 0.25rem;
            }
    }

    /* Ultra-compact for very small screens */
    @@media (max-width: 1024px) {
        .container-fluid {
            padding-left: 5px;
            padding-right: 5px;
        }

        .card-body {
            padding: 0.75rem;
        }

        .table-responsive {
            font-size: 0.75rem;
        }

        .form-control-sm, .form-select-sm {
            font-size: 0.75rem;
        }

        .btn-sm {
            font-size: 0.75rem;
        }
    }

    /* Ensure Select2 dropdowns match form-floating height and styling */
    .form-floating .select2-container {
        height: 58px; /* Match form-floating height */
    }

        .form-floating .select2-container .select2-selection {
            height: 58px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
        }

        .form-floating .select2-container .select2-selection--single {
            display: flex;
            align-items: center;
            padding: 0.75rem 0.75rem;
        }

        .form-floating .select2-container .select2-selection__rendered {
            padding: 0;
            line-height: 1.5;
            color: #212529;
        }

        .form-floating .select2-container .select2-selection__placeholder {
            color: #6c757d;
        }

        .form-floating .select2-container .select2-selection__arrow {
            height: 56px;
            right: 0.75rem;
        }

    .form-floating .select2-container--bootstrap-5 .select2-selection {
        border-color: #dee2e6;
    }

    .form-floating .select2-container--bootstrap-5.select2-container--focus .select2-selection {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    /* Ensure consistent spacing */
    .form-floating .select2-container {
        margin-bottom: 0;
    }

    /* Make table form fields match form-floating appearance */
    .invoice-table .form-control,
    .invoice-table .form-control-sm,
    .invoice-table .form-select {
        /* height: 48px !important; */
        padding: 0.75rem 0.75rem !important;
        border: 1px solid #dee2e6 !important;
        border-radius: 0.375rem !important;
        font-size: 1rem !important;
        /* line-height: 1.5 !important; */
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .invoice-table .form-control:focus,
        .invoice-table .form-control-sm:focus,
        .invoice-table .form-select:focus {
            border-color: #86b7fe !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
            outline: 0 !important;
        }

    


    /* Style Select2 dropdowns in table to match form-floating */
    .invoice-table .select2-container .select2-selection {
        height: 48px !important;
        border: 1px solid #dee2e6 !important;
        border-radius: 0.375rem !important;
        padding: 0.75rem 0.75rem !important;
    }

    .invoice-table .select2-container .select2-selection--single {
        display: flex !important;
        align-items: center !important;
        padding: 0.75rem 0.75rem !important;
    }

    .invoice-table .select2-container .select2-selection__rendered {
        padding: 0 !important;
        /* line-height: 1.5 !important; */
        color: #212529 !important;
    }

    .invoice-table .select2-container .select2-selection__arrow {
        height: 46px !important;
        right: 0.75rem !important;
    }

    .invoice-table .select2-container--bootstrap-5.select2-container--focus .select2-selection {
        border-color: #86b7fe !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
    }

    /* Also apply to dynamically created elements */
    .tax-row .form-control,
    .tax-row .form-control-sm,
    .tax-row .form-select {
        height: 42px !important;
        padding: 0.5rem 0.75rem !important;
        border: 1px solid #dee2e6 !important;
        border-radius: 0.375rem !important;
        font-size: 0.9rem !important;
        line-height: 1.4 !important;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .tax-row .form-control:focus,
        .tax-row .form-control-sm:focus,
        .tax-row .form-select:focus {
            border-color: #86b7fe !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
            outline: 0 !important;
        }

    /* Fix Select2 + form-floating label overlap */
    .form-floating .select2-container--bootstrap-5 .select2-selection--single {
        padding-top: 1.6rem !important; /* Adjust as needed for your label size */
        padding-left: 0.75rem;
        padding-bottom: 0.375rem;
        min-height: 58px;
        display: flex;
        align-items: flex-end;
    }

    .form-floating .select2-container--bootstrap-5 .select2-selection__rendered {
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-top: 0 !important;
    }

    .form-floating > label {
        z-index: 10;
        pointer-events: none;
    }

    /* Loading spinner and indicator styles */
    .loading-spinner {
        z-index: 20;
    }

    .auto-populated-indicator {
        z-index: 20;
    }

    .form-control.is-valid {
        border-color: #198754;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 8 8'%3e%3cpath fill='%23198754' d='m2.3 6.73.94-.94 2.89 2.89 2.89-2.89.94.94L6.12 9.62z'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right calc(0.375em + 0.1875rem) center;
        background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
    }

        .form-control.is-valid:focus {
            border-color: #198754;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
        }

    /* Debug panel styles */
    #debugPanel {
        font-size: 0.875rem;
    }

        #debugPanel small {
            font-size: 0.75rem;
        }

    /* Test button styles */
    .btn-outline-info:hover {
        background-color: #0dcaf0;
        border-color: #0dcaf0;
        color: #000;
    }

    /* SweetAlert customization for wider popup */
    .swal-wide {
        width: 500px !important;
        max-width: 95vw !important;
    }

    .swal-submission-success .swal2-html-container {
        margin: 0 !important;
        padding: 10px !important;
        text-align: left !important;
    }

    .swal-submission-success .submission-details {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 15px;
        margin-top: 10px;
    }

    .swal-submission-success .detail-item {
        margin-bottom: 12px;
        padding: 8px;
        background: white;
        border-radius: 5px;
        border-left: 3px solid #3AA564;  /* eInvWorld brand primary green */
    }

        .swal-submission-success .detail-item:last-child {
            margin-bottom: 0;
        }
        
        /* Specific border colors for different detail item types */
        .swal-submission-success .detail-item:has(code.text-primary) {
            border-left-color: #3AA564 !important;  /* Green for Submission UID */
        }
        
        .swal-submission-success .detail-item:has(code.text-info) {
            border-left-color: #299cdb !important;  /* Blue for UUID */
        }
        
        /* Ensure text alignment matches CreateInvoice template */
        .swal-submission-success .detail-item {
            text-align: left !important;
        }
        
        .swal-submission-success .detail-item strong {
            text-align: left !important;
            display: block !important;
            margin-bottom: 4px !important;
        }

    .swal-submission-success code {
        display: inline-block;
        background: #f1f3f4;
        padding: 4px 8px;
        border-radius: 4px;
        font-family: inherit;
        font-size: 14px;
        word-break: break-all;
        margin-top: 5px;
        width: 100%;
        border: 1px solid #dee2e6;
    }

    .swal-submission-success h6 {
        color: #6c757d !important;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .swal-submission-success .copy-btn {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 2px 6px;
        color: #6c757d;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: -2px;
    }

        .swal-submission-success .copy-btn:hover {
            background: #e9ecef;
            color: #495057;
            border-color: #adb5bd;
        }

        .swal-submission-success .copy-btn.copied {
            background: #d1edff;
            color: #0c63e4;
            border-color: #0c63e4;
        }

            .swal-submission-success .copy-btn.copied i:before {
                content: "\eb7a"; /* ri-check-line */
            }

   
    /* Optimizations for 1280x720 resolution using system fonts */
    @@media (max-width: 1280px) {
       

        .tax-row {
            margin-bottom: 0.2rem !important;
            padding: 0.15rem !important;
        }

        .tax-section .btn-sm {
            padding: 0.1rem 0.2rem;
        }
       
        /* Responsive tax section */
        .tax-category-wrapper {
            flex: 1 1 auto;
        }

        .tax-percentage-wrapper {
            flex: 0 0 50px;
        }

        .tax-action-wrapper {
            flex: 0 0 auto;
        }
    }

    /* Responsive breakpoints for tax section */
    @@media (max-width: 1200px) {
        .tax-row .d-flex.flex-wrap {
            flex-direction: column;
            gap: 0.25rem !important;
        }

        .tax-category-wrapper,
        .tax-percentage-wrapper {
            flex: none;
            width: 100%;
        }

        .tax-percentage-wrapper {
            max-width: 80px;
        }

        .tax-action-wrapper {
            width: auto;
            align-self: flex-end;
        }
    }

    /* Extra responsive for very narrow tax columns */
    @@media (max-width: 768px) {
        .tax-row .d-flex.flex-wrap {
            flex-direction: column;
        }

        .tax-category-wrapper,
        .tax-percentage-wrapper,
        .tax-action-wrapper {
            width: 100%;
            max-width: none;
        }

        .tax-action-wrapper {
            align-self: flex-start;
        }
    }

    /* Copy toast animation */
    @@keyframes fadeInOut {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }

        20% {
            opacity: 1;
            transform: translateY(0);
        }

        80% {
            opacity: 1;
            transform: translateY(0);
        }

        100% {
            opacity: 0;
            transform: translateY(-10px);
        }
    }

    /* Action buttons styling */
    .item-row .d-flex.gap-1 {
        flex-wrap: nowrap;
    }

    .btn-outline-success:hover {
        background-color: #198754;
        border-color: #198754;
        color: white;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    /* Tooltip styling for action buttons */
    .btn[title]:hover::after {
        content: attr(title);
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        white-space: nowrap;
        z-index: 1000;
        margin-bottom: 4px;
    }

    /* Ensure action column doesn't wrap */
    #lineItemsTable td:last-child {
        white-space: nowrap;
        vertical-align: middle;
        text-align: center;
    }

    /* Icon button styling for actions */
    .ri-file-copy-line,
    .ri-delete-bin-line {
        border-radius: 3px;
    }

    /* Adjust action column width for vertical layout */
    #lineItemsTable th:last-child,
    #lineItemsTable td:last-child {
        width: 5%;
        min-width: 40px;
    }

    /* Remove validation icons while keeping colored borders */
    .form-control:invalid,
    .form-control.is-invalid,
    .form-select:invalid,
    .form-select.is-invalid {
        background-image: none !important;
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    .form-control:valid,
    .form-control.is-valid,
    .form-select:valid,
    .form-select.is-valid {
        background-image: none !important;
        border-color: #198754 !important;
        box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.25) !important;
    }

    /* Force validation for required empty fields */
    .form-control[required]:invalid:not(:focus),
    .form-select[required]:invalid:not(:focus),
    input[required]:invalid:not(:focus),
    select[required]:invalid:not(:focus) {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Specific validation for empty required fields */
    .form-control[required]:placeholder-shown:not(:focus),
    .form-control[required][value=""]:not(:focus),
    input[required][value=""]:not(:focus),
    input[required]:placeholder-shown:not(:focus),
    select[required]:invalid:not(:focus),
    textarea[required]:placeholder-shown:not(:focus) {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Force validation for truly empty invoice line items only */
    #lineItemsTable select[required]:invalid:not(:focus):not(.is-valid),
    #lineItemsTable input[required]:invalid:not(:focus):not(.is-valid),
    #lineItemsTable textarea[required]:invalid:not(:focus):not(.is-valid) {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Override CSS validation for fields with values - force normal appearance */
    #lineItemsTable input[required]:valid,
    #lineItemsTable select[required]:valid,
    #lineItemsTable textarea[required]:valid,
    #lineItemsTable input[required]:not(.is-invalid),
    #lineItemsTable select[required]:not(.is-invalid),
    #lineItemsTable textarea[required]:not(.is-invalid),
    #lineItemsTable .form-control:valid,
    #lineItemsTable .form-control.is-valid,
    #lineItemsTable .form-select:valid,
    #lineItemsTable .form-select.is-valid {
        border-color: #ced4da !important;
        box-shadow: none !important;
        background-image: none !important;
    }

    /* Specifically override Bootstrap's valid state styling */
    #lineItemsTable .is-valid,
    #lineItemsTable .was-validated .form-control:valid,
    #lineItemsTable .was-validated .form-select:valid {
        border-color: #ced4da !important;
        box-shadow: none !important;
        background-image: none !important;
    }

    /* Force normal borders for all filled fields in invoice table */
    #lineItemsTable .form-control[value]:not([value=""]):not(.is-invalid),
    #lineItemsTable .form-select[value]:not([value=""]):not(.is-invalid),
    #lineItemsTable textarea:not(:placeholder-shown):not(.is-invalid) {
        border-color: #ced4da !important;
        box-shadow: none !important;
        background-image: none !important;
    }

    /* Optimized Table Column Widths */
    #lineItemsTable {
        table-layout: fixed; /* Forces browser to respect our exact widths */
        min-width: 1000px; /* Ensures the table doesn't get too squeezed on small screens */
    }

        #lineItemsTable th:nth-child(1) {
            width: 36%;
        }
        /* Items */
        #lineItemsTable th:nth-child(2) {
            width: 6%;
        }
        /* Quantity */
        #lineItemsTable th:nth-child(3) {
            width: 16%;
        }
        /* Unit */
        #lineItemsTable th:nth-child(4) {
            width: 9%;
        }
        /* Unit Price */
        #lineItemsTable th:nth-child(5) {
            width: 8%;
        }
        /* Subtotal */
        #lineItemsTable th:nth-child(6) {
            width: 22%;
        }
        /* Tax */
        #lineItemsTable th:nth-child(7) {
            width: 3%;
        }
        /* Actions */

        /* Improve Textarea usability */
        #lineItemsTable textarea {
            resize: vertical;
            min-height: 70px;
            white-space: pre-wrap !important;
        }

    /* Override Bootstrap validation feedback positioning */
    .invalid-feedback,
    .valid-feedback {
        display: none !important;
    }

    /* Enhanced card styling for form sections */
    .page-title-box {
        border: 1px solid #e9ecef;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border-radius: 0.5rem;
    }

    /* Card styling for form groups */
    .form-group-card {
        border: 1px solid #e9ecef;
        border-radius: 0.375rem;
        padding: 1rem;
        margin-bottom: 1rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    /* Normal card styling for all sections */
    .card,
    .card-body {
        border: 1px solid #e9ecef;
        border-radius: 0.375rem;
        box-shadow: none;
    }

    /* Standard table styling */
    .table-responsive {
        border: 1px solid #e9ecef;
        border-radius: 0.375rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        overflow: hidden;
    }

    /* Tax row card styling */
    .tax-row {
        background: #f8f9fa;
        border: 1px solid #e9ecef !important;
        border-radius: 0.375rem !important;
    }

    /* Item row card styling */
    .item-row {
        background: #fff;
    }

    /* Progress bar card styling */
    .progress {
        background: #e9ecef;
        border-radius: 0.5rem;
        box-shadow: inset 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    /* Standard button styling */
    .btn {
        border-radius: 0.375rem;
        box-shadow: none;
    }

    /* Enhanced RefUUID dropdown styles */
    .select2-dropdown-custom .select2-results__option--highlighted {
        background-color: #f8f9fa !important;
        border-left: 3px solid #3AA564 !important;
    }

    .select2-dropdown-custom .select2-results__option {
        border-bottom: 1px solid #eee;
        transition: all 0.2s ease;
    }

        .select2-dropdown-custom .select2-results__option:hover {
            background-color: #f0f8f4 !important;
        }

    /* RefUUID select container styling */
    #refUUIDSelect + .select2-container .select2-selection--single {
        height: calc(3.5rem + 2px) !important;
        padding: 1rem 0.75rem !important;
        border: 1px solid #ced4da !important;
        border-radius: 0.375rem !important;
    }

    #refUUIDSelect + .select2-container .select2-selection__rendered {
        padding: 0 !important;
        height: auto !important;
        line-height: 1.5 !important;
        color: #495057 !important;
    }

    #refUUIDSelect + .select2-container .select2-selection__placeholder {
        color: #6c757d !important;
    }

    /* Highlighting for existing vs new RefUUIDs */
    .select2-dropdown-custom .select2-results__option:hover {
        background-color: #f8f9fa !important;
    }

        /* Enhanced hover effects for highlighted entries */
        .select2-dropdown-custom .select2-results__option:hover div[style*="background-color: #f0f8f4"] {
            background-color: #e8f5ea !important;
        }

        .select2-dropdown-custom .select2-results__option:hover div[style*="background-color: #fff8f0"] {
            background-color: #fef3e2 !important;
        }

    #lineItemsTable select.saved-item-select,
    #lineItemsTable select.saved-item-select:valid,
    #lineItemsTable select.saved-item-select:focus {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: right 0.75rem center !important;
        background-size: 16px 12px !important;
        padding-right: 2.25rem !important;
        appearance: none !important;
    }
</style>

<!-- Page Header -->
<div class="row mb-3">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between bg-galaxy-transparent rounded-3 p-2">
            <div class="d-flex align-items-center">
                <div class="avatar-sm bg-primary rounded-circle d-flex align-items-center justify-content-center me-2">
                    <i class="ri-file-text-line text-white fs-5"></i>
                </div>
                <div>
                    <h5 class="mb-0">Create e-Invoice</h5>
                    <p class="text-muted mb-0 small">Fill in the details below to create your electronic invoice</p>
                </div>
            </div>
            <div class="page-title-right d-flex align-items-center">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Invoice Management</a></li>
                    <li class="breadcrumb-item active">Create e-Invoice</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Progress Indicator -->
<div class="row mb-3">
    <div class="col-12">
        <div class="progress" style="height: 6px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 0%" id="formProgress"></div>
        </div>
        <div class="d-flex justify-content-between mt-1">
            <small class="text-muted">Step 1: Basic Information</small>
            <small class="text-muted">Step 2: Invoice Items</small>
            <small class="text-muted">Step 3: Review & Submit</small>
        </div>
    </div>
</div>

<!-- Template Alert -->
@if (!string.IsNullOrEmpty(Model.TemplateName))
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="alert alert-info border-0 bg-light-info">
                <div class="d-flex align-items-center">
                    <i class="ri-file-copy-line fs-5 me-2"></i>
                    <div>
                        <strong>Using Template:</strong> @Model.TemplateName
                        <br><small class="text-muted">You can modify any fields below as needed</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Validation Errors -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="alert alert-danger border-0">
                <div class="d-flex align-items-center">
                    <i class="ri-error-warning-line fs-5 me-2"></i>
                    <div>
                        <strong>Please fix the following errors:</strong>
                        <ul class="mb-0 mt-2">
                            @foreach (var state in ViewData.ModelState)
                            {
                                if (state.Value.Errors.Count > 0)
                                {
                                    <li><strong>@state.Key:</strong> @string.Join(", ", state.Value.Errors.Select(e => e.ErrorMessage))</li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Main Form -->
<div class="row">
    <div class="col-lg-12">
        <form asp-page="/Invoices/CreateInvoice" method="post" id="invoice_form" class="needs-validation" novalidate>
            <input type="hidden" name="action" id="invoiceAction" />
            <input type="hidden" name="TemplateName" id="templateNameInput" />
            <input type="hidden" name="handler" id="handler" />
            <input type="hidden" asp-for="Invoice.InvoiceNo" id="invoiceNo" />

            <!-- Hidden fields for totals -->
            <input type="hidden" asp-for="Invoice.TotalAmountExclTax" id="totalAmountExclTax" />
            <input type="hidden" asp-for="Invoice.TotalTaxAmount" id="totalTaxAmount" />
            <input type="hidden" asp-for="Invoice.TotalAmountIncTax" id="totalAmountIncTax" />
            <input type="hidden" asp-for="Invoice.TotalDiscountAmount" id="totalDiscountAmount" />
            <input type="hidden" asp-for="Invoice.TotalPayableAmount" id="totalPayableAmount" />
            <input type="hidden" asp-for="Invoice.TotalNetAmount" id="totalNetAmount" />

            <!-- Hidden field for ForeignCurrency (auto-set to same as Currency) -->
            <input type="hidden" asp-for="Invoice.ForeignCurrency" id="foreignCurrency" />

            <!-- Step 1: Basic Information -->
            <div class="card mb-3" id="step1">
                <div class="card-header bg-primary bg-opacity-10 border-0">
                    <div class="d-flex align-items-center">
                        <div class="avatar-sm bg-primary rounded-circle d-flex align-items-center justify-content-center me-2">
                            <span class="text-white fw-bold">1</span>
                        </div>
                        <div>
                            <h6 class="card-title mb-0">Basic Information</h6>
                            <small class="text-muted">Enter the fundamental details of your invoice</small>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Document Type -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="Invoice.DocTypeCode" class="form-select select2" id="docTypeCode" required>
                                    <option value="">Select e-Invoice Type</option>
                                    @if (Model.EInvoiceTypes != null && Model.EInvoiceTypes.Any())
                                    {
                                        @foreach (var docType in Model.EInvoiceTypes)
                                        {
                                            <option value="@docType.Code">@docType.Description</option>
                                        }
                                    }
                                </select>
                                <label for="docTypeCode">
                                    e-Invoice Type Code <span class="text-danger">*</span>
                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Select the type of electronic invoice you're creating"></i>
                                </label>
                                <div class="invalid-feedback">Please select an invoice type.</div>
                            </div>
                        </div>

                        <!-- Reference UUID (for Credit Notes) -->
                        <!-- DEBUG: RefUUID Value = '@Model.Invoice?.RefUUID' -->
                        <!-- DEBUG: DocTypeCode = '@Model.Invoice?.DocTypeCode' -->
                        <!-- DEBUG: URL Params: type=@(Request.Query["type"]), uuid=@(Request.Query["uuid"]) -->
                        
                        @{
                            // Determine display mode on server side - All adjustment document types that require RefUUID
                            // Document type 11 = Self-billed Invoice (original, no RefUUID)
                            // Document types 12,13,14 = Self-billed adjustments (need RefUUID to reference type 11)
                            string[] refUUIDRequiredTypes = { "02", "03", "04", "12", "13", "14" }; // CN, DN, RN, Self-CN, Self-DN, Self-RN
                            string[] urlTypeParams = { "CN", "DN", "RN" }; // URL type parameters that indicate RefUUID needed
                            
                            bool isRefUUIDRequired = System.Linq.Enumerable.Contains(refUUIDRequiredTypes, Model.Invoice?.DocTypeCode);
                            bool hasPresetRefUUID = !string.IsNullOrEmpty(Model.Invoice?.RefUUID);
                            bool isUrlRefUUIDType = System.Linq.Enumerable.Contains(urlTypeParams, Request.Query["type"].ToString());
                            bool showRefUUIDSection = isRefUUIDRequired || isUrlRefUUIDType;
                            bool showDisplayMode = hasPresetRefUUID && (isRefUUIDRequired || isUrlRefUUIDType);
                            bool showSelectMode = !hasPresetRefUUID && (isRefUUIDRequired || isUrlRefUUIDType);
                        }

                        <div class="col-md-6" id="refUUIDSection" style="display: @(showRefUUIDSection ? "block" : "none");">
                            <!-- Auto-selected UUID display (when creating adjustment document from existing invoice) -->
                            <div id="refUUIDDisplayMode" style="display: @(showDisplayMode ? "block" : "none");">
                                <div class="form-floating">
                                    <input type="text" asp-for="Invoice.RefUUID" class="form-control" id="refUUIDDisplay" readonly placeholder="Reference UUID" style="background-color: #f8f9fa; padding-top: 1.75rem; padding-bottom: 0.625rem;">
                                    <label for="refUUIDDisplay">
                                        Reference UUID <span class="text-danger">*</span>
                                        <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="UUID of the original invoice that this adjustment document references"></i>
                                    </label>
                                </div>
                            </div>
                            
                            <!-- Manual selection dropdown (when creating adjustment document from scratch) -->
                            <div id="refUUIDSelectMode" style="display: @(showSelectMode ? "block" : "none");">
                                <div class="form-floating">
                                    <select class="form-select select2" id="refUUIDSelect" data-placeholder="Select original invoice to reference" style="padding-top: 1.75rem; padding-bottom: 0.625rem;">
                                        <option value="">Select original invoice</option>
                                    </select>
                                    <label for="refUUIDSelect">
                                        Reference UUID <span class="text-danger">*</span>
                                        <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Select the original invoice that this adjustment document references"></i>
                                    </label>
                                    <div class="invalid-feedback">Please select the original invoice for this adjustment document.</div>
                                </div>
                                <!-- Hidden input to store the selected RefUUID for form submission -->
                                <input type="hidden" name="Invoice.RefUUID" id="refUUIDHidden" value="@(showSelectMode ? "" : Model.Invoice?.RefUUID)">
                            </div>
                        </div>

                        <!-- Reference Document -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" asp-for="Invoice.RefDocumentNo" class="form-control" id="refDocumentNo" placeholder="Enter reference number" />
                                <label for="refDocumentNo">
                                    Reference Document Number
                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Optional reference number for your internal tracking"></i>
                                </label>
                            </div>
                        </div>

                        <!-- Date Invoice (Original Date) -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="date" asp-for="Invoice.OriginalInvoiceDate" class="form-control" id="originalInvoiceDate" placeholder="Select original invoice date" />
                                <label for="originalInvoiceDate">
                                    Invoice Date (Original Date)
                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Optional: The original date of the invoice, if different from issue date"></i>
                                </label>
                            </div>
                        </div>
                        <!-- PO/DO No -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" asp-for="Invoice.PoDoNo" class="form-control" id="poDoNo" placeholder="Enter PO/DO Number (optional)" />
                                <label for="poDoNo">
                                    PO/DO No
                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Optional: Purchase Order or Delivery Order Number"></i>
                                </label>
                            </div>
                        </div>

                        <!-- Currency -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <select asp-for="Invoice.Currency" class="form-select select2" id="currency" required onchange="updateExchangeRate()">
                                    <option value="">Select Currency</option>
                                    @if (Model.CurrencyCodes != null && Model.CurrencyCodes.Any())
                                    {
                                        @foreach (var currency in Model.CurrencyCodes)
                                        {
                                            var isSelected = currency.Value == "MYR";
                                            <option value="@currency.Value" selected="@(isSelected ? "selected" : null)">@currency.Text</option>
                                        }
                                    }
                                </select>
                                <label for="currency">
                                    Currency Code <span class="text-danger">*</span>
                                </label>
                                <div class="invalid-feedback">Please select a currency.</div>
                            </div>
                        </div>

                        <!-- Exchange Rate -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="number" asp-for="Invoice.ExchangeRate" class="form-control" id="exchangeRate" step="0.01" placeholder="1.00" />
                                <label for="exchangeRate">
                                    Exchange Rate
                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Exchange rate if different from base currency"></i>
                                </label>
                            </div>
                        </div>

                        <!-- Issue Date -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" asp-for="Invoice.IssueDate" class="form-control" id="issueDate" data-provider="flatpickr" data-date-format="Y-m-d H:i" required placeholder="Select date" value="@Model.Invoice?.IssueDateFormatted" />
                                <label for="issueDate">
                                    Issue Date <span class="text-danger">*</span>
                                </label>
                                <div class="invalid-feedback">Please select an issue date.</div>
                            </div>
                        </div>

                        <!-- Supplier -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="Invoice.SupplierId" class="form-select select2" id="supplierSelect" required>
                                    <option value="">Select Supplier</option>
                                    @if (Model.Suppliers != null)
                                    {
                                        @foreach (var supplier in Model.Suppliers)
                                        {
                                            var isPrimary = supplier.Value == Model.PrimaryCompanyId?.ToString();
                                            <option value="@supplier.Value" selected="@(isPrimary ? "selected" : null)">
                                                @(isPrimary ? "⭐ " + supplier.Text + " (Primary)" : supplier.Text)
                                            </option>
                                        }
                                    }
                                </select>
                                <label for="supplierSelect">
                                    Supplier Name <span class="text-danger">*</span>
                                </label>
                                <div class="invalid-feedback">Please select a supplier.</div>
                            </div>
                        </div>

                        <!-- Buyer -->
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <select asp-for="SelectedBuyerId" asp-items="Model.Customers" class="form-select select2" id="buyerSelect" required>
                                    <option value="">Select Buyer</option>
                                </select>
                                <label for="buyerSelect">Buyer Name <span class="text-danger">*</span></label>
                                <span asp-validation-for="SelectedBuyerId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Billing Period -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <select asp-for="Invoice.InvoicePeriod" asp-items="Model.InvoicePeriodOptions" class="form-select select2" required>
                                    <option value="">Select Frequency</option>
                                </select>
                                <label for="invoicePeriodEnum">
                                    Billing Frequency <span class="text-danger">*</span>
                                </label>
                                <div class="invalid-feedback">Please select billing frequency.</div>
                            </div>
                        </div>

                        <!-- Start Date -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" asp-for="Invoice.StartDate" class="form-control" id="startDate" data-provider="flatpickr" data-date-format="d-M-Y" placeholder="Select start date"/>
                                <label for="startDate">Start Date <span class="text-danger">*</span></label>
                            </div>
                        </div>

                        <!-- End Date -->
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" asp-for="Invoice.EndDate" class="form-control" id="endDate" data-provider="flatpickr" data-date-format="d-M-Y" placeholder="Select end date" />
                                <label for="endDate">End Date <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>

                    <br />
                    <!-- Additional Party Information Section -->
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="card border-primary">
                                <div class="card-header bg-primary bg-opacity-10">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <h6 class="mb-0">
                                            <i class="ri-bank-card-line me-2"></i>Additional Party Information
                                            <small class="text-muted ms-2">(Auto-populated)</small>
                                        </h6>
                                        @* <div class="d-flex align-items-center">
                                            <div class="form-check form-switch me-3">
                                                <input class="form-check-input" type="checkbox" id="debugMode" />
                                                <label class="form-check-label small" for="debugMode">Debug Mode</label>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-info" onclick="testBankAccountLoading()">
                                                <i class="ri-test-tube-line me-1"></i>Test Loading
                                            </button>
                                        </div> *@
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <!-- Bank Account Number -->
                                        <div class="col-md-6">
                                            <div class="form-floating position-relative">
                                                <input type="text" asp-for="Invoice.BankAccountNo" class="form-control" id="bankAccountNo" placeholder="Auto-populated from supplier/buyer" />
                                                <label for="bankAccountNo">
                                                    Bank Account Number
                                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Auto-populated from selected supplier/buyer"></i>
                                                </label>
                                                <div class="loading-spinner position-absolute top-50 end-0 translate-middle-y me-3" id="bankAccountNoSpinner" style="display: none;">
                                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </div>
                                                <div class="auto-populated-indicator position-absolute top-50 end-0 translate-middle-y me-3" id="bankAccountNoIndicator" style="display: none;">
                                                    <i class="ri-check-line text-success"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Bank Name -->
                                        <div class="col-md-6">
                                            <div class="form-floating position-relative">
                                                <input type="text" asp-for="Invoice.BankName" class="form-control" id="bankName" placeholder="Auto-populated from supplier/buyer" />
                                                <label for="bankName">
                                                    Bank Name
                                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="Auto-populated from selected supplier/buyer"></i>
                                                </label>
                                                <div class="loading-spinner position-absolute top-50 end-0 translate-middle-y me-3" id="bankNameSpinner" style="display: none;">
                                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </div>
                                                <div class="auto-populated-indicator position-absolute top-50 end-0 translate-middle-y me-3" id="bankNameIndicator" style="display: none;">
                                                    <i class="ri-check-line text-success"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Attention (editable) -->
                                        <div class="col-md-6">
                                            <div class="form-floating position-relative">
                                                <input type="text" asp-for="Invoice.Attention" class="form-control" id="attention" placeholder="Enter PIC for this invoice" />
                                                <label for="attention">
                                                    Attention to (PIC)
                                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="You can enter a different PIC for this invoice"></i>
                                                </label>
                                                <div class="loading-spinner position-absolute top-50 end-0 translate-middle-y me-3" id="attentionSpinner" style="display: none;">
                                                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </div>
                                                <div class="auto-populated-indicator position-absolute top-50 end-0 translate-middle-y me-3" id="attentionIndicator" style="display: none;">
                                                    <i class="ri-check-line text-success"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="form-floating">
                                                <input asp-for="Invoice.PaymentTerms" class="form-control" id="paymentTerms" placeholder="Enter payment terms" />
                                                <label for="paymentTerms">
                                                    Payment Terms
                                                    <i class="ri-information-line ms-1" data-bs-toggle="tooltip" title="E.g., 30 DAYS FROM THE DATE OF INVOICE, DUE UPON INVOICE"></i>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Debug Information Panel -->
                                    <div class="mt-3" id="debugPanel" style="display: none;">
                                        <div class="alert alert-info border-0 bg-light-info">
                                            <h6 class="mb-2"><i class="ri-bug-line me-2"></i>Debug Information</h6>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <small><strong>Last Supplier ID:</strong> <span id="debugSupplierId">-</span></small><br>
                                                    <small><strong>Last Buyer ID:</strong> <span id="debugBuyerId">-</span></small><br>
                                                    <small><strong>Last API Call:</strong> <span id="debugLastCall">-</span></small>
                                                </div>
                                                <div class="col-md-6">
                                                    <small><strong>API Response:</strong> <span id="debugResponse">-</span></small><br>
                                                    <small><strong>Loading Status:</strong> <span id="debugLoadingStatus">-</span></small><br>
                                                    <small><strong>Error Count:</strong> <span id="debugErrorCount">0</span></small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="button" class="btn btn-outline-danger me-2" onclick="location.reload()">
                            <i class="ri-refresh-line me-1"></i>Reset
                        </button>
                        <button type="button" class="btn btn-primary" onclick="nextStep()">
                            Next: Invoice Items <i class="ri-arrow-right-line ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Step 2: Invoice Items -->
            <div class="card mb-3 d-none" id="step2">
                <div class="card-header bg-success bg-opacity-10 border-0">
                    <div class="d-flex align-items-center">
                        <div class="avatar-sm bg-success rounded-circle d-flex align-items-center justify-content-center me-2">
                            <span class="text-white fw-bold">2</span>
                        </div>
                        <div>
                            <h6 class="card-title mb-0">Invoice Items</h6>
                            <small class="text-muted">Add products or services to your invoice</small>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered invoice-table" id="lineItemsTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th scope="col" style="text-align: center;">Items</th>
                                    <th scope="col" style="text-align: center;">Quantity</th>
                                    <th scope="col" style="text-align: center;">Unit</th>
                                    <th scope="col" style="text-align: center;">Unit Price</th>
                                    <th scope="col" style="text-align: center;">Subtotal</th>
                                    <th scope="col" style="text-align: center;">Tax</th>
                                    <th scope="col" style="text-align: center;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="lineItems">
                                @for (int i = 0; i < (Model.Invoice?.InvoiceLines.Count ?? 0); i++)
                                {
                                    <tr data-item-index="@i" class="item-row">
                                        <td>
                                            <div class="mb-2">
                                                <select class="form-select form-select-sm saved-item-select bg-light border-primary" onchange="autoFillItem(this, @i)">
                                                    <option value="">-- Select Saved Item --</option>
                                                    @if (Model.SavedItems != null && Model.SavedItems.Any())
                                                    {
                                                        foreach (var item in Model.SavedItems)
                                                        {
                                                            <option value="@item.Value">@item.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="row g-2 mb-2">
                                                <div class="col-sm-7">
                                                    <select asp-for="Invoice.InvoiceLines[i].ClassificationCode" asp-items="Model.ClassificationCodes" class="form-select form-select-sm item-classification" required>
                                                        <option value="">Select Classification</option>
                                                    </select>
                                                </div>
                                                <div class="col-sm-5">
                                                    <input asp-for="Invoice.InvoiceLines[i].ItemCode" class="form-control form-control-sm item-code" placeholder="Item Code" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <textarea asp-for="Invoice.InvoiceLines[i].ItemDescription" class="form-control form-control-sm item-description" rows="3" placeholder="Enter comprehensive item description..." required></textarea>
                                            </div>
                                        </td>
                                        <td>
                                            <input asp-for="Invoice.InvoiceLines[i].Quantity" type="number" class="form-control form-control-sm quantity-input" step="0.01" min="0" required placeholder="0" />
                                        </td>
                                        <td>
                                            <select asp-for="Invoice.InvoiceLines[i].UnitOfMeasure" asp-items="Model.UnitOptions" class="form-control form-control-sm" required>
                                                <option value="">Unit</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input asp-for="Invoice.InvoiceLines[i].UnitPrice" type="number" class="form-control form-control-sm price-input" step="0.01" min="0" required placeholder="0.00" />
                                        </td>
                                        <td>
                                            <div class="amount text-end fw-bold" id="subtotal-@i">0.00</div>
                                        </td>
                                        <td>
                                            <div class="tax-section" id="taxes-@i">
                                                @if (Model.Invoice?.InvoiceLines[i].Taxes != null)
                                                {
                                                    for (int j = 0; j < (Model.Invoice?.InvoiceLines[i].Taxes?.Count ?? 0); j++)
                                                    {
                                                        <div class="tax-row mb-2 p-2 border rounded">
                                                            <div class="d-flex flex-wrap gap-1 align-items-start">
                                                                <div class="flex-fill tax-category-wrapper" style="min-width: 100px;">
                                                                    <select asp-for="Invoice.InvoiceLines[i].Taxes[j].TaxCategory" asp-items="Model.TaxCategoryOptions" class="form-select form-select-sm tax-category">
                                                                        <option value="">Tax Category</option>
                                                                    </select>
                                                                </div>
                                                                <div class="tax-percentage-wrapper" style="min-width: 65px; flex: 0 0 50px;">
                                                                    <input asp-for="Invoice.InvoiceLines[i].Taxes[j].TaxPercentage" type="number" class="form-control form-control-sm" placeholder="%" step="0.01" required />
                                                                </div>
                                                                <div class="tax-action-wrapper" style="flex: 0 0 auto;">
                                                                    <i class="ri-close-circle-line text-danger" onclick="removeTaxRow(this)" title="Remove Tax" style="cursor: pointer; font-size: 16px; padding: 2px;"></i>
                                                                </div>
                                                            </div>
                                                            <div class="mt-2 tax-exemption-reason" style="display: none;">
                                                                <input asp-for="Invoice.InvoiceLines[i].Taxes[j].TaxExemptionReason" class="form-control form-control-sm" placeholder="Exemption Reason (Required)" />
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                            <button type="button" class="btn btn-sm btn-primary" onclick="addTaxRow(@i)">
                                                <i class="ri-add-line me-1"></i>Tax
                                            </button>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column gap-1 align-items-center">
                                                <i class="ri-file-copy-line text-success" onclick="duplicateItem(this)" title="Duplicate Row" style="cursor: pointer; font-size: 16px; padding: 2px;"></i>
                                                <i class="ri-delete-bin-line text-danger" onclick="removeItem(this)" title="Delete Row" style="cursor: pointer; font-size: 16px; padding: 2px;"></i>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                            <!-- 🔧 Required for model binding -->
                            <input type="hidden" id="itemCount" name="Invoice.InvoiceLines.Count" value="@(Model.Invoice?.InvoiceLines.Count ?? 0)" />

                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-center mt-3">
                    <button type="button" class="btn btn-outline-primary" id="addItemBtn">
                        <i class="ri-add-line me-1"></i>Add Item
                    </button>
                   @*  <button type="button" class="btn btn-outline-warning ms-2" onclick="updateAllClassificationCodes(true)">
                        <i class="ri-refresh-line me-1"></i>Test Classification Update
                    </button> *@
                    @* <button type="button" class="btn btn-outline-info ms-2" onclick="testAddItem()">
                        <i class="ri-test-tube-line me-1"></i>Test Add Item
                    </button> *@
                </div>

                <!-- Tax Management Section -->
                @* <div class="card border-warning mt-3">
                    <div class="card-header bg-warning bg-opacity-10">
                        <h6 class="mb-0"><i class="ri-taxi-line me-2"></i>Item & Tax Validation <small class="text-muted">(All fields must be filled including taxes)</small></h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <button type="button" class="btn btn-outline-warning" onclick="validateItemRequirements()">
                                <i class="ri-check-line me-1"></i>Check Item Requirements
                            </button>
                            <button type="button" class="btn btn-outline-success" onclick="addTaxToAllItems()">
                                <i class="ri-add-line me-1"></i>Add Taxes to All Items
                            </button>

                        </div>
                    </div>
                </div> *@

                <!-- Step Navigation -->
                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-outline-secondary" onclick="prevStep()">
                        <i class="ri-arrow-left-line me-1"></i>Previous
                    </button>
                    <button type="button" class="btn btn-primary" onclick="nextStep()">
                        Next: Review & Submit <i class="ri-arrow-right-line ms-1"></i>
                    </button>
                </div>
            </div>
        </form>
        <!-- Step 3: Review & Submit -->
        <div class="card mb-4 d-none" id="step3">
            <div class="card-header bg-warning bg-opacity-10 border-0">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-warning rounded-circle d-flex align-items-center justify-content-center me-3">
                        <span class="text-white fw-bold">3</span>
                    </div>
                    <div>
                        <h5 class="card-title mb-0">Review & Submit</h5>
                        <small class="text-muted">Review your invoice and choose your action</small>
