@page
@model EINVWORLD.Pages.Invoices.OcrUploadModel
@{
    ViewData["Title"] = "Upload & Extract Invoice";
}

<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0 text-white">Extract Invoice Data</h5>
        </div>

        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Upload Vendor Invoice (PDF)</label>
                    <input type="file" class="form-control" asp-for="UploadedPdf" accept=".pdf" required />
                </div>

                <button type="submit" class="btn btn-success">
                    Extract Data
                </button>
            </form>
        </div>
    </div>

    @if (Model.ExtractedData != null)
    {
        <div class="card shadow-sm border-success">

            <div class="card-header bg-success text-white d-flex justify-content-between">
                <h5 class="mb-0">Extraction Results</h5>
                <span class="badge bg-light text-dark">
                    Confidence: @(Math.Round((Model.ExtractedData?.Confidence ?? 0) * 100, 1))%
                </span>
            </div>

            <div class="card-body">

                <div class="row">
                    <div class="col-md-6">
                        <h6><strong>Supplier Details</strong></h6>
                        <p><strong>Name:</strong> @Model.ExtractedData?.GetFieldString("supplier_name")</p>
                        <p><strong>TIN:</strong> @Model.ExtractedData?.GetFieldString("supplier_tin")</p>
                        <p><strong>BRN:</strong> @Model.ExtractedData?.GetFieldString("supplier_registration_no")</p>
                        <p><strong>SST:</strong> @Model.ExtractedData?.GetFieldString("supplier_sst")</p>
                        <p><strong>Address:</strong> @Model.ExtractedData?.GetFieldString("supplier_address")</p>
                    </div>

                    <div class="col-md-6">
                        <h6><strong>Buyer Details</strong></h6>
                        <p><strong>Name:</strong> @Model.ExtractedData?.GetFieldString("buyer_name")</p>
                        <p><strong>TIN:</strong> @Model.ExtractedData?.GetFieldString("buyer_tin")</p>
                        <p><strong>BRN:</strong> @Model.ExtractedData?.GetFieldString("buyer_brn")</p>
                        <p><strong>Address:</strong> @Model.ExtractedData?.GetFieldString("buyer_address")</p>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-md-6">
                        <h6><strong>Invoice Info</strong></h6>
                        <p><strong>Invoice No:</strong> @Model.ExtractedData?.GetFieldString("invoice_number")</p>
                        <p><strong>Date:</strong> @Model.ExtractedData?.GetFieldString("invoice_date")</p>
                        <p><strong>E-Invoice:</strong> @Model.ExtractedData?.GetFieldString("einvoice_number")</p>
                    </div>

                    <div class="col-md-6">
                        <h6><strong>Totals</strong></h6>
                        <p><strong>Subtotal:</strong> @Model.ExtractedData?.GetFieldString("currency") @Model.ExtractedData?.GetFieldDecimal("subtotal")</p>
                        <p><strong>Tax:</strong> @Model.ExtractedData?.GetFieldDecimal("tax_amount")</p>
                        <p><strong>Total:</strong> @Model.ExtractedData?.GetFieldString("currency") @Model.ExtractedData?.GetFieldDecimal("total_amount")</p>
                    </div>
                </div>

                <hr />

                <h6><strong>Line Items</strong></h6>

                <table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.ExtractedData?.LineItems ?? new())
                        {
                            <tr>
                                <td>@item.Description</td>
                                <td>@(item.Qty ?? item.Quantity)</td>
                                <td>@item.UnitPrice</td>
                                <td>@(item.Amount ?? item.TotalAmount)</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="mt-3">
                    <a href="/Invoices/CreateInvoice" class="btn btn-primary">
                        Proceed to Draft e-Invoice
                    </a>
                </div>

            </div>
        </div>
    }

</div>