@page
@using eInvWorld.Models.InputModel
@using Microsoft.AspNetCore.Html
@using eInvWorld.Helpers
@model eInvWorld.Pages.Invoices.InvoiceListsModel
@{
    ViewData["Title"] = "Invoice List";
    Layout = "_LayoutTabler";

    var invoiceDirection = string.IsNullOrEmpty(Request.Query["invoiceDirection"]) ? "Sent" : Request.Query["invoiceDirection"].ToString();
    if (Model.UserType == "Buyer")
    {
        invoiceDirection = "Received";
    }

    var rejectionReasons = eInvWorld.Models.Document.RejectDocumentInput.GetReasons();
    var invoiceStatus = string.IsNullOrEmpty(Request.Query["LHDNStatus"]) ? "" : Request.Query["LHDNStatus"].ToString();

    // Single Stitch-style tab row: All / Draft / Sent / Received (Buyers see only Received).
    var mainTabs = new List<(string Key, string Label)>();

    if (Model.UserType == "Buyer")
    {
        mainTabs.Add(("Received", "Received"));
    }
    else
    {
        mainTabs = new List<(string Key, string Label)>
        {
            ("All", "All Invoices"),
            ("Draft", "Draft"),
            ("Sent", "Sent"),
            ("Received", "Received")
        };
    }

    // LHDN statuses that make sense as a filter for the current tab — used to validate the
    // LHDNStatus query value carried across tab switches (the filter itself lives in the filter card).
    var validStatuses = invoiceDirection switch
    {
        "Sent" => new[] { "Submitted", "Valid", "Invalid", "Cancelled" },
        "All" => new[] { "Submitted", "Valid", "Invalid", "Cancelled" },
        "Received" => new[] { "Valid", "Cancelled" },
        _ => Array.Empty<string>()
    };

    // Ensure status is valid for the selected invoiceDirection
    if (!validStatuses.Contains(invoiceStatus))
    {
        invoiceStatus = null; // Remove it from the query parameters
    }

    @functions {
        string? GetEditUrl(string docTypeCode, string invoiceNo)
        {
            // Return null if invoiceNo is null to avoid CS8603
            if (invoiceNo == null)
                return null;
            return Url.Page("/Invoices/InvoiceEdit", new { id = invoiceNo });
        }

        string GetEditLabel(string docTypeCode)
        {
            return docTypeCode switch
            {
                "01" => "Edit Invoice",
                "02" => "Edit CN",
                "03" => "Edit DN",
                "04" => "Edit RN",
                "11" => "Edit Self-billed Invoice",
                "12" => "Edit Self-billed CN",
                "13" => "Edit Self-billed DN",
                "14" => "Edit Self-billed RN",
                _ => "Edit Document"
            };
        }

        // Sort link that preserves every active filter (direction, search, dates, doc types,
        // statuses, page size) and resets to page 1 — clicking a header no longer drops filters.
        string SortUrl(string column)
        {
            var sb = new System.Text.StringBuilder("./InvoiceLists");
            var sep = '?';
            void Add(string key, string? value)
            {
                if (string.IsNullOrEmpty(value)) return;
                sb.Append(sep).Append(Uri.EscapeDataString(key)).Append('=').Append(Uri.EscapeDataString(value));
                sep = '&';
            }
            Add("invoiceDirection", Request.Query["invoiceDirection"]);
            Add("searchQuery", Request.Query["searchQuery"]);
            Add("submissionDateFrom", Request.Query["submissionDateFrom"]);
            Add("submissionDateTo", Request.Query["submissionDateTo"]);
            foreach (var docType in Request.Query["documentType"]) { Add("documentType", docType); }
            Add("LHDNStatus", Request.Query["LHDNStatus"]);
            Add("InternalStatus", Request.Query["InternalStatus"]);
            Add("status", Request.Query["status"]);
            Add("pageSize", Request.Query["pageSize"]);
            Add("pageNo", "1");
            Add("sortBy", column);
            Add("sortOrder", Model.SortBy == column && Model.SortOrder == "asc" ? "desc" : "asc");
            return sb.ToString();
        }

        // Pager link that preserves every active filter and the current sort.
        string PageUrl(int pageNo)
        {
            var sb = new System.Text.StringBuilder("./InvoiceLists");
            var sep = '?';
            void Add(string key, string? value)
            {
                if (string.IsNullOrEmpty(value)) return;
                sb.Append(sep).Append(Uri.EscapeDataString(key)).Append('=').Append(Uri.EscapeDataString(value));
                sep = '&';
            }
            Add("invoiceDirection", Request.Query["invoiceDirection"]);
            Add("searchQuery", Request.Query["searchQuery"]);
            Add("submissionDateFrom", Request.Query["submissionDateFrom"]);
            Add("submissionDateTo", Request.Query["submissionDateTo"]);
            foreach (var docType in Request.Query["documentType"]) { Add("documentType", docType); }
            Add("LHDNStatus", Request.Query["LHDNStatus"]);
            Add("InternalStatus", Request.Query["InternalStatus"]);
            Add("status", Request.Query["status"]);
            Add("sortBy", Request.Query["sortBy"]);
            Add("sortOrder", Request.Query["sortOrder"]);
            Add("pageSize", Request.Query["pageSize"]);
            Add("pageNo", pageNo.ToString());
            return sb.ToString();
        }

        string SortIcon(string column)
        {
            if (Model.SortBy == column)
            {
                return Model.SortOrder == "asc" ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line";
            }
            return "ri-arrow-up-down-line";
        }

        // Compact Stitch status badge classes: soft tinted background + solid semantic text.
        string LhdnBadgeClass(string? statusId) => statusId switch
        {
            "Valid" => "einv-badge einv-badge-success",
            "Submitted" => "einv-badge einv-badge-warning",
            "Invalid" => "einv-badge einv-badge-danger",
            "Cancelled" => "einv-badge einv-badge-danger",
            _ => "einv-badge einv-badge-neutral"
        };

        string InternalBadgeClass(string? statusId) => statusId switch
        {
            "Valid" or "Completed" => "einv-badge einv-badge-success",
            "Submitted" or "ValidInternal" => "einv-badge einv-badge-warning",
            "Invalid" or "RequestReject" or "TransmissionError" => "einv-badge einv-badge-danger",
            "Cancelled" or "CancelledInternal" => "einv-badge einv-badge-danger",
            _ => "einv-badge einv-badge-neutral" // Draft & informational states
        };
    }
@if (TempData["DeleteMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                Swal.fire({
                    icon: 'success',
                    title: 'Deleted!',
                    text: @Json.Serialize(TempData["DeleteMessage"]),
                    timer: 2000,
                    showConfirmButton: false
                });
            });
        </script>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                Swal.fire({
                    icon: 'success',
                    title: 'Sync Complete',
                    text: @Json.Serialize(TempData["SuccessMessage"]),
                    timer: 4000,
                    showConfirmButton: false
                });
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                Swal.fire({
                    icon: 'warning',
                    title: 'Notice',
                    text: @Json.Serialize(TempData["ErrorMessage"]),
                    showConfirmButton: true,
                    confirmButtonColor: '#006948'
                });
            });
        </script>
    }
}


<div id="submitLoadingOverlay" class="loading-overlay" style="display:none;">
    <div class="spinner-border text-light" role="status"></div>
    <p>Submitting invoice to LHDN...</p>
</div>
<div id="refreshApiOverlay" class="loading-overlay" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center; flex-direction: column; color: white;">
    <div class="spinner-border text-success" role="status" style="width: 4rem; height: 4rem;"></div>
    <h4 class="mt-3 text-white">Syncing with LHDN API...</h4>
    <p>Please wait while we fetch the latest updates. Do not close this page.</p>
</div>

@{
    var pageTitle = invoiceDirection switch
    {
        "Draft" => "Draft Invoices",
        "Sent" => "Sent Invoices",
        "Received" => "Received Invoices",
        _ => "All Invoices"
    };
    var pageDescription = invoiceDirection switch
    {
        "Draft" => "Manage, validate and submit your pending documents.",
        "Sent" => "Manage and track your outgoing documents delivered to buyers.",
        "Received" => "Manage and track incoming documents from your suppliers.",
        _ => "Track every document across drafts, sent and received in one place."
    };
    // Page actions per tab (Stitch): Refresh syncs from LHDN, so it is not shown on the
    // local-only Draft tab; Create Invoice appears where new documents are started (All/Draft).
    var showRefreshAction = invoiceDirection != "Draft";
    var showCreateAction = Model.UserType == "Supplier" && !Model.IsViewOnly
                           && (invoiceDirection == "All" || invoiceDirection == "Draft");
    // Row selection exists where bulk actions exist (Draft/Sent/Received). The mixed-status All
    // tab has no bulk actions, so it renders without the checkbox column.
    var showSelection = !Model.IsViewOnly
                        && (invoiceDirection == "Draft" || invoiceDirection == "Sent" || invoiceDirection == "Received");
}

<!-- Stitch page header: breadcrumb + title + description left, page actions right -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box mb-3 d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 mb-1">
                        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-page="./InvoiceLists">Invoices</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@pageTitle</li>
                    </ol>
                </nav>
                <h1 class="einv-page-title mb-1">@pageTitle</h1>
                <p class="text-muted mb-0">@pageDescription</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <!-- Filter Button (collapses/expands the inline filter card) -->
                <button class="btn btn-outline-secondary d-flex align-items-center gap-1" data-bs-toggle="collapse"
                        data-bs-target="#filterOffcanvas" aria-expanded="true" aria-controls="filterOffcanvas">
                    <i class="ri-filter-line"></i> Filter
                </button>

                @if (showRefreshAction)
                {
                    <a asp-page="./InvoiceLists"
                       asp-route-status="@Request.Query["status"]"
                       asp-route-invoiceDirection="@Model.invoiceDirection"
                       asp-route-submissionDateFrom="@Request.Query["submissionDateFrom"]"
                       asp-route-submissionDateTo="@Request.Query["submissionDateTo"]"
                       asp-route-refresh="true"
                       class="btn btn-outline-secondary d-flex align-items-center gap-1"
                       title="Refresh invoices from LHDN API"
                       onclick="document.getElementById('refreshApiOverlay').style.display='flex';">
                        <i class="ri-refresh-line"></i> Refresh from API
                    </a>
                }

                <a class="btn btn-outline-secondary d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#exportModal">
                    <i class="ri-file-download-line"></i> Export
                </a>

                <!-- Customize Columns Button -->
                <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1"
                        data-bs-toggle="modal" data-bs-target="#columnSettingsModal"
                        title="Customize column display" id="columnSettingsBtnMoved">
                    <i class="ri-settings-3-line"></i> Customize
                </button>

                @if (showCreateAction)
                {
                    <a href="/Invoices/CreateInvoice" class="btn btn-primary d-flex align-items-center gap-1">
                        <i class="ri-add-line align-bottom"></i> Create Invoice
                    </a>
                }
            </div>
        </div>
    </div>
</div>



<!-- Main invoice tabs — single Stitch underline row (green underline on the active tab) -->
<ul class="nav nav-tabs einv-invoice-tabs mb-3">
    @foreach (var tab in mainTabs)
    {
        var isTabActive = invoiceDirection == tab.Key;
        <li class="nav-item">
            <a class="nav-link fw-semibold @(isTabActive ? "active" : "")"
               asp-page="./InvoiceLists"
               asp-route-invoiceDirection="@tab.Key"
               asp-route-LHDNStatus="@(tab.Key == "Draft" ? null : (validStatuses.Contains(invoiceStatus) ? invoiceStatus : null))"
               asp-route-status="@(tab.Key == "Draft" ? null : (validStatuses.Contains(invoiceStatus) ? invoiceStatus : null))">
                @tab.Label
            </a>
        </li>
    }
</ul>

<div class="row">
    <div class="col-lg-12">
        <div id="documentList">
            <!-- Inline filter card (Stitch design) — same GET form + field names/ids the previous
                 offcanvas carried (date-picker.js keys on #submissionDateRange), rendered as an
                 always-visible card that the header Filter button collapses/expands. -->
            <div class="collapse show" id="filterOffcanvas">
                <div class="card mb-3">
                    <div class="card-body pb-2">
                        <form method="get" action="./InvoiceLists">
                            <input type="hidden" name="invoiceDirection" value="@invoiceDirection" />
                            @* No hidden status/lhdnStatus inputs here: the LHDNStatus select below is the
                               single source for that filter — a duplicate hidden field bound first and
                               silently discarded the selected value. *@
                            <input type="hidden" id="submissionDateFrom" name="submissionDateFrom" value="@Request.Query["submissionDateFrom"]">
                            <input type="hidden" id="submissionDateTo" name="submissionDateTo" value="@Request.Query["submissionDateTo"]">
                            @* Column-header links drive sorting; carry the current sort through the filter form. *@
                            <input type="hidden" id="sortBy" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" id="sortOrder" name="sortOrder" value="@Model.SortOrder" />

                            <div class="row g-2 align-items-end">
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label for="searchQuery" class="form-label mb-1">Search</label>
                                    <input type="text" id="searchQuery" name="searchQuery" class="form-control"
                                           placeholder="Invoice No, Supplier, Buyer, UUID..."
                                           value="@Model.SearchInput?.searchQuery">
                                </div>
                                <div class="col-12 col-md-6 col-xl-2">
                                    <label for="submissionDateRange" class="form-label mb-1">Date Range</label>
                                    <input type="text" id="submissionDateRange" class="form-control" placeholder="Select date range" readonly>
                                </div>
                                <div class="col-6 col-md-4 col-xl-2">
                                    <label class="form-label mb-1 d-block">Document Type</label>
                                    <div class="dropdown w-100">
                                        <button class="btn btn-outline-secondary w-100 text-start dropdown-toggle" type="button"
                                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                            @(Request.Query["documentType"].Count > 0 ? $"{Request.Query["documentType"].Count} selected" : "All Types")
                                        </button>
                                        <div class="dropdown-menu p-3" style="min-width: 260px;">
                                            @foreach (var documentType in Enum.GetValues(typeof(EInvoiceDocumentType)).Cast<EInvoiceDocumentType>())
                                            {
                                                var docTypeValue = ((int)documentType).ToString("D2");
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="docType_@docTypeValue" name="documentType" value="@docTypeValue"
                                                    @(Request.Query["documentType"].Contains(docTypeValue) ? "checked" : "")>
                                                    <label class="form-check-label" for="docType_@docTypeValue">
                                                        @DocumentTypeDisplay.GetDisplayNames()[documentType]
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-4 col-xl-2">
                                    <label for="LHDNStatusFilter" class="form-label mb-1">LHDN Status</label>
                                    <select id="LHDNStatusFilter" name="LHDNStatus" class="form-select">
                                        @{ var lhdnSel = Request.Query["LHDNStatus"].ToString(); }
                                        <option value="">All</option>
                                        <option value="Valid" selected="@(lhdnSel == "Valid")">Valid</option>
                                        <option value="Cancelled" selected="@(lhdnSel == "Cancelled")">Cancelled</option>
                                        <option value="Invalid" selected="@(lhdnSel == "Invalid")">Invalid</option>
                                        <option value="Submitted" selected="@(lhdnSel == "Submitted")">Submitted</option>
                                    </select>
                                </div>
                                <div class="col-6 col-md-4 col-xl-2">
                                    <label for="InternalStatusFilter" class="form-label mb-1">Internal Status</label>
                                    <select id="InternalStatusFilter" name="InternalStatus" class="form-select">
                                        @{ var internalSel = Request.Query["InternalStatus"].ToString(); }
                                        <option value="">All</option>
                                        <option value="Valid" selected="@(internalSel == "Valid")">Valid</option>
                                        <option value="Completed" selected="@(internalSel == "Completed")">Completed</option>
                                        <option value="Draft" selected="@(internalSel == "Draft")">Draft</option>
                                        <option value="RequestReject" selected="@(internalSel == "RequestReject")">Request Reject</option>
                                        <option value="CancelledInternal" selected="@(internalSel == "CancelledInternal")">Cancelled</option>
                                    </select>
                                </div>
                                <div class="col-6 col-md-4 col-xl-1 d-flex gap-2">
                                    <button type="submit" class="btn btn-primary flex-fill">
                                        <i class="ri-search-line"></i> Apply
                                    </button>
                                </div>
                                <div class="col-12 text-end">
                                    <a class="small fw-semibold text-decoration-none" href="./InvoiceLists?invoiceDirection=@invoiceDirection">Clear all filters</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <input type="hidden" id="rejectionReasons" value='@Json.Serialize(rejectionReasons)' />

                @* Bulk actions: floating dark bar shown while rows are selected (Stitch). The button
                   ids are unchanged — all existing bulk handlers keep working; visibility is driven
                   by the same refreshBulkVisibility() script as before. *@
                @if (!Model.IsViewOnly && (Model.invoiceDirection == "Draft" || Model.invoiceDirection == "Sent" || Model.invoiceDirection == "Received"))
                {
                    <div id="bulkActionBar" class="einv-bulk-bar d-none" role="toolbar" aria-label="Bulk actions for selected invoices">
                        <span class="einv-bulk-count" id="bulkSelectedCount">0 Selected</span>
                        <span class="einv-bulk-hint d-none d-sm-inline">Bulk actions for selected invoices</span>
                        @if (Model.invoiceDirection == "Draft")
                        {
                            <button id="bulkSubmitBtn" class="btn btn-primary btn-sm d-none" title="Submit the selected draft invoices to LHDN">
                                <i class="ri-send-plane-fill"></i> Submit to LHDN
                            </button>
                            <button id="bulkDeleteBtn" class="btn btn-danger btn-sm d-none">
                                <i class="ri-delete-bin-5-fill"></i> Delete e-Invoice
                            </button>
                        }
                        @if (Model.invoiceDirection == "Sent")
                        {
                            <button id="bulkCancelBtn" class="btn btn-warning btn-sm d-none">
                                <i class="ri-close-circle-line"></i> Cancel e-Invoice
                            </button>
                        }
                        @if (Model.invoiceDirection == "Received")
                        {
                            <button id="bulkRejectBtn" class="btn btn-danger btn-sm d-none">
                                <i class="ri-close-circle-line"></i> Request Reject e-Invoice
                            </button>
                        }
                    </div>
                }

            <div>
                <div>
                        <div class="card mb-3">
                        <div class="tab-content">
                            <!-- All Tab Content -->
                            <div class="tab-pane fade show active" id="allTab" role="tabpanel">

                                
                                
                                <!-- Enhanced Scrollable Table Container -->
                                <div class="table-scroll at-left">
                                    <div class="inner" style="overflow-x: auto; width: 100%;">
                                        <table class="table table-nowrap align-middle table-hover mb-0" id="invoiceTable">
                                        <thead class="einv-table-head">
                                        <tr>
                                            @if (showSelection)
                                            {
                                                <th class="col-checkbox"><input type="checkbox" id="selectAll" aria-label="Select all invoices" /></th>
                                            }

                                            <th class="col-invoice-no">
                                                <a href="@SortUrl("InvoiceNo")" class="@(Model.SortBy == "InvoiceNo" ? "text-primary fw-semibold" : "")">
                                                    Invoice # <i class="@SortIcon("InvoiceNo") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-document-type">
                                                <a href="@SortUrl("DocumentType")" class="@(Model.SortBy == "DocumentType" ? "text-primary fw-semibold" : "")">
                                                    Type <i class="@SortIcon("DocumentType") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-supplier">
                                                <a href="@SortUrl("SupplierName")" class="@(Model.SortBy == "SupplierName" ? "text-primary fw-semibold" : "")">
                                                    Supplier <i class="@SortIcon("SupplierName") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-buyer">
                                                <a href="@SortUrl("CustomerName")" class="@(Model.SortBy == "CustomerName" ? "text-primary fw-semibold" : "")">
                                                    Buyer <i class="@SortIcon("CustomerName") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-submitted-date">
                                                <a href="@SortUrl("IssueDate")" class="@(Model.SortBy == "IssueDate" ? "text-primary fw-semibold" : "")">
                                                    Date <i class="@SortIcon("IssueDate") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-total-amount text-end">
                                                <a href="@SortUrl("TotalAmount")" class="@(Model.SortBy == "TotalAmount" ? "text-primary fw-semibold" : "")">
                                                    Total <i class="@SortIcon("TotalAmount") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-internal-status">
                                                <a href="@SortUrl("InternalStatus")" class="@(Model.SortBy == "InternalStatus" ? "text-primary fw-semibold" : "")">
                                                    Internal Status <i class="@SortIcon("InternalStatus") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-lhdn-status">
                                                <a href="@SortUrl("LHDNStatus")" class="@(Model.SortBy == "LHDNStatus" ? "text-primary fw-semibold" : "")">
                                                    LHDN Status <i class="@SortIcon("LHDNStatus") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-created-by">Created By</th>

                                            @if (invoiceDirection != "Draft")
                                            {
                                                @* Technical metadata — hidden by default, available via Customize *@
                                                <th class="col-uuid">
                                                    <a href="@SortUrl("UUID")" class="@(Model.SortBy == "UUID" ? "text-primary fw-semibold" : "")">
                                                        UUID <i class="@SortIcon("UUID") sort-indicator"></i>
                                                    </a>
                                                </th>
                                                <th class="col-submission-id">
                                                    <a href="@SortUrl("SubmissionId")" class="@(Model.SortBy == "SubmissionId" ? "text-primary fw-semibold" : "")">
                                                        Submission ID <i class="@SortIcon("SubmissionId") sort-indicator"></i>
                                                    </a>
                                                </th>
                                            }

                                            <th class="col-rejected-date">
                                                <a href="@SortUrl("RejectedDate")" class="@(Model.SortBy == "RejectedDate" ? "text-primary fw-semibold" : "")">
                                                    Rejected Date <i class="@SortIcon("RejectedDate") sort-indicator"></i>
                                                </a>
                                            </th>

                                            <th class="col-last-updated">
                                                <a href="@SortUrl("UpdatedDate")" class="@(Model.SortBy == "UpdatedDate" ? "text-primary fw-semibold" : "")">
                                                    Last Updated <i class="@SortIcon("UpdatedDate") sort-indicator"></i>
                                                </a>
                                            </th>

                                            @if (!Model.IsViewOnly)
                                            {
                                                <th class="col-action text-end">Action</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Invoices != null && Model.Invoices.Count > 0)
                                        {
                                            @foreach (var invoice in Model.Invoices.Where(i => Model.invoiceDirection != "Sent" || i.InternalStatusId != "Draft"))
                                            {
                                                // NEW LOGIC: Determine the correct TIN for the API call
                                                var isSelfBilled = new[] { "11", "12", "13", "14" }.Contains(invoice.DocTypeCode);
                                                var submittingTin = isSelfBilled 
                                                    ? (invoice.Customer?.TIN ?? invoice.PublicCustomer?.TIN) 
                                                    : (Model.invoiceDirection == "Received" 
                                                        ? (invoice.Customer?.TIN ?? invoice.PublicCustomer?.TIN) 
                                                        : invoice.Supplier?.TIN);

                                                <tr id="row-@invoice.InvoiceNo" data-invoiceno="@invoice.InvoiceNo">
                                                    @if (showSelection)
                                                    {
                                                        <td class="col-checkbox">
                                                            <input type="checkbox" class="invoice-checkbox" value="@invoice.UUID" data-invoiceno="@invoice.InvoiceNo" data-tin="@submittingTin" aria-label="Select invoice @invoice.InvoiceNo">
                                                        </td>
                                                    }
                                                    <td class="col-invoice-no" data-label="Invoice #">
