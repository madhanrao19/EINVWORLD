                                                                               data-uuid="@invoice.UUID"
                                                                               data-invoiceno="@invoice.InvoiceNo"
                                                                               data-tin="@(invoice.Customer?.TIN ?? invoice.PublicCustomer?.TIN)">
                                                                                <i class="ri-error-warning-fill me-1"></i>
                                                                                Request Reject e-Invoice
                                                                            </a>
                                                                        </li>
                                                                    }

                                                                    <!-- Cancel Invoice Button - Only for SUPPLIERS of this invoice -->
                                                                    @if (invoice.LHDNStatusId == "Valid" && invoice.LHDNStatusId != "Cancelled" && 
                                                                         !string.IsNullOrEmpty(invoice.Supplier?.TIN) && Model.UserTINs.Contains(invoice.Supplier.TIN))
                                                                    {
