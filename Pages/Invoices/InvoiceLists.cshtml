    <script>
    document.addEventListener("DOMContentLoaded", function () {
        initResizableColumns();
        initDragToScroll();
        initDoubleClickToCopy();
        const toggleBtn = document.querySelector('[data-bs-target="#instructionCollapse"]');
        const collapseEl = document.getElementById("instructionCollapse");

        if (!toggleBtn || !collapseEl) return;

        const bsCollapse = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });

        collapseEl.addEventListener('show.bs.collapse', () => {
            toggleBtn.innerHTML = `<i class="ri-eye-line me-1"></i> Hide Instructions`;
        });

        collapseEl.addEventListener('hide.bs.collapse', () => {
            toggleBtn.innerHTML = `<i class="ri-eye-off-line me-1"></i> Show Instructions`;
        });

        const storageKey = "invoiceHelpVisible";
        if (localStorage.getItem(storageKey) === "true") {
            bsCollapse.show();
        }

        collapseEl.addEventListener("shown.bs.collapse", () => {
            localStorage.setItem(storageKey, "true");
        });

        collapseEl.addEventListener("hidden.bs.collapse", () => {
            localStorage.setItem(storageKey, "false");
        });
    });
    function initDoubleClickToCopy() {
        const table = document.getElementById('invoiceTable');
        if (!table) return;

        table.addEventListener('dblclick', function(e) {
            // 1. Ignore if the user clicked a link, button, input, or the column resizer
            if (e.target.closest('a') || e.target.closest('button') || e.target.closest('input') || e.target.classList.contains('col-resizer')) {
                return; 
            }

            // 2. Find the closest table cell (td) that was clicked
            const td = e.target.closest('td');
            
            // 3. IGNORE if it's not a cell OR if it is the Action column
            if (!td || td.classList.contains('col-action')) {
                return;
            }

            // 4. Get the text content and clean up any extra whitespace/newlines
            const textToCopy = td.textContent.trim().replace(/\s+/g, ' ');
            if (!textToCopy) return;

            // 5. Copy the text to the clipboard
            navigator.clipboard.writeText(textToCopy).then(() => {
                // Show a tiny toast notification using SweetAlert2
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        toast: true,
                        position: 'top-end', 
                        icon: 'success',
                        title: 'Copied: ' + (textToCopy.length > 30 ? textToCopy.substring(0, 30) + '...' : textToCopy),
                        showConfirmButton: false,
                        timer: 1500,
                        timerProgressBar: true,
                        customClass: {
                            popup: 'colored-toast'
                        }
                    });
                }
            }).catch(err => {
                console.error('Failed to copy text: ', err);
            });
        });
    }
    function initDragToScroll() {
    const slider = document.querySelector('.table-scroll .inner');
    if (!slider) return;

    let isDown = false;
    let startX;
    let scrollLeft;

    slider.addEventListener('mousedown', (e) => {
        // CRITICAL: Ignore the drag if the user is clicking a link, button, checkbox, dropdown, or our column resizer!
        if (e.target.closest('a, button, input, .dropdown-menu, .col-resizer, .form-check')) {
            return;
        }

        isDown = true;
        slider.classList.add('is-dragging');
        
        // Calculate the starting position
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
    });

    slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
    });

    slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
    });

    slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        
        e.preventDefault(); // Stop default browser behaviors
        
        // Calculate how far the mouse has moved
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5; // Multiply by 1.5 to make scrolling slightly faster/smoother
        
        // Apply the scroll
        slider.scrollLeft = scrollLeft - walk;
    });
}


    function initResizableColumns() {
        const table = document.getElementById('invoiceTable');
        if (!table) return;
    
        const cols = table.querySelectorAll('thead th');
        const savedWidths = JSON.parse(localStorage.getItem('invoiceTableColWidths')) || {};

        // FIRST PASS: Lock every single column to an exact pixel width immediately.
        // This stops the browser from auto-distributing space, which causes the "jump".
        [].forEach.call(cols, function (col) {
            const colClass = Array.from(col.classList).find(c => c.startsWith('col-'));
        
            if (colClass && savedWidths[colClass]) {
                // Apply saved widths
                col.style.width = savedWidths[colClass];
                col.style.minWidth = savedWidths[colClass];
                col.style.maxWidth = savedWidths[colClass];
            } else {
                // Read the currently rendered actual width and lock it in
                const rect = col.getBoundingClientRect();
                if (rect.width > 0) {
                    col.style.width = `${rect.width}px`;
                    col.style.minWidth = `${rect.width}px`;
                    col.style.maxWidth = `${rect.width}px`;
                }
            }

            // Skip adding the drag handle for checkbox and action columns
            if (col.classList.contains('col-checkbox') || col.classList.contains('col-action')) return;

            // Create the drag handle element
            const resizer = document.createElement('div');
            resizer.classList.add('col-resizer');
            col.appendChild(resizer);
            col.style.position = 'relative'; 

            let x = 0;
            let w = 0;

            const mouseDownHandler = function (e) {
                x = e.clientX;
                // Now that padding is handled by border-box, this reading is perfectly accurate
                w = col.getBoundingClientRect().width;

                // Stop text from turning blue while dragging rapidly
                document.body.style.userSelect = 'none';

                document.addEventListener('mousemove', mouseMoveHandler);
                document.addEventListener('mouseup', mouseUpHandler);
                resizer.classList.add('resizing');
            };

            const mouseMoveHandler = function (e) {
                const dx = e.clientX - x;
                const newWidth = Math.max(30, w + dx); // 40px minimum width

                col.style.width = `${newWidth}px`;
                col.style.minWidth = `${newWidth}px`;
                col.style.maxWidth = `${newWidth}px`;
            };

            const mouseUpHandler = function () {
                document.removeEventListener('mousemove', mouseMoveHandler);
                document.removeEventListener('mouseup', mouseUpHandler);
                resizer.classList.remove('resizing');
            
                // Restore text selection
                document.body.style.userSelect = '';
            
                if (colClass) {
                    savedWidths[colClass] = col.style.width;
                    localStorage.setItem('invoiceTableColWidths', JSON.stringify(savedWidths));
                }
            };

            resizer.addEventListener('mousedown', mouseDownHandler);
        });
    }
    // Column Display Settings - Server-side User-specific Storage
    async function loadColumnSettings() {
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = {};
            
            if (csrfToken) {
                headers['RequestVerificationToken'] = csrfToken.value;
            }
            
            const response = await fetch('?handler=LoadColumnPreferences', {
                method: 'GET',
                headers: headers
            });
            
            const result = await response.json();
            
            if (result.success && result.data) {
                const settings = result.data;
                
                // Apply saved settings
                Object.keys(settings).forEach(columnClass => {
                    const isVisible = settings[columnClass];
                    const toggleCheckbox = document.querySelector(`input[value="${columnClass}"]`);
                    
                    if (toggleCheckbox && !toggleCheckbox.disabled) {
                        toggleCheckbox.checked = isVisible;
                    }
                    
                    // Apply visibility to table columns
                    const columns = document.querySelectorAll(`.${columnClass}`);
                    columns.forEach(col => {
                        if (isVisible) {
                            col.style.removeProperty('display');
                        } else {
                            col.style.setProperty('display', 'none', 'important');
                        }
                    });
                });
            }
        } catch (error) {
            console.error('Error loading column preferences:', error);
            // Fall back to default settings if loading fails
            loadDefaultColumnSettings();
        }
    }

    function loadDefaultColumnSettings() {
        // Default settings — the lean Stitch column set. Detail/audit columns (UUID, Submission ID,
        // Supplier, Rejected Date, Last Updated) stay available via Customize; saved user
        // preferences always override these defaults.
        const defaultSettings = {
            'col-checkbox': true,
            'col-invoice-no': true,
            'col-uuid': false,
            'col-submission-id': false,
            'col-supplier': false,
            'col-buyer': true,
            'col-submitted-date': true,
            'col-document-type': true,
            'col-total-amount': true,
            'col-lhdn-status': true,
            'col-internal-status': true,
            'col-rejected-date': false,
            'col-last-updated': true,
            'col-created-by': true,
            'col-action': true
        };

        Object.keys(defaultSettings).forEach(columnClass => {
            const isVisible = defaultSettings[columnClass];
            const toggleCheckbox = document.querySelector(`input[value="${columnClass}"]`);
            
            if (toggleCheckbox && !toggleCheckbox.disabled) {
                toggleCheckbox.checked = isVisible;
            }
            
            const columns = document.querySelectorAll(`.${columnClass}`);
            columns.forEach(col => {
                if (isVisible) {
                    col.style.removeProperty('display');
                } else {
                    col.style.setProperty('display', 'none', 'important');
                }
            });
        });
    }

    async function applyColumnSettings() {
        const settings = {};
        const toggles = document.querySelectorAll('.column-toggle');
        const saveButton = document.querySelector('#columnSettingsModal button[onclick="applyColumnSettings()"]') || 
                          document.querySelector('#columnSettingsModal .btn-primary');
        const saveSpinner = document.getElementById('saveSpinner');
        
        // Show loading state with null checks
        if (saveButton) {
            saveButton.disabled = true;
            const buttonIcon = saveButton.querySelector('i');
            if (buttonIcon) {
                buttonIcon.classList.add('d-none');
            }
        }
        
        if (saveSpinner) {
            saveSpinner.classList.remove('d-none');
        }
        
        toggles.forEach(toggle => {
            const columnClass = toggle.value;
            const isVisible = toggle.checked;
            settings[columnClass] = isVisible;
            
            // Apply visibility immediately
            const columns = document.querySelectorAll(`.${columnClass}`);
            columns.forEach(col => {
                if (isVisible) {
                    col.style.removeProperty('display');
                } else {
                    col.style.setProperty('display', 'none', 'important');
                }
            });
        });
        
        // Save to server
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = {
                'Content-Type': 'application/json'
            };
            
            if (csrfToken) {
                headers['RequestVerificationToken'] = csrfToken.value;
            }
            
            const response = await fetch('?handler=SaveColumnPreferences', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(settings)
            });
            
            const result = await response.json();
            
            if (result.success) {
                // Close modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('columnSettingsModal'));
                modal.hide();
                
                // Show enhanced success message
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Saved Successfully!',
                        text: 'Your personalized column preferences have been saved.',
                        icon: 'success',
                        confirmButtonColor: '#006948',
                        timer: 2500,
                        timerProgressBar: true,
                        showClass: {
                            popup: 'animate__animated animate__fadeInDown'
                        },
                        hideClass: {
                            popup: 'animate__animated animate__fadeOutUp'
                        }
                    });
                } else {
                    // Fallback to simple alert if SweetAlert2 is not loaded
                    alert('Column preferences saved successfully!');
                }
            } else {
                throw new Error(result.message || 'Failed to save preferences');
            }
        } catch (error) {
            console.error('Error saving column preferences:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: 'Oops! Something went wrong',
                    text: 'Failed to save your column preferences. Please try again.',
                    icon: 'error',
                    confirmButtonColor: '#006948',
                    confirmButtonText: 'Try Again'
                });
            } else {
                // Fallback to simple alert if SweetAlert2 is not loaded
                alert('Error: Failed to save column preferences. Please try again.');
            }
        } finally {
            // Reset button state with null checks
            if (saveButton) {
                saveButton.disabled = false;
                const buttonIcon = saveButton.querySelector('i');
                if (buttonIcon) {
                    buttonIcon.classList.remove('d-none');
                }
            }
            
            if (saveSpinner) {
                saveSpinner.classList.add('d-none');
            }
        }
    }

    // Load settings on page load
    document.addEventListener('DOMContentLoaded', function() {
        loadColumnSettings();
        
    });

    function showInvalidReason(btn) {
        const invoiceNo = btn.getAttribute('data-invoiceno');
        const uuid = btn.getAttribute('data-uuid');
        const submissionId = btn.getAttribute('data-submissionid');
        const tin = btn.getAttribute('data-tin');
        const generalReason = btn.getAttribute('data-reason');

        document.getElementById('invalidInvoiceNo').innerText = invoiceNo;
        document.getElementById('invalidUuid').innerText = uuid || "N/A";
        document.getElementById('invalidGeneralReason').innerText = generalReason || "Validation failed during processing.";
        
        document.getElementById('validationDetailsContainer').innerHTML = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Fetching technical validation steps from LHDN...</p>
            </div>`;
            
        var modal = new bootstrap.Modal(document.getElementById('invalidReasonModal'));
        modal.show();
        
        // Bypass API fetch if no LHDN tracking IDs exist
        if (!uuid && !submissionId) {
            document.getElementById('validationDetailsContainer').innerHTML = `
                <div class="alert alert-info border-0 shadow-sm"><i class="ri-information-line me-2"></i> No advanced LHDN tracking IDs available to fetch detailed technical steps.</div>`;
            return;
        }

        fetch(`?handler=ValidationDetails&uuid=${encodeURIComponent(uuid || '')}&submissionId=${encodeURIComponent(submissionId || '')}&tin=${encodeURIComponent(tin || '')}&invoiceNo=${encodeURIComponent(invoiceNo || '')}`)
            .then(response => response.json())
            .then(data => {
                let html = '';
                if (data.success && data.errors && data.errors.length > 0) {
                    html += '<div class="list-group gap-2">';
                    data.errors.forEach(err => {
                        html += `
                        <div class="list-group-item list-group-item-danger border border-danger border-opacity-25 rounded shadow-sm">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-danger fw-bold"><i class="ri-close-circle-line me-1"></i> Error Code: ${err.errorCode || 'N/A'}</h6>
                            </div>
                            <p class="mb-2"><strong>Error:</strong> ${err.error || 'Validation error'}</p>
                            ${err.propertyPath ? `<p class="mb-2 text-muted fs-13"><i class="ri-map-pin-line me-1"></i> <strong>Location:</strong> <code class="bg-white border px-1 rounded text-danger">${err.propertyPath}</code></p>` : ''}
                            ${err.innerErrors && err.innerErrors.length > 0 ? `<div class="bg-white border border-danger border-opacity-10 p-2 rounded mb-2 fs-13"><strong class="d-block mb-1 text-danger">Inner Errors:</strong><ul class="mb-0 text-muted" style="padding-left: 20px;">` + err.innerErrors.map(ie => `<li><b>${ie.propertyName}</b>: ${ie.error}</li>`).join('') + `</ul></div>` : ''}

                        </div>`;
                    });
                    html += '</div>';
                } else {
                    html = `<div class="alert alert-info border-0 shadow-sm"><i class="ri-information-line me-2"></i> No additional technical validation steps were provided by LHDN for this document. <br><br><b>Tip:</b> Review the general reason above and verify your input against LHDN MyInvois guidelines.</div>`;
                }
                document.getElementById('validationDetailsContainer').innerHTML = html;
            })
            .catch(error => {
                console.error("Popup Error:", error);
                document.getElementById('validationDetailsContainer').innerHTML = `
                    <div class="alert alert-danger border-0 shadow-sm"><i class="ri-error-warning-line me-2"></i> Failed to load detailed errors from the server.</div>`;
            });
    }
    document.addEventListener("DOMContentLoaded", function () {
        
        // --- DROPDOWN OVERFLOW FIX ---
        const tableContainer = document.querySelector('.table-scroll .inner');
        if (tableContainer) {
            // 1. When the user clicks the 3 dots to open the menu
            tableContainer.addEventListener('show.bs.dropdown', function (e) {
                const dropdownBtn = e.target;
                const dropdownMenu = dropdownBtn.nextElementSibling;
                
                if (!dropdownMenu || !dropdownMenu.classList.contains('dropdown-menu')) return;

                // Move the dropdown to the body to escape the table's clipping boundaries
                document.body.appendChild(dropdownMenu);
                
                // Force it to block briefly so we can calculate its width
                dropdownMenu.style.display = 'block';

                // Get exact coordinates of the button on the screen
                const btnRect = dropdownBtn.getBoundingClientRect();

                // Force the menu to float exactly under the button as a fixed element
                dropdownMenu.style.position = 'fixed';
                dropdownMenu.style.top = btnRect.bottom + 'px';
                // Align the right edge of the menu with the right edge of the button
                dropdownMenu.style.left = (btnRect.right - dropdownMenu.offsetWidth) + 'px'; 
                dropdownMenu.style.zIndex = '99999';

                // Save the button's ID so we know where to return the menu when it closes
                dropdownMenu.dataset.returnId = dropdownBtn.id || (dropdownBtn.id = 'btn-' + Math.random().toString(36).substr(2, 9));
            });

            // 2. When the user closes the menu
            tableContainer.addEventListener('hide.bs.dropdown', function (e) {
                const dropdownBtn = e.target;
                const dropdownMenu = document.querySelector('.dropdown-menu[data-return-id="' + dropdownBtn.id + '"]');
                
                if (dropdownMenu) {
                    // Put it back in the table next to its original button
                    dropdownBtn.parentNode.appendChild(dropdownMenu);
                    
                    // Clear the manual floating styles
                    dropdownMenu.style.position = '';
                    dropdownMenu.style.top = '';
                    dropdownMenu.style.left = '';
                    dropdownMenu.style.zIndex = '';
                    dropdownMenu.style.display = '';
                }
            });

            // 3. Auto-close floating dropdowns if the user scrolls the table or the window
            const closeFloatingDropdowns = function () {
                const openBtn = document.querySelector('.table-scroll .inner [data-bs-toggle="dropdown"][aria-expanded="true"]');
                if (openBtn) {
                    const bsDropdown = bootstrap.Dropdown.getInstance(openBtn);
                    if (bsDropdown) bsDropdown.hide();
                }
            };
            
            tableContainer.addEventListener('scroll', closeFloatingDropdowns);
            window.addEventListener('scroll', closeFloatingDropdowns);
        }
    });
</script>
<script>
    $(document).ready(function () {
        // Guard so interval ticks never stack: a rate-limited sync can take minutes server-side,
        // and firing another request on top multiplies the LHDN polling load.
        let sessionSyncInFlight = false;

        // Runs every 30 seconds
        setInterval(function () {
            // Stop running if the user switches to another browser tab (Saves API calls!)
            if (document.hidden) return;

            // Skip this tick if the previous sync request hasn't finished yet
            if (sessionSyncInFlight) return;

            // Gather the Invoice Numbers currently visible on the table
            let visibleInvoices = [];
            $('.invoice-checkbox').each(function () {
                let invoiceNo = $(this).data('invoiceno');
                if (invoiceNo) {
                    visibleInvoices.push(invoiceNo);
                }
            });

            if (visibleInvoices.length > 0) {
                sessionSyncInFlight = true;
                $.ajax({
                    url: '?handler=SyncActiveSession',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    data: JSON.stringify(visibleInvoices),
                    success: function (response) {
                        // If the backend found updates (e.g., a buyer rejected it!), reload the page to show it.
                        if (response.success && response.updatedCount > 0) {
                            console.log("Updates found from LHDN! Refreshing data...");
                            location.reload();
                        }
                    },
                    complete: function () {
                        sessionSyncInFlight = false;
                    }
                });
            }
        }, 30000); // 30,000 milliseconds = 30 seconds
    });
</script>
<script>
    // Bulk-action UX (presentational only — bulk handlers still read `.invoice-checkbox:checked`).
    //  1) Keep the Delete/Cancel/Reject bulk buttons hidden until at least one row is selected.
    //  2) Make the header "select all" checkbox actually select/deselect every row + reflect an
    //     indeterminate state. No PageModel/query/permission/API change.
    (function () {
        var bulkIds = ['bulkSubmitBtn', 'bulkDeleteBtn', 'bulkCancelBtn', 'bulkRejectBtn'];

        function rowCheckboxes() { return Array.prototype.slice.call(document.querySelectorAll('.invoice-checkbox')); }

        function refreshBulkVisibility() {
            var checked = document.querySelectorAll('.invoice-checkbox:checked').length;
            bulkIds.forEach(function (id) {
                var btn = document.getElementById(id);
                if (btn) { btn.classList.toggle('d-none', checked === 0); }
            });
            var bar = document.getElementById('bulkActionBar');
            if (bar) { bar.classList.toggle('d-none', checked === 0); }
            var count = document.getElementById('bulkSelectedCount');
            if (count) { count.textContent = checked + ' Selected'; }
            var selectAll = document.getElementById('selectAll');
            if (selectAll) {
                var total = rowCheckboxes().length;
                selectAll.checked = total > 0 && checked === total;
                selectAll.indeterminate = checked > 0 && checked < total;
            }
        }

        document.addEventListener('change', function (e) {
            var t = e.target;
            if (!t) return;
            if (t.id === 'selectAll') {
                rowCheckboxes().forEach(function (cb) { cb.checked = t.checked; });
                refreshBulkVisibility();
            } else if (t.classList && t.classList.contains('invoice-checkbox')) {
                refreshBulkVisibility();
            }
        });

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', refreshBulkVisibility);
        } else {
            refreshBulkVisibility();
        }
    })();
</script>
