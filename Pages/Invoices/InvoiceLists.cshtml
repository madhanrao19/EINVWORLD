                                                                                </a>
                                                                            </li>
                                                                            <li>
                                                                                <a class="dropdown-item" href="/Invoices/CreateInvoice?invoiceNo=@invoice.InvoiceNo&uuid=@invoice.UUID&type=SELF-RN">
                                                                                    <i class="ri-refund-fill me-1"></i> Create Self-billed RN
                                                                                </a>
                                                                            </li>
