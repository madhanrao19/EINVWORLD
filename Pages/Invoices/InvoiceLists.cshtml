                                                                            <a href="#" class="dropdown-item cancel-btn" data-uuid="@invoice.UUID" data-invoiceno="@invoice.InvoiceNo" data-tin="@invoice.Supplier.TIN">
                                                                                <i class="ri-close-circle-fill me-1"></i> Cancel e-Invoice
