                                                                    {
                                                                        <li>
                                                                            <a href="#"
                                                                               class="dropdown-item reject-btn"
                                                                               data-uuid="@invoice.UUID"
                                                                               data-invoiceno="@invoice.InvoiceNo"
                                                                               data-tin="@(invoice.Customer?.TIN ?? invoice.PublicCustomer?.TIN)">
