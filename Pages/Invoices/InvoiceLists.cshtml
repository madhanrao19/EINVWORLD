                                                                }
                                                            </ul>
                                                        </div>
                                                    </td>
                                                    }
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="14" class="text-center py-5 text-muted">
                                                    <i class="ri-file-list-3-line d-block mb-2" style="font-size:2rem;" aria-hidden="true"></i>
                                                    No e-invoices found for the current filters.
                                                </td>
                                            </tr>
                                        }
                                        </tbody>
                                     </table>
                                </div>
                            </div> 
                        </div> 
                    </div> 
                                    
                    @{
                        // Stitch table footer: result count (left) + compact numbered pager (right).
                        var footerTotal = Model.Metadata?.totalCount ?? 0;
                        var footerTotalPages = Math.Max(1, Model.Metadata?.totalPages ?? 1);
                        var footerPageNo = Math.Max(1, Model.SearchInput?.pageNo ?? 1);
                        var footerPageSize = Math.Max(1, Model.SearchInput?.pageSize ?? 25);
                        var footerFrom = footerTotal == 0 ? 0 : ((footerPageNo - 1) * footerPageSize) + 1;
                        var footerTo = Math.Min(footerTotal, footerPageNo * footerPageSize);

                        // Compact page window: 1 … (p-1) p (p+1) … N
                        var pagerPages = new List<int>();
                        for (var p = 1; p <= footerTotalPages; p++)
                        {
                            if (p == 1 || p == footerTotalPages || Math.Abs(p - footerPageNo) <= 1)
                            {
                                pagerPages.Add(p);
                            }
                        }
                    }
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 py-3 border-top">
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="text-muted small" aria-live="polite">
                                Showing @footerFrom&ndash;@footerTo of @footerTotal.ToString("N0") results
                            </span>
                            <div class="d-flex align-items-center">
                                <label for="pageSizeSelect" class="form-label me-2 mb-0 small text-muted">Show</label>
                                <select id="pageSizeSelect" class="form-select form-select-sm" style="width: auto;" onchange="changePageSize(this.value)">
                                    <option value="10" selected="@(Model.SearchInput?.pageSize == 10)">10</option>
                                    <option value="25" selected="@(Model.SearchInput?.pageSize == 25)">25</option>
                                    <option value="50" selected="@(Model.SearchInput?.pageSize == 50)">50</option>
                                    <option value="100" selected="@(Model.SearchInput?.pageSize == 100)">100</option>
                                </select>
                            </div>
                        </div>

                        <nav aria-label="Invoice list pages">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(footerPageNo <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="@(footerPageNo <= 1 ? "#" : PageUrl(footerPageNo - 1))" aria-label="Previous page">
                                        <i class="ri-arrow-left-s-line" aria-hidden="true"></i>
                                    </a>
                                </li>
                                @{ var lastRendered = 0; }
                                @foreach (var p in pagerPages)
                                {
                                    if (lastRendered > 0 && p - lastRendered > 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                                    }
                                    <li class="page-item @(p == footerPageNo ? "active" : "")" @(p == footerPageNo ? Html.Raw("aria-current=\"page\"") : null)>
                                        <a class="page-link" href="@PageUrl(p)">@p</a>
                                    </li>
                                    lastRendered = p;
                                }
                                <li class="page-item @(footerPageNo >= footerTotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@(footerPageNo >= footerTotalPages ? "#" : PageUrl(footerPageNo + 1))" aria-label="Next page">
                                        <i class="ri-arrow-right-s-line" aria-hidden="true"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                    </div>

                    @{
                        // Compliance strip (Stitch): real, direction-scoped LHDN status counts — no
                        // placeholder figures. Hidden entirely when the tab has no documents.
                        var lhdnCounts = Model.InvoiceSummaryByStatus ?? new Dictionary<string, int>();
                        var lhdnTotal = lhdnCounts.Values.Sum();
                        var lhdnValid = lhdnCounts.TryGetValue("Valid", out var lhdnValidCount) ? lhdnValidCount : 0;
                        var lhdnPending = lhdnCounts.TryGetValue("Submitted", out var lhdnPendingCount) ? lhdnPendingCount : 0;
                        var lhdnValidRate = lhdnTotal > 0 ? (int)Math.Round(lhdnValid * 100.0 / lhdnTotal) : 0;
                    }
                    @if (invoiceDirection != "Draft" && lhdnTotal > 0)
                    {
                        <div class="row g-3 mt-1">
                            <div class="col-md-5">
                                <div class="card mb-0 h-100">
                                    <div class="card-body py-3">
                                        <p class="text-muted text-uppercase fw-semibold small mb-2" style="letter-spacing:.05em;">LHDN Validation Rate</p>
                                        <div class="d-flex align-items-center gap-3">
                                            <h3 class="mb-0 fw-bold" style="color:@(lhdnValidRate >= 90 ? "var(--einv-success)" : lhdnValidRate >= 70 ? "var(--einv-warning)" : "var(--einv-error)");">@lhdnValidRate%</h3>
                                            <div class="flex-grow-1">
                                                <div class="progress" style="height:8px;">
                                                    <div class="progress-bar bg-primary" role="progressbar" style="width:@lhdnValidRate%;"
                                                         aria-valuenow="@lhdnValidRate" aria-valuemin="0" aria-valuemax="100"
                                                         aria-label="LHDN validation success rate"></div>
                                                </div>
                                                <span class="small text-muted">@lhdnValid.ToString("N0") of @lhdnTotal.ToString("N0") documents validated successfully</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="card mb-0 h-100">
                                    <div class="card-body py-3 d-flex align-items-center justify-content-between gap-3">
                                        <div>
                                            <p class="text-muted text-uppercase fw-semibold small mb-2" style="letter-spacing:.05em;">Pending Submissions</p>
                                            <h3 class="mb-0 fw-bold" style="color:var(--einv-warning);">@lhdnPending.ToString("N0")</h3>
                                            <span class="small text-muted">Invoices awaiting LHDN validation</span>
                                        </div>
                                        @if (lhdnPending > 0)
                                        {
                                            <a class="small fw-semibold text-decoration-none"
                                               href="./InvoiceLists?invoiceDirection=@invoiceDirection&LHDNStatus=Submitted&status=Submitted">
                                                View details <i class="ri-arrow-right-line align-bottom" aria-hidden="true"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (invoiceDirection == "Draft" && lhdnTotal > 0)
                    {
                        <div class="row g-3 mt-1">
                            <div class="col-md-5">
                                <div class="card mb-0 h-100">
                                    <div class="card-body py-3">
                                        <p class="text-muted text-uppercase fw-semibold small mb-2" style="letter-spacing:.05em;">Total Drafts</p>
                                        <h3 class="mb-0 fw-bold">@lhdnTotal.ToString("N0")</h3>
                                        <span class="small text-muted">Unsubmitted documents — submit within your reporting window</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                </div>

                <!-- Modal -->
                <div class="modal fade flip" id="deleteOrder" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-body p-5 text-center">
                                <lord-icon src="https://cdn.lordicon.com/gsqxdxog.json" trigger="loop" colors="primary:#405189,secondary:#f06548" style="width:90px;height:90px"></lord-icon>
                                <div class="mt-4 text-center">
                                    <h4 id="delete-message">Are you sure you want to delete this invoice?</h4>
                                    <p class="text-muted fs-15 mb-4">Deleting your order will remove all of your information from our database.</p>

                                    <!-- Hidden form to submit deletion request -->
                                    <form id="deleteForm" method="post" asp-page="/Invoices/InvoiceLists" asp-page-handler="SoftDelete">
                                        @Html.AntiForgeryToken()  <!-- 🔥 Needed -->

                                        <input type="hidden" id="internalId" name="internalId" />
                                        <div class="hstack gap-2 justify-content-center remove">
                                            <button class="btn btn-link link-success fw-medium text-decoration-none" id="deleteRecord-close" data-bs-dismiss="modal">
                                                <i class="ri-close-line me-1 align-middle"></i> Close
                                            </button>
                                            <button class="btn btn-danger" id="delete-record">Yes, Delete it</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!--end modal -->
                <!-- Export Modal -->
