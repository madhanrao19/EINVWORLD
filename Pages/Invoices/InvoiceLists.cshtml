                                            <p class="text-muted text-uppercase fw-semibold small mb-2" style="letter-spacing:.05em;">Pending Submissions</p>
                                            <h3 class="mb-0 fw-bold" style="color:var(--einv-warning);">@lhdnPending.ToString("N0")</h3>
                                            <span class="small text-muted">Invoices awaiting LHDN validation</span>
                                        </div>
