                            </div> 
                        </div> 
                    </div> 
                                    
                    @{
                        // "Showing X to Y of Z" range for the current page (Stitch table footer).
                        var footerTotal = Model.Metadata?.totalCount ?? 0;
                        var footerPageNo = Math.Max(1, Model.SearchInput?.pageNo ?? 1);
                        var footerPageSize = Math.Max(1, Model.SearchInput?.pageSize ?? 25);
                        var footerFrom = footerTotal == 0 ? 0 : ((footerPageNo - 1) * footerPageSize) + 1;
                        var footerTo = Math.Min(footerTotal, footerPageNo * footerPageSize);
                    }
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                        <!-- Page Size Selector -->
                        <div class="d-flex align-items-center">
                            <label for="pageSizeSelect" class="form-label me-2 mb-0">Show:</label>
                            <select id="pageSizeSelect" class="form-select form-select-sm" style="width: auto;" onchange="changePageSize(this.value)">
                                <option value="10" selected="@(Model.SearchInput?.pageSize == 10)">10</option>
                                <option value="25" selected="@(Model.SearchInput?.pageSize == 25)">25</option>
                                <option value="50" selected="@(Model.SearchInput?.pageSize == 50)">50</option>
                                <option value="100" selected="@(Model.SearchInput?.pageSize == 100)">100</option>
                            </select>
                            <span class="ms-2 text-muted">entries</span>
                        </div>

                        <span class="text-muted small" aria-live="polite">
                            Showing @footerFrom&ndash;@footerTo of @footerTotal.ToString("N0") results
                        </span>

                        <div class="pagination-wrap hstack gap-2">
                            @if (Model.SearchInput?.pageNo > 1)
                            {
                                <a class="page-item pagination-prev"
                                   asp-page="./InvoiceLists"
                                   asp-route-pageNo="@(Model.SearchInput.pageNo - 1)"
                                   asp-route-pageSize="@(Model.SearchInput.pageSize)"
                                   asp-route-searchQuery="@Model.SearchInput?.searchQuery"
                                   asp-route-submissionDateFrom="@Request.Query["submissionDateFrom"]"
                                   asp-route-submissionDateTo="@Request.Query["submissionDateTo"]"
                                   asp-route-documentType="@Request.Query["documentType"]"
                                   asp-route-LHDNStatus="@Request.Query["LHDNStatus"]"
                                   asp-route-InternalStatus="@Request.Query["InternalStatus"]"
                                   asp-route-sortBy="@Request.Query["sortBy"]"
                                   asp-route-sortOrder="@Request.Query["sortOrder"]"
                                   asp-route-invoiceDirection="@invoiceDirection">
                                    Previous
                                </a>
                            }
                            @if (Model.SearchInput?.pageNo < Model.Metadata?.totalPages)
                            {
                                <a class="page-item pagination-next"
                                   asp-page="./InvoiceLists"
                                   asp-route-pageNo="@(Model.SearchInput.pageNo + 1)"
                                   asp-route-pageSize="@(Model.SearchInput.pageSize)"
                                   asp-route-searchQuery="@Model.SearchInput?.searchQuery"
                                   asp-route-submissionDateFrom="@Request.Query["submissionDateFrom"]"
                                   asp-route-submissionDateTo="@Request.Query["submissionDateTo"]"
                                   asp-route-documentType="@Request.Query["documentType"]"
                                   asp-route-LHDNStatus="@Request.Query["LHDNStatus"]"
                                   asp-route-InternalStatus="@Request.Query["InternalStatus"]"
                                   asp-route-sortBy="@Request.Query["sortBy"]"
                                   asp-route-sortOrder="@Request.Query["sortOrder"]"
                                   asp-route-invoiceDirection="@invoiceDirection">
                                    Next
                                </a>
                            }
                        </div>
                    </div>

                    @{
                        // Compliance strip (Stitch): real, direction-scoped LHDN status counts — no
                        // placeholder figures. Hidden entirely when the tab has no documents.
                        var lhdnCounts = Model.InvoiceSummaryByStatus ?? new Dictionary<string, int>();
                        var lhdnTotal = lhdnCounts.Values.Sum();
                        var lhdnValid = lhdnCounts.TryGetValue("Valid", out var lhdnValidCount) ? lhdnValidCount : 0;
                        var lhdnPending = lhdnCounts.TryGetValue("Submitted", out var lhdnPendingCount) ? lhdnPendingCount : 0;
                        var lhdnValidRate = lhdnTotal > 0 ? (int)Math.Round(lhdnValid * 100.0 / lhdnTotal) : 0;
                    }
                    @if (invoiceDirection != "Draft" && lhdnTotal > 0)
                    {
                        <div class="row g-3 mt-1">
                            <div class="col-md-5">
                                <div class="card mb-0 h-100">
                                    <div class="card-body py-3">
                                        <p class="text-muted text-uppercase fw-semibold small mb-2" style="letter-spacing:.05em;">LHDN Validation Rate</p>
                                        <div class="d-flex align-items-center gap-3">
                                            <h3 class="mb-0 fw-bold" style="color:@(lhdnValidRate >= 90 ? "var(--einv-success)" : lhdnValidRate >= 70 ? "var(--einv-warning)" : "var(--einv-error)");">@lhdnValidRate%</h3>
                                            <div class="flex-grow-1">
                                                <div class="progress" style="height:8px;">
                                                    <div class="progress-bar bg-primary" role="progressbar" style="width:@lhdnValidRate%;"
                                                         aria-valuenow="@lhdnValidRate" aria-valuemin="0" aria-valuemax="100"
                                                         aria-label="LHDN validation success rate"></div>
                                                </div>
                                                <span class="small text-muted">@lhdnValid.ToString("N0") of @lhdnTotal.ToString("N0") documents validated successfully</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
