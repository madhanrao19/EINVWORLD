@page
@model eInvWorld.Pages.Items.DeleteModel
@{
    ViewData["Title"] = "Delete Item";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h5 class="card-title mb-0 text-white">Confirm Deletion</h5>
    </div>
    <div class="card-body">
        <h4>Are you sure you want to delete this item?</h4>
        <hr />
        <dl class="row mt-3">
            <dt class="col-sm-3">Item Code</dt>
            <dd class="col-sm-9">@Model.ItemDescription.ItemCode</dd>

            <dt class="col-sm-3">Classification Code</dt>
            <dd class="col-sm-9">@Model.ItemDescription.ClassificationCode</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.ItemDescription.Description</dd>
        </dl>

        <form method="post" class="mt-4">
            <input type="hidden" asp-for="ItemDescription.Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-page="./Index" class="btn btn-light">Cancel</a>
        </form>
    </div>
</div>