@page "{handler?}"
@model eInvWorld.Pages.Lead.ListModel

@{
    ViewData["Title"] = "Manage Customer Info Submissions";

    string GetSortUrl(string column)
    {
        string newSortOrder = (Model.SortBy == column && Model.SortOrder == "asc") ? "desc" : "asc";
        return Url.Page(null, new { SortBy = column, SortOrder = newSortOrder, searchName = Model.SearchName, searchTIN = Model.SearchTIN, searchEmail = Model.SearchEmail }) ?? "#";
    }

    Microsoft.AspNetCore.Html.IHtmlContent GetSortIcon(string column)
    {
        if (Model.SortBy == column)
        {
            return Html.Raw(Model.SortOrder == "asc" ? "<i class='ri-arrow-up-s-fill ms-1'></i>" : "<i class='ri-arrow-down-s-fill ms-1'></i>");
        }
        return Html.Raw("");
    }
}

<form method="post" id="__afForm">@Html.AntiForgeryToken()</form>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between bg-galaxy-transparent">
            <h4 class="mb-sm-0">Manage Customer Info Submissions</h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Lead Management</a></li>
                    <li class="breadcrumb-item active">Manage Customer Info Submissions</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <div class="flex-grow-1">
                        <div class="flex-grow-1">
                            <a class="btn btn-info add-btn" asp-page="/Suppliers/Create" asp-route-from="lead"><i class="ri-add-fill me-1 align-bottom"></i> Add Lead</a>
                            <a class="btn btn-secondary ms-2" asp-page="/Suppliers/Import" asp-route-from="lead"><i class="ri-upload-cloud-2-fill align-bottom me-1"></i> Import Leads</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-12">
        <div class="card" id="companyList">
            <div class="card-header">
                <div class="row g-2">
                    <form method="get">
                        <input type="hidden" name="SortBy" value="@Model.SortBy" />
                        <input type="hidden" name="SortOrder" value="@Model.SortOrder" />

                        <div class="row">
                            <div class="col">
                                <input type="text" name="searchName" class="form-control" placeholder="Search by Name" value="@Model.SearchName" />
                            </div>
                            <div class="col">
                                <input type="text" name="searchTIN" class="form-control" placeholder="Search by Tax ID" value="@Model.SearchTIN" />
                            </div>
                            <div class="col">
                                <input type="text" name="searchEmail" class="form-control" placeholder="Search by Email" value="@Model.SearchEmail" />
                            </div>
                            <div class="col">
                                <button type="submit" class="btn btn-secondary">Filter</button>
                                <button type="button" class="btn btn-danger" onclick="clearFilters()">Clear</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card-body">
                <div>
                    <div class="table-responsive table-card mb-3">
                        <table class="table align-middle table-nowrap mb-0" id="customerTable">
                            <thead class="table-light">
                                <tr>
                                    <th></th>
                                    <th><a href="@GetSortUrl("name")" class="text-dark text-decoration-none">Company @GetSortIcon("name")</a></th>
                                    <th><a href="@GetSortUrl("tin")" class="text-dark text-decoration-none">TIN @GetSortIcon("tin")</a></th>
                                    <th><a href="@GetSortUrl("regtype")" class="text-dark text-decoration-none">Reg Type @GetSortIcon("regtype")</a></th>
                                    <th>Reg No</th>
                                    <th><a href="@GetSortUrl("email")" class="text-dark text-decoration-none">Email @GetSortIcon("email")</a></th>
                                    <th>Phone</th>
                                    <th><a href="@GetSortUrl("updatedby")" class="text-dark text-decoration-none">Updated By @GetSortIcon("updatedby")</a></th>
                                    <th><a href="@GetSortUrl("updateddate")" class="text-dark text-decoration-none">Updated Date @GetSortIcon("updateddate")</a></th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody class="list form-check-all">
                                @foreach (var item in Model.LeadCompanies)
                                {
                                    <tr>
                                        <th scope="row">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="chk_child" value="option1">
                                            </div>
                                        </th>
                                        <td class="id" style="display:none;"><a href="javascript:void(0);" class="fw-medium link-primary">#VZ001</a></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0">
                                                    <img src="@(!string.IsNullOrEmpty(item.LogoPath) ? Url.Content(item.LogoPath) : Url.Content("~/assets/images/users/multi-user.jpg"))"
                                                         alt="Company Logo" class="avatar-xxs rounded-circle object-fit-contain" />
                                                </div>
                                                <div class="flex-grow-1 ms-2 name">
                                                    @Html.DisplayFor(modelItem => item.CompanyName)
                                                </div>
                                            </div>
                                        </td>
                                        <td class="tin"> @Html.DisplayFor(modelItem => item.TIN)</td>
                                        <td class="reg_type">@Html.DisplayFor(modelItem => item.RegTypeCode)</td>
                                        <td><span class="reg_no">@Html.DisplayFor(modelItem => item.RegNo)</span></td>
                                        <td><span class="email">@Html.DisplayFor(modelItem => item.Email)</span></td>
                                        <td><span class="phone_no">@Html.DisplayFor(modelItem => item.PhoneNo)</span></td>
                                        <td>@(string.IsNullOrEmpty(item.UpdatedBy) ? "-" : item.UpdatedBy)</td>
                                        <td>@(item.UpdatedDate?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                        <td>
                                            <ul class="list-inline hstack gap-2 mb-0">
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <li class="list-inline-item" data-bs-toggle="tooltip" title="To Approve">
                                                        <a href="javascript:void(0);" class="text-success approveBtn" data-id="@item.PartyInfoId" data-name="@item.CompanyName">
                                                            <i class="ri-checkbox-circle-line fs-16"></i>
                                                        </a>
                                                    </li>
                                                }
                                                <li class="list-inline-item" data-bs-toggle="tooltip" data-bs-trigger="hover" data-bs-placement="top" title="View">
                                                    <a asp-page="/Suppliers/Details" asp-route-id="@item.PartyInfoId" asp-route-from="lead" class="text-primary d-inline-block">
                                                        <i class="ri-eye-fill fs-16"></i>
                                                    </a>
                                                </li>
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <li class="list-inline-item" data-bs-toggle="tooltip" data-bs-trigger="hover" data-bs-placement="top" title="Edit">
                                                        <a asp-page="/Suppliers/Edit" asp-route-id="@item.PartyInfoId" asp-route-from="lead" class="text-primary">
                                                            <i class="ri-pencil-fill fs-16"></i>
                                                        </a>
                                                    </li>
                                                    <li class="list-inline-item" data-bs-toggle="tooltip" data-bs-trigger="hover" data-bs-placement="top" title="Delete">
                                                        <a href="javascript:void(0);" class="text-danger deleteBtn" data-id="@item.PartyInfoId" data-name="@item.CompanyName">
                                                            <i class="ri-delete-bin-fill fs-16"></i>
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="noresult" style="display: none">
                            <div class="text-center">
                                <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                                <h5 class="mt-2">Sorry! No Result Found</h5>
                                <p class="text-muted mb-0">We did not find any companies for your search.</p>
                            </div>
                        </div>
                    </div>
                    @if (Model.TotalPages > 1)
                    {
                        <div class="row mt-3 align-items-center">
                            <div class="col-sm">
                                <div class="text-muted">
                                    Showing <span class="fw-semibold">@(((Model.CurrentPage - 1) * Model.PageSize) + 1)</span> to
                                    <span class="fw-semibold">@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)</span> of
                                    <span class="fw-semibold">@Model.TotalRecords</span> entries
                                </div>
                            </div>
                            <div class="col-sm-auto">
                                <ul class="pagination pagination-separated pagination-sm justify-content-center justify-content-sm-start mb-0">
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage - 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchTIN = Model.SearchTIN, searchEmail = Model.SearchEmail })">Previous</a>
                                    </li>

                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Page(null, new { CurrentPage = i, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchTIN = Model.SearchTIN, searchEmail = Model.SearchEmail })">@i</a>
                                        </li>
                                    }

                                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Page(null, new { CurrentPage = Model.CurrentPage + 1, SortBy = Model.SortBy, SortOrder = Model.SortOrder, searchName = Model.SearchName, searchTIN = Model.SearchTIN, searchEmail = Model.SearchEmail })">Next</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        function approveLead(id, name) {
            Swal.fire({
                title: "Approve Lead?",
                text: `Approve ${name} and move it from Leads to Approved list?`,
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes, approve"
            }).then(result => {
                if (result.isConfirmed) {
                    fetch(`?handler=Approve`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                            "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: `id=${id}`
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire("Approved!", `"${name}" has been approved.`, "success").then(() => location.reload());
                        } else {
                            Swal.fire("Error!", "Approval failed.", "error");
                        }
                    })
                    .catch(() => Swal.fire("Error!", "Network error.", "error"));
                }
            });
        }

        function clearFilters() {
            const url = new URL(window.location.href);
            url.searchParams.delete("searchName");
            url.searchParams.delete("searchTIN");
            url.searchParams.delete("searchEmail");
            url.searchParams.delete("SortBy");
            url.searchParams.delete("SortOrder");
            window.location.href = url.toString();
        }

        document.querySelectorAll(".approveBtn").forEach(button => {
            button.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                const name = this.getAttribute("data-name");
                approveLead(id, name);
            });
        });

        document.querySelectorAll(".deleteBtn").forEach(button => {
            button.addEventListener("click", function () {
                var supplierId = this.getAttribute("data-id");
                var supplierName = this.getAttribute("data-name");

                Swal.fire({
                    title: "You are about to delete a lead ?",
                    text: `You are about to delete ${supplierName}. This action cannot be undone.`,
                    html: `
                        <div style="display: flex; justify-content: center; margin-bottom: 10px;">
                            <lord-icon src="https://cdn.lordicon.com/gsqxdxog.json" trigger="loop" colors="primary:#405189,secondary:#f06548" style="width:90px;height:90px; display: block; margin: 0 auto;"></lord-icon>
                        </div>
                        <p style="margin-top: 15px; font-size: 16px; color: #6c757d;">
                            You are about to delete <strong>${supplierName}</strong>. This action cannot be undone.
                        </p>`,
                    showCancelButton: true,
                    confirmButtonColor: "var(--einv-primary)",
                    cancelButtonColor: "var(--einv-danger)",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/Suppliers/Index?id=${supplierId}`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/x-www-form-urlencoded",
                                "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: `id=${supplierId}`
                        })
                        .then(response => {
                            if (!response.ok) throw new Error(`Error: ${response.status}`);
                            return response.text();
                        })
                        .then(() => {
                            Swal.fire("Deleted!", `${supplierName} has been deleted.`, "success").then(() => location.reload());
                        })
                        .catch(error => {
                            Swal.fire("Error!", "Failed to delete supplier. Try again later.", "error");
                            console.error("Delete error:", error);
                        });
                    }
                });
            });
        });
    </script>

    @if (TempData["StatusMessage"] != null || TempData["SuccessMessage"] != null)
    {
        var message = TempData["StatusMessage"] ?? TempData["SuccessMessage"] ?? "";
        <script>
            window.addEventListener("DOMContentLoaded", () => {
                const toast = document.createElement("div");
                toast.className = "toast align-items-center text-white bg-success border-0 position-fixed bottom-0 end-0 m-3 show";
                toast.setAttribute("role", "alert");
                toast.innerHTML = `
                    <div class="d-flex">
                        <div class="toast-body">@Html.Raw(message)</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>`;
                document.body.appendChild(toast);
                new bootstrap.Toast(toast).show();
            });
        </script>
    }
}