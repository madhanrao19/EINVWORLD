@page
@model eInvWorld.Pages.PublicCustomer.DetailsModel
@{
    ViewData["Title"] = "Buyer Details";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <h4 class="mb-sm-0">Buyer Details</h4>

    <div class="d-flex gap-2">
        @if (Model.CanEdit)
        {
            <a asp-page="./Edit"
               asp-route-id="@Model.PublicCustomer.PublicCustomerId"
               class="btn btn-primary">
                <i class="ri-edit-line me-1"></i> Edit
            </a>
        }

        <a asp-page="./List" class="btn btn-light">
            Back to List
        </a>
    </div>
</div>


<div class="card mt-3">
    <div class="card-body">

        <div class="row mb-4">
            <div class="col-md-3 text-center">
                <img src="@(string.IsNullOrEmpty(Model.PublicCustomer.LogoPath)
                                                 ? Url.Content("~/assets/images/users/multi-user.jpg")
                                                 : Url.Content(Model.PublicCustomer.LogoPath))"
                     class="img-fluid rounded-circle border"
                     style="width:120px;height:120px;object-fit:cover;" />
            </div>
            <div class="col-md-9">
                <h4>@Model.PublicCustomer.CompanyName</h4>
                <p class="text-muted mb-1">
                    <strong>TIN:</strong> @Model.PublicCustomer.TIN
                </p>
                <p class="text-muted mb-0">
                    <strong>Status:</strong>
                    @if (Model.PublicCustomer.IsApproved)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                </p>
            </div>
        </div>

        <hr />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Registration Type</label>
                <div>
                    @(Model.PublicCustomer.RegType?.Name ?? "-")
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Registration Number</label>
                <div>
                    @(Model.PublicCustomer.RegNo ?? "-")
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Old Registration Number</label>
                <div>@(Model.PublicCustomer.OldRegNo ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">MSIC Code</label>
                <div>@(Model.PublicCustomer.IndustryClassificationCode ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Business Description</label>
                <div>@(Model.PublicCustomer.BizDescription ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">SST</label>
                <div>@(Model.PublicCustomer.SST?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">TTX</label>
                <div>@(Model.PublicCustomer.TTX ?? "-")</div>
            </div>

            <div class="col-md-12 mb-3">
                <label class="fw-bold">Address</label>
                <div>
                    @if (!string.IsNullOrEmpty(Model.PublicCustomer.Addr1))
                    {
                        @Html.Raw(System.Net.WebUtility.HtmlEncode(Model.PublicCustomer.Addr1.Trim()).Replace("\n", "<br/>").Replace("\r", ""))

                        <br />
                    }
                    else
                    {
                        @Html.Raw("-<br />")
                    }
                    @(Model.PublicCustomer.PostalCode ?? "-") @(Model.PublicCustomer.CityName ?? "-")<br />
                    @(Model.PublicCustomer.State?.State ?? "-"), @(string.IsNullOrEmpty(Model.PublicCustomer.Country?.Country) ? "-" : System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(Model.PublicCustomer.Country.Country.ToLower()))
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Email</label>
                <div>@(Model.PublicCustomer.Email ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Phone</label>
                <div>@(Model.PublicCustomer.PhoneNo ?? "-")</div>
            </div>
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Fax</label>
                <div>@(Model.PublicCustomer.FaxNo ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Bank Name</label>
                <div>@(Model.PublicCustomer.BankName ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Bank Account</label>
                <div>@(Model.PublicCustomer.BankAccountNo ?? "-")</div>
            </div>
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Attention</label>
                <div>@(Model.PublicCustomer.Attention ?? "-")</div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Payment Terms</label>
                <div>@(Model.PublicCustomer.PaymentTerms ?? "-")</div>
            </div>

            <div class="col-md-12 mb-3">
                <label class="fw-bold">Remarks</label>
                <div>@(Model.PublicCustomer.Remarks ?? "-")</div>
            </div>
        </div>

    </div>
</div>
