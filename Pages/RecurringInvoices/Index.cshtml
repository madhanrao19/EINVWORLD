@page
@model eInvWorld.Pages.RecurringInvoices.IndexModel
@{
    ViewData["Title"] = "Recurring Invoices";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">Recurring Invoices</h4>
            <div class="page-title-right">
                <a href="/Templates/TemplateLists" class="btn btn-success">
                    <i class="ri-add-line align-bottom me-1"></i> New Profile
                </a>
            </div>
        </div>
        <p class="text-muted">Automate invoice generation on schedules based on your templates.</p>
    </div>
</div>

<div class="row">
    <div class="col-xl-4 col-md-6">
        <div class="card card-animate">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1 overflow-hidden">
                        <p class="text-uppercase fw-medium text-muted text-truncate mb-0">Total Profiles</p>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mt-4">
                    <div>
                        <h4 class="fs-22 fw-semibold ff-secondary mb-4">@Model.TotalProfiles</h4>
                    </div>
                    <div class="avatar-sm flex-shrink-0">
                        <span class="avatar-title bg-light rounded fs-3">
                            <i class="ri-refresh-line text-primary"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="card card-animate">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1 overflow-hidden">
                        <p class="text-uppercase fw-medium text-muted text-truncate mb-0">Active</p>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mt-4">
                    <div>
                        <h4 class="fs-22 fw-semibold ff-secondary mb-4">@Model.ActiveProfiles</h4>
                    </div>
                    <div class="avatar-sm flex-shrink-0">
                        <span class="avatar-title bg-success-subtle rounded fs-3">
                            <i class="ri-play-fill text-success"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="card card-animate">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1 overflow-hidden">
                        <p class="text-uppercase fw-medium text-muted text-truncate mb-0">Paused</p>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mt-4">
                    <div>
                        <h4 class="fs-22 fw-semibold ff-secondary mb-4">@Model.PausedProfiles</h4>
                    </div>
                    <div class="avatar-sm flex-shrink-0">
                        <span class="avatar-title bg-warning-subtle rounded fs-3">
                            <i class="ri-pause-fill text-warning"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle table-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Profile Name</th>
                                <th>Company</th>
                                <th>Buyer</th>
                                <th>Frequency</th>
                                <th>Next Run Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Profiles.Any())
                            {
                                foreach (var item in Model.Profiles)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="ri-refresh-line text-primary me-2"></i>
                                                <span class="fw-medium">@item.ProfileName</span>
                                            </div>
                                        </td>
                                        <td>@(item.InvoiceTemplate?.Supplier?.CompanyName ?? "-")</td>
                                        <td>@(item.InvoiceTemplate?.Customer?.CompanyName ?? item.InvoiceTemplate?.PublicCustomer?.CompanyName ?? "All Buyers")</td>
                                        <td>
                                            <span class="badge bg-light text-body border border-dark-subtle">
                                                <i class="ri-time-line align-bottom me-1"></i> @item.Frequency
                                            </span>
                                        </td>
                                        <td>@item.NextRunDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (item.Status == "Active")
                                            {
                                                <span class="badge bg-success-subtle text-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning">Paused</span>
                                            }
                                        </td>
                                        <td>
                                            <ul class="list-inline hstack gap-2 mb-0">
                                                <li class="list-inline-item" title="@(item.Status == "Active" ? "Pause Profile" : "Resume Profile")">
                                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-soft-@(item.Status == "Active" ? "warning" : "success") border-0">
                                                            <i class="ri-@(item.Status == "Active" ? "pause" : "play")-fill fs-16"></i>
                                                        </button>
                                                    </form>
                                                </li>
                                                <li class="list-inline-item" title="Edit Profile">
                                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="text-primary d-inline-block">
                                                        <i class="ri-pencil-fill fs-16"></i>
                                                    </a>
                                                </li>
                                                <li class="list-inline-item" title="Delete Profile">
                                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this recurring profile? This will not delete the base template.');">
                                                        <button type="submit" class="btn btn-link p-0 text-danger border-0">
                                                            <i class="ri-delete-bin-5-fill fs-16"></i>
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="ri-calendar-todo-line fs-24 d-block mb-2"></i>
                                        No recurring profiles found. Click "New Profile" to automate an invoice.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>