@* Shared Partial: _HelpInstructions.cshtml *@
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="ri-lightbulb-flash-line me-2"></i>How to Use the e-Invoice Actions
        </h5>
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#instructionCollapse">
            <i class="ri-eye-off-line me-1"></i> Show Instructions
        </button>
    </div>
    <div class="collapse" id="instructionCollapse">
        <div class="card-body">
            <ul class="mb-2">
                <li><b>Draft:</b> You can <i class="ri-pencil-fill text-primary me-1"></i><b>Edit</b>, <i class="ri-delete-bin-5-fill text-danger me-1"></i><b>Delete</b>, <i class="ri-mail-send-fill text-info me-1"></i><b>Resend</b>, or <i class="ri-send-plane-fill text-success me-1"></i><b>Submit</b> the e-invoice.</li>
                <li><b>Valid:</b> You can <i class="ri-eye-fill text-primary me-1"></i><b>View</b>, <i class="ri-close-circle-fill text-danger me-1"></i><b>Cancel</b>, <i class="ri-mail-send-fill text-info me-1"></i><b>Resend</b>, or <i class="ri-download-2-line text-secondary me-1"></i><b>Download</b> the e-invoice.</li>
                <li><b>Invalid:</b> You can <i class="ri-mail-send-fill text-info me-1"></i><b>Resend</b> after correction.</li>
                <li><b>Cancelled:</b> You can <i class="ri-mail-send-fill text-info me-1"></i><b>Resend</b> if necessary.</li>
                <li><b>Submitted:</b> <i class="ri-eye-fill text-primary me-1"></i>View-only; no further actions can be taken.</li>
            </ul>
            <p class="mb-0">Hover over action icons for quick tips, and check the <b>Status</b> column for more context.</p>
        </div>
    </div>
</div>
