@{
    Layout = null; // Prevent nesting layouts
}
@inject IConfiguration Configuration

<!DOCTYPE html>

<html lang="en" data-layout="vertical" data-topbar="light" data-sidebar="dark" data-sidebar-size="lg" data-sidebar-image="none" data-preloader="disable" data-theme="default" data-theme-colors="green">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>@ViewData["Title"]</title>
    <meta name="description" content="@ViewData["Description"]" />
    <meta name="keywords" content="@ViewData["Keywords"]" />

    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["Description"]" />
    <meta property="og:image" content="@ViewData["MetaImage"] ?? " /assets/images/default-og.jpg"" />
    <meta property="og:type" content="article" />



    @await Html.PartialAsync("_Favicons")

  @*   <!-- Favicon -->
    <link href="~/img/favicon.ico" rel="icon">

    <!-- App favicon -->
    <link rel="shortcut icon" href="~/assets/images/favicon.ico"> *@

    <!-- Core CSS -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css">
    <link href="~/assets/css/icons.min.css" rel="stylesheet" type="text/css">
    <link href="~/assets/css/app.min.css" rel="stylesheet" type="text/css">
    <link href="~/assets/css/custom.min.css" rel="stylesheet" type="text/css">
    @* <link href="~/css/style.css" rel="stylesheet" type="text/css"> *@

    <!-- Sweet Alert CSS -->
    <link href="~/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css">


    <!--Turnstile widget. data-cfasync="false" exempts it from Cloudflare Rocket Loader (incompatible with Turnstile).-->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" data-cfasync="false" async defer></script>

    <!-- ✅ REQUIRED for Select2 -->
    <script src="~/assets/libs/jquery/dist/jquery.min.js"></script>

    <!-- Select2 CSS + JS -->
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
    <link href="~/assets/libs/swiper/swiper-bundle.min.css" rel="stylesheet" type="text/css" />

    @await Html.PartialAsync("_GoogleAnalytics")

</head>

<body>
    <!-- Non-authenticated user header -->
    <!-- Begin page -->
    <div class="layout-wrapper landing">
        <!-- Navbar Start -->
        <nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0 shadow-sm">
            <div class="container d-flex align-items-center justify-content-between py-2 px-3">

                <!-- Brand Logo -->
                <a href="/" class="navbar-brand d-flex align-items-center px-3">
                    <img src="~/images/einvworld-logo.png" alt="eInvWorld Logo" style="width: 100px; height: auto;">
                </a>

                <!-- Toggler Button (single only) -->
                <button class="navbar-toggler me-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                        aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Collapsible Content -->
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">

                    <!-- Center Navigation -->
                    <div class="navbar-nav mx-auto text-center text-lg-start mt-3 mt-lg-0">
                        <a href="/" class="nav-item nav-link fw-semibold fs-15 active">Home</a>
                        <a href="/about" class="nav-item nav-link fw-semibold fs-15">About</a>
                        <a href="/ourservices" class="nav-item nav-link fw-semibold fs-15">Our Services</a>
                        <a href="/resources" class="nav-item nav-link fw-semibold fs-15">Resources</a>
                        <a href="/contact" class="nav-item nav-link fw-semibold fs-15">Contact</a>
                    </div>

                    <!-- Right-Aligned Buttons -->
                    <div class="d-grid gap-2 d-lg-flex mt-3 mt-lg-0 ms-lg-3 text-center">
                        <a class="btn btn-primary px-4 py-2 @(Context.Request.Path.Value?.Contains("/customer-info/submit") == true ? "active" : "")"
                           href="/customer-info/submit">
                            <i class="ri-suitcase-fill align-bottom me-1"></i> Submit Company Info for e-Invoicing
                        </a>
                        <a class="btn btn-soft-primary px-4 py-2" asp-area="Identity" asp-page="/Account/Login">
                            <i class="ri-user-3-line align-bottom me-1"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </nav>
        <!-- Navbar End -->
        @* Public pages reuse full-bleed banners (mx-n4) designed for the authenticated
           layout's padded .page-content. Without that padding they spill ~24px past the
           viewport; clip the horizontal excess here so the banner still reaches both edges
           without creating a page-wide horizontal scrollbar. *@
        <div style="overflow-x: clip;">
            @RenderBody()
        </div>

        <!-- Start footer -->
        <footer class="custom-footer bg-dark py-3 position-relative">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 mt-4">
                        <div>
                            <img src="~/images/einvworld-logo-light.png" alt="eInvWorld Logo" style="width: 200px; height: auto;" class="me-2">
                            <div class="mt-4 fs-13">
                                <p class="ff-secondary">
                                    <i class="las la-map-marked fs-4 me-2"></i>
                                    18.2, CP Tower, Pusat Dagang, Seksyen 16, <br />46350 Petaling Jaya, Selangor, MYS
                                </p>
                                <p class="ff-secondary">
                                    <i class="las la-phone fs-4 me-2"></i>
                                    +603-7660 2222
                                </p>
                                <p class="ff-secondary">
                                    <i class="las la-envelope fs-4 me-2"></i>
                                    info@einvworld.com
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7 ms-lg-auto">
                        <div class="row">
                            <div class="col-sm-4 mt-4">
                                <h5 class="text-white mb-0">Quick Links</h5>
                                <div class="text-muted mt-3">
                                    <ul class="list-unstyled ff-secondary footer-list fs-14">
                                        <li><a href="/about">About Us</a></li>
                                        <li><a href="/ourservices">Our Services</a></li>
                                        <li><a href="/resources">Resources</a></li>
                                        <li><a href="/contact">Contact Us</a></li>
                                        <li><a href="/term-and-condition">Terms & Condition</a></li>
                                        <li><a href="/privacy">Privacy &amp; Cookie Policy</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row text-center text-sm-start align-items-center mt-5">
                    <div class="col-sm-6">
                        <div>
                            <p class="copy-rights mb-0">
                                <script>document.write(new Date().getFullYear())</script> © eInvWorld 
                                | Version @Configuration["AppInfo:Version"]
                                | Designed by
                                <a href="https://www.datamationgroup.com/"
                                   target="_blank"
                                   class="text-white border-bottom text-nowrap text-sm-wrap">
                                    Datamation Technology (M) Sdn Bhd<span class="d-block d-sm-none"></span> [199601004511 (376857P)]
                                </a>
                            </p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-sm-end mt-3 mt-sm-0">
                            <ul class="list-inline mb-0 footer-social-link">
                                <li class="list-inline-item">
                                    <a href="https://www.facebook.com/DatamationGroup/" class="avatar-xs d-block">
                                        <div class="avatar-title rounded-circle">
                                            <i class="ri-facebook-fill"></i>
                                        </div>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="https://twitter.com/datamationmy" class="avatar-xs d-block">
                                        <div class="avatar-title rounded-circle">
                                            <i class="ri-twitter-fill"></i>
                                        </div>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="https://www.linkedin.com/company/421306" class="avatar-xs d-block">
                                        <div class="avatar-title rounded-circle">
                                            <i class="ri-linkedin-fill"></i>
                                        </div>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="https://www.youtube.com/channel/UCNFjNa9Jr6HyFozB720RtsA" class="avatar-xs d-block">
                                        <div class="avatar-title rounded-circle">
                                            <i class="ri-youtube-fill"></i>
                                        </div>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
        <!-- end footer -->
        <!--start back-to-top-->
    <button onclick="topFunction()" class="btn btn-danger btn-icon landing-back-top" id="back-to-top">
        <i class="ri-arrow-up-line"></i>
    </button>
    <!--end back-to-top-->
   

    <!-- Core JavaScript -->
    <script src="~/assets/libs/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/libs/simplebar/simplebar.min.js"></script>
    <script src="~/assets/libs/node-waves/waves.min.js"></script>
    <script src="~/assets/libs/feather-icons/feather.min.js"></script>
    <script src="~/assets/js/pages/plugins/lord-icon-2.1.0.js"></script>
    <script src="~/assets/js/plugins.js"></script>
    <!--Swiper slider js-->
    <script src="~/assets/libs/swiper/swiper-bundle.min.js"></script>

    <!-- landing init -->
    <script src="~/assets/js/pages/landing.init.js"></script>

    <script src="~/assets/js/pages/timeline.init.js"></script>


        <!-- Select2 CSS + JS -->
        <link href="~/assets/libs/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
        <script src="~/assets/libs/select2/js/select2.min.js"></script>
</body>
</html>
@RenderSection("Scripts", required: false)
