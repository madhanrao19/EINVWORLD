    <!-- Global Theme Management Script -->
    <script>
        $(document).ready(function() {
            // Load global theme on page load
            loadGlobalTheme();
            
            // Handle save global theme button click (Admin only)
            $('#save-global-theme').click(function() {
                saveGlobalTheme();
            });
        });

        function loadGlobalTheme() {
            fetch('/api/Theme/global')
                .then(response => response.json())
                .then(data => {
                    console.log('Loading global theme:', data);
                    
                    // Apply global theme settings to current page
                    applyGlobalTheme(data);
                })
                .catch(error => {
                    console.error('Error loading global theme:', error);
                });
        }

        function applyGlobalTheme(theme) {
            // Apply theme settings to document
            document.documentElement.setAttribute('data-layout', theme.dataLayout);
            document.documentElement.setAttribute('data-theme', theme.dataTheme);
            document.documentElement.setAttribute('data-theme-colors', theme.dataThemeColors);
            document.documentElement.setAttribute('data-topbar', theme.dataTopbar);
            document.documentElement.setAttribute('data-sidebar', theme.dataSidebar);
            document.documentElement.setAttribute('data-sidebar-size', theme.dataSidebarSize);
            document.documentElement.setAttribute('data-sidebar-image', theme.dataSidebarImage);
            document.documentElement.setAttribute('data-layout-width', theme.dataLayoutWidth);
            document.documentElement.setAttribute('data-layout-position', theme.dataLayoutPosition);
            document.documentElement.setAttribute('data-layout-style', theme.dataLayoutStyle);
            document.documentElement.setAttribute('data-bs-theme', theme.dataBsTheme);
            document.documentElement.setAttribute('data-preloader', theme.dataPreloader);
            document.documentElement.setAttribute('data-body-image', theme.dataBodyImage);
            document.documentElement.setAttribute('data-sidebar-visibility', theme.dataSidebarVisibility);

            // Override sessionStorage with global theme
            sessionStorage.setItem('data-layout', theme.dataLayout);
            sessionStorage.setItem('data-theme', theme.dataTheme);
            sessionStorage.setItem('data-theme-colors', theme.dataThemeColors);
            sessionStorage.setItem('data-topbar', theme.dataTopbar);
            sessionStorage.setItem('data-sidebar', theme.dataSidebar);
            sessionStorage.setItem('data-sidebar-size', theme.dataSidebarSize);
            sessionStorage.setItem('data-sidebar-image', theme.dataSidebarImage);
            sessionStorage.setItem('data-layout-width', theme.dataLayoutWidth);
            sessionStorage.setItem('data-layout-position', theme.dataLayoutPosition);
            sessionStorage.setItem('data-layout-style', theme.dataLayoutStyle);
            sessionStorage.setItem('data-bs-theme', theme.dataBsTheme);
            sessionStorage.setItem('data-preloader', theme.dataPreloader);
            sessionStorage.setItem('data-body-image', theme.dataBodyImage);
            sessionStorage.setItem('data-sidebar-visibility', theme.dataSidebarVisibility);

            // Update customizer checkboxes to reflect current theme
            updateCustomizerControls(theme);
            
            console.log('✅ Global theme applied successfully');
        }

        function updateCustomizerControls(theme) {
            // Update radio buttons in theme customizer
            $('input[name="data-layout"][value="' + theme.dataLayout + '"]').prop('checked', true);
            $('input[name="data-theme"][value="' + theme.dataTheme + '"]').prop('checked', true);
            $('input[name="data-theme-colors"][value="' + theme.dataThemeColors + '"]').prop('checked', true);
            $('input[name="data-topbar"][value="' + theme.dataTopbar + '"]').prop('checked', true);
            $('input[name="data-sidebar"][value="' + theme.dataSidebar + '"]').prop('checked', true);
            $('input[name="data-sidebar-size"][value="' + theme.dataSidebarSize + '"]').prop('checked', true);
            $('input[name="data-sidebar-image"][value="' + theme.dataSidebarImage + '"]').prop('checked', true);
            $('input[name="data-layout-width"][value="' + theme.dataLayoutWidth + '"]').prop('checked', true);
            $('input[name="data-layout-position"][value="' + theme.dataLayoutPosition + '"]').prop('checked', true);
            $('input[name="data-layout-style"][value="' + theme.dataLayoutStyle + '"]').prop('checked', true);
            $('input[name="data-bs-theme"][value="' + theme.dataBsTheme + '"]').prop('checked', true);
            $('input[name="data-preloader"][value="' + theme.dataPreloader + '"]').prop('checked', true);
            $('input[name="data-body-image"][value="' + theme.dataBodyImage + '"]').prop('checked', true);
            $('input[name="data-sidebar-visibility"][value="' + theme.dataSidebarVisibility + '"]').prop('checked', true);
        }

        function saveGlobalTheme() {
            // Get current theme settings from sessionStorage and document attributes
            const themeData = {
                'data-layout': document.documentElement.getAttribute('data-layout') || sessionStorage.getItem('data-layout') || 'vertical',
                'data-theme': document.documentElement.getAttribute('data-theme') || sessionStorage.getItem('data-theme') || 'default',
                'data-theme-colors': document.documentElement.getAttribute('data-theme-colors') || sessionStorage.getItem('data-theme-colors') || 'green',
                'data-topbar': document.documentElement.getAttribute('data-topbar') || sessionStorage.getItem('data-topbar') || 'light',
                'data-sidebar': document.documentElement.getAttribute('data-sidebar') || sessionStorage.getItem('data-sidebar') || 'dark',
                'data-sidebar-size': document.documentElement.getAttribute('data-sidebar-size') || sessionStorage.getItem('data-sidebar-size') || 'lg',
                'data-sidebar-image': document.documentElement.getAttribute('data-sidebar-image') || sessionStorage.getItem('data-sidebar-image') || 'none',
                'data-layout-width': document.documentElement.getAttribute('data-layout-width') || sessionStorage.getItem('data-layout-width') || 'fluid',
                'data-layout-position': document.documentElement.getAttribute('data-layout-position') || sessionStorage.getItem('data-layout-position') || 'fixed',
                'data-layout-style': document.documentElement.getAttribute('data-layout-style') || sessionStorage.getItem('data-layout-style') || 'default',
                'data-bs-theme': document.documentElement.getAttribute('data-bs-theme') || sessionStorage.getItem('data-bs-theme') || 'light',
                'data-preloader': document.documentElement.getAttribute('data-preloader') || sessionStorage.getItem('data-preloader') || 'disable',
                'data-body-image': document.documentElement.getAttribute('data-body-image') || sessionStorage.getItem('data-body-image') || 'none',
                'data-sidebar-visibility': document.documentElement.getAttribute('data-sidebar-visibility') || sessionStorage.getItem('data-sidebar-visibility') || 'show'
            };

            console.log('Saving global theme:', themeData);

            // Show loading state
            const saveButton = $('#save-global-theme');
            const originalText = saveButton.html();
            saveButton.prop('disabled', true).html('<i class="ri-loader-4-line spinner-border spinner-border-sm me-1"></i>Saving...');

            // Get CSRF token
            let token = $('input[name="__RequestVerificationToken"]').val();
            if (!token) {
                // Try to get from meta tag
                token = $('meta[name="__RequestVerificationToken"]').attr('content');
            }

            const headers = {
                'Content-Type': 'application/json'
            };

            // Add CSRF token if available
            if (token) {
                headers['RequestVerificationToken'] = token;
            }

            fetch('/api/Theme/save', {
                method: 'POST',
                headers: headers,
                credentials: 'same-origin', // Include cookies for authentication
                body: JSON.stringify(themeData)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                saveButton.prop('disabled', false).html(originalText);
                
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Theme Saved!',
                        text: 'Global theme settings have been saved for all users.',
                        confirmButtonColor: '#3AA564'
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Save Failed',
                        text: data.message || 'Failed to save theme settings.',
                        confirmButtonColor: '#3AA564'
                    });
                }
            })
            .catch(error => {
                saveButton.prop('disabled', false).html(originalText);
                console.error('Error saving global theme:', error);
                
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while saving theme settings: ' + error.message,
                    confirmButtonColor: '#3AA564'
                });
            });
        }
                document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("searchInput");
            const searchDropdown = document.getElementById("search-dropdown");
            const resultsContainer = document.getElementById("search-results-container");
            const closeBtn = document.getElementById("search-close-options");
            let debounceTimer;

            if(searchInput) {
                searchInput.addEventListener("input", function (e) {
                    clearTimeout(debounceTimer);
                    const query = e.target.value.trim();

                    if (query.length > 0) {
                        closeBtn.classList.remove("d-none");
                    } else {
                        closeBtn.classList.add("d-none");
                        searchDropdown.classList.remove("show");
                        return;
                    }

                    // Debounce: wait 300ms after user stops typing to query server
                    debounceTimer = setTimeout(() => {
                        if (query.length >= 2) { // Only search if 2 or more characters
                            performSearch(query);
                        }
                    }, 300);
                });

                // Close search when clicking close button
                closeBtn.addEventListener("click", function() {
                    searchInput.value = "";
                    searchDropdown.classList.remove("show");
                    closeBtn.classList.add("d-none");
                });

                // Hide dropdown when clicking outside
                document.addEventListener("click", function(e) {
                    if (!searchInput.contains(e.target) && !searchDropdown.contains(e.target)) {
                        searchDropdown.classList.remove("show");
                    }
                });
            }

            async function performSearch(query) {
                try {
                    const response = await fetch(`/api/Search?q=${encodeURIComponent(query)}`);
                    if (response.ok) {
                        const data = await response.json();
                        renderResults(data.results);
                    }
                } catch (error) {
                    console.error("Search failed", error);
                }
            }

            function renderResults(results) {
                resultsContainer.innerHTML = ""; // Clear old results

                if (results.length === 0) {
                    resultsContainer.innerHTML = `<div class="p-3 text-center text-muted">No results found</div>`;
                } else {
                    // Group results by Type (e.g., Pages, Invoices, Users)
                    const grouped = results.reduce((acc, curr) => {
                        (acc[curr.type] = acc[curr.type] || []).push(curr.data);
                        return acc;
                    }, {});

                    for (const [type, items] of Object.entries(grouped)) {
                        // Add Category Header
                        resultsContainer.innerHTML += `
                            <div class="dropdown-header mt-2">
                                <h6 class="text-overflow text-muted mb-1 text-uppercase">${type}s</h6>
                            </div>`;

                        // Add Items
                        items.forEach(item => {
                            const icon = item.icon || (type === 'User' ? 'ri-user-line' : type === 'Invoice' ? 'ri-file-list-3-line' : 'ri-search-line');
                            resultsContainer.innerHTML += `
                                <a href="${item.link}" class="dropdown-item notify-item">
                                    <i class="${icon} align-middle fs-18 text-muted me-2"></i>
                                    <span>${item.title} <small class="text-muted ms-1">${item.subtitle || ''}</small></span>
                                </a>`;
                        });
                    }
                }

                // Show the dropdown
                searchDropdown.classList.add("show");
            }
        });
    </script>
