<body>

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1055">
        <div id="toast-success" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="toast-success-message">
                    <!-- Message will be injected here -->
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>


    <div class="layout-wrapper">
        <!-- Sidebar -->
        @if (ViewBag.HideSidebar != true)
        {
            @await Html.PartialAsync("_Sidebar")
        }
        <div class="main-content">
            <div class="page-content">
                <div class="container-fluid">
                    <!-- Main body content -->
                    @RenderBody()
                </div>
            </div>
            <footer class="footer">
                <div class="container-fluid">
                    <div class="row text-muted">
                        <div class="col-6 text-start">
                            <p class="mb-0">
                                <a href="https://www.datamationgroup.com/" class="text-muted">
                                    <strong>
                                        @* Version string is Admin-only — a granular build number aids attacker fingerprinting for no benefit to other roles. *@
                                        © eInvWorld @(User.IsInRole("Admin") ? $"| {Configuration["AppInfo:Version"]} " : "")| Datamation Technology (M) Sdn Bhd [199601004511 (376857P)]
                                    </strong>
                                </a>
                            </p>
                        </div>
                        <div class="col-6 text-end">
                            <ul class="list-inline">
                                <li class="list-inline-item">
                                    <a href="/contact" class="text-muted">Contact</a>
                                </li>
                                <!-- More Footer Items -->
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>
   
    <!--start back-to-top-->
    <button onclick="topFunction()" class="btn btn-danger btn-icon" id="back-to-top">
        <i class="ri-arrow-up-line"></i>
    </button>
    <!--end back-to-top-->
    <!--preloader-->
    <div id="preloader">
        <div id="status">
            <div class="spinner-border text-primary avatar-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
    @* The theme normally fades the preloader out on window 'load'. If any resource is slow
       or unreachable, that event is delayed and the overlay stays up intercepting clicks.
       Hide it as soon as the DOM is ready (with a hard 3s cap) so it can never block the UI. *@
    <script>
        (function () {
            var hide = function () {
                var p = document.getElementById('preloader');
                if (p) { p.style.opacity = '0'; p.style.visibility = 'hidden'; }
            };
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', hide);
            } else { hide(); }
            setTimeout(hide, 3000);
        })();
    </script>

