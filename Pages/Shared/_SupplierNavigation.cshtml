@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject eInvWorld.Data.ApplicationDbContext DbContext
@*
    Supplier role navigation (Tabler). Rendered inside _TablerSidebar for Supplier users only.
    Resolves the caller's own company id (same query as the Velzon _Sidebar) for the
    "My Company Details" link. Cosmetic only — authorization is enforced server-side and unchanged.
*@
@{
    string? companyId = null;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    if (!string.IsNullOrEmpty(userId))
    {
        companyId = DbContext.UserCompanies
            .Where(uc => uc.UserId == userId)
            .Select(uc => uc.PartyInfoId.ToString())
            .FirstOrDefault();
    }
}
