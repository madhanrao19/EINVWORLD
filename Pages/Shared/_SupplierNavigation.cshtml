@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject eInvWorld.Data.ApplicationDbContext DbContext
@*
    Supplier role navigation (Tabler, "EinvWorld Professional"). Flat sectioned menu per the
    Navigation Master reference — every link the previous grouped menu carried is preserved, just
    rendered flat under small section labels (einvworld-ui.js highlights the active link by href).
    Resolves the caller's own company id (same query as before) for the "My Company" link.
    Cosmetic only — authorization is enforced server-side and unchanged.
*@
@{
    string? companyId = null;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    if (!string.IsNullOrEmpty(userId))
    {
        companyId = DbContext.UserCompanies
            .Where(uc => uc.UserId == userId)
            .Select(uc => uc.PartyInfoId.ToString())
            .FirstOrDefault();
    }
}
