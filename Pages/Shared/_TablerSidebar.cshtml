@using eInvWorld.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@*
    Tabler vertical sidebar shell. Brand + a mobile-collapsible container that renders the
    role-specific navigation partial. The role split mirrors the Velzon _Sidebar exactly; the actual
    access control is server-side and unchanged. Accessible: labelled toggler + aria-controls.
*@
@if (SignInManager.IsSignedIn(User))
{
    @* Light sidebar (Stitch "Navigation Master"): white surface + green active states, styled in
       einvworld-tokens.css. The dark-text logo variant is required on the light background. *@
    <aside class="navbar navbar-vertical navbar-expand-lg">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#einv-sidebar-menu"
                    aria-controls="einv-sidebar-menu" aria-expanded="false" aria-label="Toggle navigation menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a href="/Dashboard/Dashboard" class="navbar-brand" aria-label="EINVWORLD home">
                <img src="~/assets/images/einvworld-logo-dark.png" height="26" alt="eInvWorld">
            </a>

            <div class="collapse navbar-collapse" id="einv-sidebar-menu">
                <nav aria-label="Main navigation">
                    @if (User?.IsInRole("Admin") == true)
                    {
                        @await Html.PartialAsync("_AdminNavigation")
                    }
                    else if (User?.IsInRole("Supplier") == true)
                    {
                        @await Html.PartialAsync("_SupplierNavigation")
                    }
                    else if (User?.IsInRole("Buyer") == true)
                    {
                        @await Html.PartialAsync("_BuyerNavigation")
                    }
                </nav>

                @* Bottom-pinned utility links (Navigation Master): profile + sign out. The logout is
                   the same POST form the user menu uses — no new endpoints. *@
                <div class="einv-nav-bottom" role="navigation" aria-label="Account">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="/Profile/Index">
                                <span class="nav-link-icon" aria-hidden="true"><i class="ri-settings-3-line"></i></span>
                                <span class="nav-link-title">Profile &amp; Settings</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post" class="m-0">
                                <input type="hidden" name="logoutReason" value="manual" />
                                <button type="submit" class="nav-link w-100 border-0 bg-transparent text-start">
                                    <span class="nav-link-icon" aria-hidden="true"><i class="ri-logout-box-line"></i></span>
                                    <span class="nav-link-title">Logout</span>
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </aside>
}
