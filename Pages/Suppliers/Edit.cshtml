@page
@model eInvWorld.Pages.Suppliers.EditModel

@{
    ViewData["Title"] = "Edit Company";
}

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between bg-galaxy-transparent">
            <h4 class="mb-sm-0">@((Model.From == "lead") ? "Edit Lead Info" : "Edit Company Info")</h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Company Management</a></li>
                    <li class="breadcrumb-item active">Edit Company</li>
                </ol>
            </div>

        </div>
    </div>
</div>
<!-- end page title -->

<form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="PartyInfo.PartyInfoId" />
    <input type="hidden" asp-for="PartyInfo.CreatedBy" />


    <div class="row mb-3">

        <div class="col-md-6">
            <fieldset>
                <legend>General Information</legend>
                <!-- Supplier fields here -->

                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.CompanyName" class="control-label"></label>
                    <input asp-for="PartyInfo.CompanyName" class="form-control" />
                    <span asp-validation-for="PartyInfo.CompanyName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.RegTypeCode" class="control-label"></label>
                    <select asp-for="PartyInfo.RegTypeCode" class="form-control" asp-items="Model.IdTypesOptions" id="idTypeSelect">
                        <option value="">Select an ID Type</option> <!-- Optional placeholder -->
                    </select>
                    <span asp-validation-for="PartyInfo.RegTypeCode" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.TIN" class="control-label"></label>
                    <input asp-for="PartyInfo.TIN" class="form-control" id="PartyInfo_TaxIdentificationNumber" />
                    @* <button type="button" class="btn btn-secondary" id="validateTinBtn">Validate TIN</button> *@
                    <span asp-validation-for="PartyInfo.TIN" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.RegNo" class="control-label"></label>
                    <input asp-for="PartyInfo.RegNo" class="form-control" />
                    <span asp-validation-for="PartyInfo.RegNo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.SST" class="control-label"></label>
                    <input asp-for="PartyInfo.SST" class="form-control" />
                    <span asp-validation-for="PartyInfo.SST" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.TTX" class="control-label"></label>
                    <input asp-for="PartyInfo.TTX" class="form-control" />
                    <span asp-validation-for="PartyInfo.TTX" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.IndustryClassificationCode" class="control-label"></label>
                    <select asp-for="PartyInfo.IndustryClassificationCode" class="form-control" id="msicSelect">
                        <option value="">-- Select MSIC Code --</option>
                        @foreach (var msic in Model.MSICOptions)
                        {
                            <option value="@msic.Value" data-description="@msic.Text">
                                @msic.Text
                            </option>
                        }
                    </select>
                    <span asp-validation-for="PartyInfo.IndustryClassificationCode" class="text-danger"></span>
                </div>




                <!-- BizDesciption Field -->
                <div class="form-group mb-3" id="bizDescriptionContainer">
                    <label asp-for="PartyInfo.BizDescription" class="control-label"></label>
                    <textarea asp-for="PartyInfo.BizDescription" class="form-control" rows="3" id="PartyInfo_BizDescription"></textarea>
                    <span asp-validation-for="PartyInfo.BizDescription" class="text-danger"></span>
                </div>


                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.Email" class="control-label"></label>
                    <input asp-for="PartyInfo.Email" class="form-control" />
                    <span asp-validation-for="PartyInfo.Email" class="text-danger"></span>
                </div>
            </fieldset>
        </div>

        <div class="col-md-6">
            <fieldset>
                <legend>Address Information</legend>
                <!-- Address fields here -->

                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.Addr1" class="control-label">Full Address</label>
                    <textarea asp-for="PartyInfo.Addr1" class="form-control" rows="5" placeholder="Enter full address..."></textarea>
                    <span asp-validation-for="PartyInfo.Addr1" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.PostalCode" class="control-label"></label>
                    <input asp-for="PartyInfo.PostalCode" class="form-control" />
                    <span asp-validation-for="PartyInfo.PostalCode" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.CityName" class="control-label"></label>
                    <input asp-for="PartyInfo.CityName" class="form-control" />
                    <span asp-validation-for="PartyInfo.CityName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.StateCode" class="control-label"></label>
                    <select asp-for="PartyInfo.StateCode" class="form-control" asp-items="Model.StateOptions" id="stateSelect">
                        <option value="">-- Select a State --</option> <!-- Optional placeholder -->
                    </select>
                    <span asp-validation-for="PartyInfo.StateCode" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.CountryCode" class="control-label"></label>
                    <select asp-for="PartyInfo.CountryCode" class="form-control" asp-items="Model.CountryOptions" id="countrySelect">
                        <option value="">-- Select a Country --</option> <!-- Optional placeholder -->
                    </select>
                    <span asp-validation-for="PartyInfo.CountryCode" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.PhoneNo" class="control-label"></label>
                    <input asp-for="PartyInfo.PhoneNo" class="form-control" />
                    <span asp-validation-for="PartyInfo.PhoneNo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.FaxNo" class="control-label"></label>
                    <input asp-for="PartyInfo.FaxNo" class="form-control" />
                    <span asp-validation-for="PartyInfo.FaxNo" class="text-danger"></span>
                </div>
                <input type="hidden" id="id-field" />

                <!-- Additional Party Information -->
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.OldRegNo" class="control-label">Old Registration Number</label>
                    <input asp-for="PartyInfo.OldRegNo" class="form-control" placeholder="Previous business registration number" />
                    <span asp-validation-for="PartyInfo.OldRegNo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.BankAccountNo" class="control-label">Bank Account Number</label>
                    <input asp-for="PartyInfo.BankAccountNo" class="form-control" placeholder="Bank account number for payments" />
                    <span asp-validation-for="PartyInfo.BankAccountNo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.BankName" class="control-label">Bank Name</label>
                    <input asp-for="PartyInfo.BankName" class="form-control" placeholder="Name of the bank" />
                    <span asp-validation-for="PartyInfo.BankName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.Attention" class="control-label">Attention To</label>
                    <input asp-for="PartyInfo.Attention" class="form-control" placeholder="Person to whom invoices should be addressed" />
                    <span asp-validation-for="PartyInfo.Attention" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="PartyInfo.AuthorisationNumber" class="control-label">Certified Exporter Auth No.</label>
                    <input asp-for="PartyInfo.AuthorisationNumber" class="form-control"
                           placeholder="Authorisation Number for Certified Exporter" maxlength="300" />
                    <span asp-validation-for="PartyInfo.AuthorisationNumber" class="text-danger"></span>
                </div>
                <div class="text-center">
                    <div class="position-relative d-inline-block">
                        <div class="position-absolute bottom-0 end-0">
                            <label for="company-logo-input" class="mb-0" data-bs-toggle="tooltip" data-bs-placement="right" title="Select Image">
                                <div class="avatar-xs cursor-pointer">
                                    <div class="avatar-title bg-light border rounded-circle text-muted">
                                        <i class="ri-image-fill"></i>
                                    </div>
                                </div>
                            </label>
                            <input class="form-control d-none" name="LogoFile" id="company-logo-input" type="file" accept="image/png, image/gif, image/jpeg">
                        </div>
                        <div class="avatar-lg p-1">
                            <div class="avatar-title bg-light rounded-circle">
                                <img id="companylogo-img"
                                     class="avatar-md rounded-circle object-fit-cover"
                                     src="@(string.IsNullOrEmpty(Model.PartyInfo.LogoPath) ? Url.Content("~/assets/images/users/multi-user.jpg") : Url.Content(Model.PartyInfo.LogoPath))"
                                     data-saved="@(string.IsNullOrEmpty(Model.PartyInfo.LogoPath) ? "" : Url.Content(Model.PartyInfo.LogoPath))" />
                            </div>
                        </div>
                    </div>
                    <h5 class="fs-13 mt-3">Company Logo</h5>
                </div>
            </fieldset>
        </div>
    </div>

    <!-- Remarks field spanning three columns -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="form-group mb-3">
                <label asp-for="PartyInfo.Remarks" class="control-label"></label>
                <textarea asp-for="PartyInfo.Remarks" class="form-control" rows="3"></textarea>
                <span asp-validation-for="PartyInfo.Remarks" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group mb-3">
        <input type="submit" value="Save" class="btn btn-primary" />
    </div>
</form>


<div>
    <a class="btn btn-outline-secondary" asp-page="@(Model.From == "lead" ? "/Lead/List" : "./Index")">
        <i class="ri-arrow-left-line"></i> Back to List
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var msicSelect = document.getElementById("msicSelect");
            var bizDescriptionField = document.getElementById("PartyInfo_BizDescription");

            function updateBizDescription() {
                var selectedOption = msicSelect.options[msicSelect.selectedIndex];

                if (selectedOption) {
                    var description = selectedOption.getAttribute("data-description");

                    // ✅ Extract only the description part (removes code)
                    if (description.includes(" - ")) {
                        description = description.split(" - ")[1];
                    }

                    bizDescriptionField.value = description ? description : "";
                }
            }

            msicSelect.addEventListener("change", updateBizDescription);

            // ✅ Initialize BizDescription on page load
            window.onload = function () {
                updateBizDescription();
            };

            // ✅ 👇 Add this for logo preview on file select
            const fileInput = document.getElementById("company-logo-input");
            const previewImg = document.getElementById("companylogo-img");

            fileInput.addEventListener("change", function () {
                const file = fileInput.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        previewImg.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>



}
