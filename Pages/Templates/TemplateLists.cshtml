<!-- Enhanced Table Scroll JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tableScrolls = document.querySelectorAll('.table-scroll');
        
        tableScrolls.forEach(function(tableScroll) {
            const inner = tableScroll.querySelector('.inner');
            
            function updateScrollState() {
                const { scrollLeft, scrollWidth, clientWidth } = inner;
                const atLeft = scrollLeft <= 5;
                const atRight = scrollLeft >= scrollWidth - clientWidth - 5;
                
                tableScroll.classList.toggle('at-left', atLeft);
                tableScroll.classList.toggle('at-right', atRight);
            }
            
            inner.addEventListener('scroll', updateScrollState);
            window.addEventListener('resize', updateScrollState);
            updateScrollState();
        });
    });
</script>


<script>

    document.getElementById("checkAll").addEventListener("change", function () {
        const checkboxes = document.querySelectorAll(".template-checkbox");
        checkboxes.forEach(cb => cb.checked = this.checked);
    });

    function confirmDeleteSingle(templateId) {
        document.getElementById("deleteForm").action = "?handler=DeleteSingle";
        document.getElementById("deleteTemplateId").value = templateId;
        document.getElementById("bulkIds").value = "";
        new bootstrap.Modal(document.getElementById("deleteRecordModal")).show();
    }

    function deleteMultiple() {
        const selected = Array.from(document.querySelectorAll('.template-checkbox:checked'))
            .map(cb => cb.value);

        if (selected.length === 0) {
            alert("Please select at least one template to delete.");
            return;
        }

        document.getElementById("deleteForm").action = "?handler=DeleteMultiple";
        document.getElementById("deleteTemplateId").value = "";
        document.getElementById("bulkIds").value = selected.join(",");
        new bootstrap.Modal(document.getElementById("deleteRecordModal")).show();
    }

</script>

@if (TempData["StatusMessage"] != null)
{
    <script>
        window.addEventListener("DOMContentLoaded", () => {
            const toast = document.createElement("div");
            toast.className = "toast align-items-center text-white bg-success border-0 position-fixed bottom-0 end-0 m-3 show";
            toast.setAttribute("role", "alert");
            toast.innerHTML = `
                        <div class="d-flex">
                            <div class="toast-body">
        @TempData["StatusMessage"]
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>`;
            document.body.appendChild(toast);
            new bootstrap.Toast(toast).show();
        });
    </script>
}
