    <div class="col-lg-12">
        <div class="card" id="customerList">
            <div class="card-header border-bottom-dashed">

                <div class="row g-4 align-items-center">
                    <div class="col-sm">
                        <div>
                            <h5 class="card-title mb-0">e-Invoice Template Lists</h5>
                        </div>
                    </div>
                    <div class="col-sm-auto">
                        <div class="d-flex flex-wrap align-items-start gap-2">
                            <button type="button" class="btn btn-danger" id="remove-actions" onClick="deleteMultiple()" style="display:inline-block;" data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    title="Select at least one template to enable">
                                <i class="ri-delete-bin-6-line align-bottom me-1" disabled></i> Delete Selected
                            </button>
                        </div>
                    </div>
                </div>
            </div>
