{
  "AppInfo": {
    "Environment": "Production"
  },
  "Seeding": {
    // Never seed the well-known demo users in Production. Create your real admin via the app and enrol 2FA.
    "SeedDefaultUsers": false
  },
  "DatabaseSettings": {
    // true = apply pending EF migrations automatically on startup. The new-version migrations are
    // additive (new tables/columns/indexes — no Up() drops data), so existing data is preserved.
    // ALWAYS take a full DB backup before deploying, and ensure the app's SQL login has DDL rights.
    "AutoMigrateOnStartup": false
  },
  "DataProtection": {
    // REQUIRED in Production. Must point OUTSIDE the App folder so a redeploy that clears App\ does not
    // wipe the encryption keys (which would log everyone out and break 2FA/antiforgery). Create the
    // folder and grant the IIS app-pool identity Modify. Override per-server with env var
    // DataProtection__KeyRingPath if your layout differs.
    "KeyRingPath": ""
  },
  "EmailConfiguration": {
    "EmailBaseUrls": {
      "BaseUrl": "https://www.einvworld.com/"
    },
    "CustomerSubmission": {
      "Subject": "📩 New Customer Registration Submitted | {{CompanyName}}"
    },
    "RegisterAccountEmailSettings": {
      "Subject": "eInvWorld | Confirm Your Account"
    },
    "ContactUsEmailSettings": {
      "AdminSubject": "eInvWorld | New Contact Form Submission",
      "UserSubject": "eInvWorld | Thank You for Contacting Us"
    },
    "ValidatedEmailSettings": {
      "Subject": "eInvWorld | EInvoice Validated"
    },
    "RequestRejectEmailSettings": {
      "Subject": "eInvWorld | Request Reject"
    },
    "RequestCancelEmailSettings": {
      "Subject": "eInvWorld | Cancelled Invoice"
    }
  },
  "PDFGenerationSettings": {
    "BaseUrl": "https://www.einvworld.com"
  }
}