{
  "AppInfo": {
    "Name": "eInvWorld",
    "Version": "v1.4.0",
    "Environment": "Development"
  },
  // Encryption key ring location. MUST point OUTSIDE the App folder on the server (e.g. D:\\EINVWORLD\\Keys)
  // so a redeploy that clears App\ does not wipe the keys (which would log out all users and break sessions).
  // Set on the server via this value or the env var DataProtection__KeyRingPath. Empty = in-app fallback.
  "DataProtection": {
    "KeyRingPath": ""
  },
  // Security toggles. EnforceAdminMfa (default true) redirects any Admin without 2FA enabled to the
  // authenticator-setup page until they enroll (block-until-enrolled). Set false only as an emergency
  // escape hatch — admins can always self-enroll, so there is no hard lockout.
  // Default demo users (admin@/supplier@/buyer@einvworld.com). Seeded on startup ONLY when
  // SeedDefaultUsers=true. They have well-known passwords, so this is forced to FALSE in
  // appsettings.Production.json. Override the passwords via Seeding:DefaultAdminPassword etc. (env/secrets).
  "Seeding": {
    "SeedDefaultUsers": true
  },
  "Security": {
    "EnforceAdminMfa": true
    // HttpsRedirectPort (HTTP->HTTPS redirect) is intentionally NOT set here so the smart default applies:
    //   • ForwardedHeaders enabled (behind a TLS-terminating proxy / Cloudflare Tunnel) -> redirect OFF
    //     (the edge enforces HTTPS, e.g. Cloudflare "Always Use HTTPS"); an in-app redirect would loop.
    //   • Direct IIS HTTPS binding (ForwardedHeaders disabled) -> redirect ON, port 443.
    // To force it, add "HttpsRedirectPort": <port> (e.g. 443) to turn it on, or 0 to turn it off.
  },
  // Reverse-proxy / tunnel forwarded-header handling. Enable when TLS is terminated upstream and the app
  // is reached over plain HTTP (e.g. Cloudflare Tunnel -> http://localhost). The app then trusts
  // X-Forwarded-Proto (original scheme = https: correct cookies/redirects/HSTS) and X-Forwarded-For (real
  // client IP: correct per-IP rate limiting + audit/log IPs). Only headers from KnownProxies are honoured.
  // cloudflared on the same host = loopback (always trusted). Add KnownProxies if it runs elsewhere.
  "ForwardedHeaders": {
    "Enabled": true,
    "KnownProxies": [],
    "ForwardLimit": 1
  },
  // Import REST API. SECRET — set Api__Key via env var / user-secrets on the server to enable
  // POST /api/import/validate for an external ERP (header X-Api-Key). Empty = API disabled.
  "Api": {
    "Key": ""
  },
  // Inbound per-IP rate limiting (a generous DoS backstop; health probes are exempt). Increase
  // PermitsPerMinute if many users share one office NAT IP, or set Enabled=false to turn it off.
  "RateLimiting": {
    "Enabled": true,
    "PermitsPerMinute": 1200,
    // Stricter per-user cap on /Admin/InvoiceSync (each post enqueues background work).
    "AdminSyncPerMinute": 10
  },
  // Optional email alert when background sync jobs pile up in the Failed (dead-letter) state. OFF by
  // default; set Enabled=true and a RecipientEmail to use it. Throttled (re-alerts only on growth or after
  // CooldownHours) so it never spams.
  "SyncFailureAlerts": {
    "Enabled": false,
    "RecipientEmail": "",
    "Threshold": 1,
    "CheckMinutes": 15,
    "CooldownHours": 6
  },
  "Turnstile": {
    "SiteKey": "0x4AAAAAAAjucfRHqjzBJlrd",
    "_SecretKey_comment": "SECRET — set via user-secrets (dev) or env var Turnstile__SecretKey (server). See SECRETS-SETUP.md",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "_ConnectionStrings_comment": "SECRETS — set via user-secrets (dev) or env vars ConnectionStrings__DefaultConnection / ConnectionStrings__WebsiteDb (server). See SECRETS-SETUP.md",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "WebsiteDb": ""
  },
  "GoogleAnalytics": {
    "MeasurementId": "GTM-W2S2NPH7"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 365,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MSSqlServer",
        "_comment": "Writes app logs to the SystemLogs DB table (shown on Admin > System Logs). This sink OWNS the table and auto-creates it (autoCreateSqlTable=true); EF does NOT manage it. The columnOptionsSection below defines the schema — the admin Logs page reads it via Database.SqlQueryRaw<SystemLog> (DTO: Models/SystemLog.cs). Keep the two in sync.",
        "Args": {
          "connectionString": "DefaultConnection",
          "tableName": "SystemLogs",
          "autoCreateSqlTable": true,
          "columnOptionsSection": {
            "removeStandardColumns": [ "MessageTemplate", "Properties" ],
            "addStandardColumns": [ "LogEvent" ],
            "additionalColumns": [
              {
                "ColumnName": "IPAddress",
                "DataType": "nvarchar",
                "DataLength": 50
              },
              {
                "ColumnName": "UserName",
                "DataType": "nvarchar",
                "DataLength": 256
              }
            ]
          }
        }
      }
    ],

    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "CodeFilePaths": {
    "ClassificationCodes": "codes/ClassificationCodes.json",
    "CountryCodes": "codes/CountryCodes.json",
    "CurrencyCodes": "codes/CurrencyCodes.json",
    "EInvoiceTypes": "codes/EInvoiceTypes.json",
    "MSICSubCategoryCodes": "codes/MSICSubCategoryCodes.json",
    "PaymentMethods": "codes/PaymentMethods.json",
    "StateCodes": "codes/StateCodes.json",
    "TaxTypes": "codes/TaxTypes.json",
    "UnitTypes": "codes/UnitTypes.json"
  },
  "EmailConfiguration": {
    "Default": {
      "SmtpServer": "dgrpmail.datamationgroup.com",
      "SmtpPort": "587",
      "SmtpUsername": "testuser@datamationgroup.com",
      "SmtpPassword": "",
      "FromEmailName": "eInvWorld Website",
      "DisallowedEmailDomains": "gmail.com, yahoo.com, hotmail.com",
      "GlobalBccEmail": "test@einvworld.com"

    },
    "EmailBaseUrls": {
      "BaseUrl": "https://localhost:7073/",
      "InvoiceBaseUrl": "Invoices/InvoiceDetails2/",
      "AccountBaseUrl": "login",
      "RegisterAccBaseUrl": "register",
      "ContactBaseUrl": "contact"
    },
    "CustomerSubmission": {
      "ReceiverEmail": "test@einvworld.com",
      "Subject": "Dev | 📩 New Customer Registration Submitted | {{CompanyName}}"
    },
    "RegisterAccountEmailSettings": {
      "Subject": "Dev | eInvWorld | Confirm Your Account"
    },
    "ContactUsEmailSettings": {
      "ReceiverEmail": "test@einvworld.com", //Admin email
      "AdminSubject": "Dev | eInvWorld | New Contact Form Submission",
      "UserSubject": "Dev | eInvWorld | Thank You for Contacting Us"
    },
    "ValidatedEmailSettings": {
      "Subject": "Dev | eInvWorld | EInvoice Validated"
    },
    "RequestRejectEmailSettings": {
      "Subject": "Dev | eInvWorld | Request Reject"
    },
    "RequestCancelEmailSettings": {
      "Subject": "Dev | eInvWorld | Cancelled Invoice"
    },
    "Notifications": {
      "EnableRejectionEmails": true,
      "EnableCancellationEmails": true,
