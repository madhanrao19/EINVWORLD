  },
  "InvoiceStatusUpdaterSettings": {
    "Enabled": true,
    "PollingIntervalSeconds": 600,
    "UiRefreshIntervalSeconds": 30,
    "UiLhdnCooldownSeconds": 60
  },
  "PDFGenerationSettings": {
    "BaseUrl": "https://localhost:7073",
    "PlaywrightRenderDelayMs": 1000,
    // Max seconds to wait for a DinkToPdf (wkhtmltopdf) render before abandoning it (so a hung render
    // can't block the request forever). Default 60.
    "TimeoutSeconds": 60,
    // PDF engine: "DinkToPdf" (default) or "Puppeteer" (headless Chromium, maintained, no native DLL).
    // Switch to "Puppeteer" to evaluate its output; set ChromiumExecutablePath on an offline server.
    "Engine": "DinkToPdf",
    "ChromiumExecutablePath": ""
  },
  "LHDNApiConfig": {
    "BaseUrl": "https://preprod-api.myinvois.hasil.gov.my/",
    "ValidationBaseUrl": "https://preprod.myinvois.hasil.gov.my/",
    "TokenEndpoint": "/connect/token",
    "ClientId": "e45926d3-bb2a-4173-b659-a56c52f29466",
    "_secrets_comment": "ClientSecret / ClientSecret2 / CertPass are SECRETS — set via user-secrets (dev) or env vars LHDNApiConfig__ClientSecret etc (server). See SECRETS-SETUP.md",
    "ClientSecret": "",
    "ClientSecret2": "",
    "Scope": "InvoicingAPI",
    "OnBehalfOf": "C1865315040",
    // ── v1.1 digital signing switch ──────────────────────────────────────────────
    // Leave SigningEnabled=false to submit unsigned v1.0 documents (current behaviour).
    // When the signing certificate is purchased: set SigningEnabled=true, DocVersion="1.1",
    // CertPath to the .p12, and CertPass via user-secrets/env var. Validate against PREPROD first.
    "SigningEnabled": false,
    "DocVersion": "1.0",
    "SyncRetentionDays": 60, // 60 days for invoice sync retention sandbox
    "CertPath": "Cert/DATAMATION_TECHNOLOGY_(M)_SDN._BHD..p12",
    "CertPass": ""
  },
  "TaxpayerValidationSettings": {
    "DefaultTIN": "C1865315040", // Also used as default TIN for token caching and system identification
    "DefaultIdType": "BRN",
    "DefaultIdValue": "199601004511"
  },
  "FilePathConfig": {
    "BasePath": "E:\\EINVWORLD\\Documents",
    "DraftFolder": "E:\\EINVWORLD\\Documents\\Draft",
    "SubmittedFolder": "E:\\EINVWORLD\\Documents\\Submitted",
    "ValidFolder": "E:\\EINVWORLD\\Documents\\Valid",
    "InvalidFolder": "E:\\EINVWORLD\\Documents\\Invalid",
    "CancelledFolder": "E:\\EINVWORLD\\Documents\\Cancelled",
    "InvoiceCounterFilePath": "E:\\EINVWORLD\\Documents\\Counters",
    "JsonGeneratedFolder": "E:\\EINVWORLD\\Documents\\JsonGenerated",
    "GeneratedPdfFolder": "E:\\EINVWORLD\\Documents\\GeneratedPdf",
    "ResourceImagesFolder": "E:\\EINVWORLD\\Documents\\Resources\\Images",
    "EditorUploadsFolder": "E:\\EINVWORLD\\Documents\\Resources\\EditorUploads",
    "CompanyLogosFolder": "E:\\EINVWORLD\\Documents\\Companies\\Logos"

  },

  "DatabaseSettings": {
    "CommandTimeoutSeconds": 180,
    // true (default): apply EF migrations on startup. Set false in production to run migrations
    // as a controlled deploy step (`dotnet ef database update`) instead.
    "AutoMigrateOnStartup": true
  },
  "InvoiceSettings": {
    "BackdateSeconds": 60
  },
  "IdentityLockout": { //Identity lockout settings
    "AllowedForNewUsers": true,
    "DefaultLockoutMinutes": 15,
    "MaxFailedAccessAttempts": 5
  },
  "SessionSettings": {
    "IdleTimeoutMinutes": 60,
    "CookieName": ".eInvWorld.Session"
  },
  "LogCleanupSettings": {
    "RetentionDays": 365,
    // Rows deleted per batch by LogCleanupService (looped until caught up). Keeps each DELETE small so it
    // never holds a table lock or hits the command timeout on a large SystemLogs table.
    "BatchSize": 5000
  },
  // AI E-invoice Assistant — local, FOSS, on-prem LLM via Ollama (https://ollama.com).
  // OFF by default. To enable: install Ollama on the server, run `ollama pull llama3.2:3b`,
  // then set Enabled=true. No invoice data leaves the server.
  // Model note: llama3.2:3b (~2 GB) is the recommended default — it fits a modest server's RAM. Larger
  // models (e.g. llama3.1 8B ~5 GB, or 70B) can fail to allocate memory ("failed to allocate buffer ..."),
  // which makes the request time out. Only move up if the server has the RAM/VRAM to spare.
  "AIAssistant": {
    "Enabled": false,
    "Provider": "Ollama",
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2:3b",
    "TimeoutSeconds": 120
  },

  // AI Document Capture: upload an invoice PDF, extract its text, and turn it into a reviewed invoice
  // suggestion via the local LLM (draft-only). Requires AIAssistant:Enabled=true as well.
  // OCR (scanned PDFs): set OcrEnabled=true AND TessdataPath to a folder holding eng.traineddata (and
  // msa.traineddata for Malay). Needs the native Tesseract/PDFium runtimes deployed — see the deploy guide.
  // Leave OcrEnabled=false (default) for digital-text PDFs only; the native libraries then never load.
  "DocumentCapture": {
    "Enabled": false,
    "MaxFileSizeMb": 10,
    "MaxPages": 15,
    "OcrEnabled": false,
    "TessdataPath": "",
    "OcrLanguage": "eng",
    "OcrDpi": 300
  },

  // Watched-folder importer: validates CSV/XLSX dropped into InboxPath and moves them to
  // Processed/ or Rejected/ with a .report.json. Validation-only; never creates invoices.
  "WatchedFolderImport": {
    "Enabled": false,
    "InboxPath": "",
    "PollSeconds": 30
  }

}
